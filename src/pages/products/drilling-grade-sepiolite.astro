---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/"},
    {"@type": "ListItem", "position": 2, "name": "Products", "item": "https://sepiolitemine.com/products/"},
    {"@type": "ListItem", "position": 3, "name": "Drilling Grade Sepiolite", "item": "https://sepiolitemine.com/products/drilling-grade-sepiolite/"}
  ]
},
  {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Drilling Grade Sepiolite",
  "description": "API-compliant drilling grade sepiolite for oil and gas drilling fluids. Stable rheology up to 300°C in saline environments. FOB Port of Mersin or Samsun.",
  "image": ["https://sepiolitemine.com/images/products/product-drilling-grade.webp"],
  "sku": "SM-DRILL-001",
  "brand": {"@type": "Brand", "name": "Sepiolite Mine"},
  "manufacturer": {"@type": "Organization", "name": "Zamana", "url": "https://zamana.com.tr"},
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://sepiolitemine.com/products/drilling-grade-sepiolite/",
    "seller": {"@type": "Organization", "name": "Sepiolite Mine"}
  },
  "countryOfOrigin": {"@type": "Country", "name": "Turkey"}
},
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Does your drilling grade sepiolite meet API specifications?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, our product is manufactured and tested to meet API Specification 13A requirements. Certificates of compliance are provided with every shipment."}
    },    {
      "@type": "Question",
      "name": "At what temperature does sepiolite outperform bentonite?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sepiolite maintains stable rheology up to 300°C, while bentonite typically begins to flocculate above 120°C. Above 150°C, sepiolite is the clear choice."}
    },    {
      "@type": "Question",
      "name": "What is the recommended concentration for drilling fluids?",
      "acceptedAnswer": {"@type": "Answer", "text": "Typical concentrations range from 2–6% by weight depending on required rheology. Our technical team can provide optimized formulations for your specific well conditions."}
    },    {
      "@type": "Question",
      "name": "Can sepiolite be used alongside other drilling fluid additives?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, sepiolite is compatible with most standard drilling fluid additives including polymers, lubricants, and fluid loss control agents. Contact us for compatibility guidance."}
    },    {
      "@type": "Question",
      "name": "What is the minimum order for drilling grade sepiolite?",
      "acceptedAnswer": {"@type": "Answer", "text": "Minimum order is 20 metric tons. For oilfield service companies with regular requirements, we offer annual supply agreements with volume discounts."}
    }
  ]
}
];
---

<Layout
  title="Drilling Grade Sepiolite – Oil & Gas Rheology"
  description="API-compliant drilling grade sepiolite for oil and gas drilling fluids. Stable rheology up to 300°C in saline environments. FOB Port of Mersin or Samsun."
  locale="en"
  alternates={{ en: "/products/drilling-grade-sepiolite/", tr: "/tr/products/sondaj-kalitesi-sepiyolit/" }}
  schemaJson={schemaJson}
>
<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="../../">Home</a>
      <span class="sep">›</span>
      <a href="../">Products</a>
      <span class="sep">›</span>
      <span class="current">Drilling Grade Sepiolite</span>
    </nav>
  </div>
</div>

<section class="product-hero">
  <div class="container">
    <div class="product-hero-grid">

      <div class="product-gallery">
        <div class="product-main-img" id="mainImg">
          <img width="1200" height="896" src="/images/products/product-drilling-grade.webp" alt="Drilling grade sepiolite – API-compliant rheology modifier" id="mainImgSrc" />
        </div>
        <div class="product-thumbs">
          <div class="product-thumb active" onclick="switchImage(this, '/images/products/product-drilling-grade.webp', 'Drilling Grade Sepiolite')">
            <img width="1200" height="896" src="/images/products/product-drilling-grade.webp" alt="Drilling Grade Sepiolite" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/factory/factory-interior-01.webp', 'Sepiolite processing for drilling grade')">
            <img width="554" height="554" src="/images/factory/factory-interior-01.webp" alt="Sepiolite processing for drilling grade" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-03.webp', 'Drilling Grade Sepiolite sample')">
            <img width="506" height="900" src="/images/products/product-sample-03.webp" alt="Drilling Grade Sepiolite sample" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-04.webp', 'Drilling Grade Sepiolite detail')">
            <img width="506" height="900" src="/images/products/product-sample-04.webp" alt="Drilling Grade Sepiolite detail" loading="lazy" />
          </div>
        </div>
      </div>

      <div class="product-info">
        <div class="product-badge">Oil & Gas</div>
        <h1 class="product-h1">Drilling Grade <em>Sepiolite</em></h1>
        <p class="product-tagline">API-compliant rheology modifier engineered for the most demanding downhole conditions. Stable performance in saline, high-temperature environments where conventional clays fail.</p>

        <div class="key-specs">
          <div class="key-spec">
            <div class="key-spec-value">300°C</div>
            <div class="key-spec-label">Thermal Stability</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">API</div>
            <div class="key-spec-label">Compliance</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">Salt OK</div>
            <div class="key-spec-label">Brine Tolerance</div>
          </div>
        </div>

        <div class="price-box">
          <div class="price-box-header">
            <span class="price-label">Bulk Pricing</span>
            <span class="price-availability">In Stock</span>
          </div>
          <div class="price-value">TBD</div>
          <div class="price-unit">Price per metric ton · FOB Port of Mersin or FOB Samsun Port, Turkey · Contact for CIF pricing</div>
          <div class="price-features">
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
