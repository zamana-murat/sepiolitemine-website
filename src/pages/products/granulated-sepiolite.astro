---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/"},
    {"@type": "ListItem", "position": 2, "name": "Products", "item": "https://sepiolitemine.com/products/"},
    {"@type": "ListItem", "position": 3, "name": "Granulated Sepiolite", "item": "https://sepiolitemine.com/products/granulated-sepiolite/"}
  ]
},
  {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Granulated Sepiolite",
  "description": "Premium granulated sepiolite in 0-2mm, 2-4mm, and 4-8mm fractions. Ideal for cat litter, agriculture, and industrial absorbent markets. FOB Mersin/Samsun.",
  "image": ["https://sepiolitemine.com/images/products/product-granulated.webp"],
  "sku": "SM-GRAN-001",
  "brand": {"@type": "Brand", "name": "Sepiolite Mine"},
  "manufacturer": {"@type": "Organization", "name": "Zamana", "url": "https://zamana.com.tr"},
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://sepiolitemine.com/products/granulated-sepiolite/",
    "seller": {"@type": "Organization", "name": "Sepiolite Mine"}
  },
  "countryOfOrigin": {"@type": "Country", "name": "Turkey"}
},
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What size fractions are available for granulated sepiolite?",
      "acceptedAnswer": {"@type": "Answer", "text": "We offer three standard fractions: 0–2mm (fine), 2–4mm (medium), and 4–8mm (coarse). Custom fractions can be produced on request with minimum order quantities."}
    },    {
      "@type": "Question",
      "name": "Is granulated sepiolite safe for use as cat litter?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, sepiolite is a naturally occurring, non-toxic mineral. It is widely used in Europe as a premium cat litter due to its high absorption, natural clumping, and odor control properties."}
    },    {
      "@type": "Question",
      "name": "What is the minimum order for granulated sepiolite?",
      "acceptedAnswer": {"@type": "Answer", "text": "Minimum order is 20 metric tons (one 20-foot container). We also accommodate larger orders in 40-foot containers or break-bulk shipments."}
    },    {
      "@type": "Question",
      "name": "How does sepiolite compare to bentonite for cat litter?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sepiolite offers higher absorption capacity (120%+ vs 80% for bentonite), lighter weight, lower dust, and better odor control. It does not swell as much when wet, making it easier to clean."}
    },    {
      "@type": "Question",
      "name": "Can you produce private-label cat litter products?",
      "acceptedAnswer": {"@type": "Answer", "text": "We supply granulated sepiolite as a raw material in bulk. For private-label or retail packaging, we can discuss arrangements with qualified distributors."}
    }
  ]
}
];
---

<Layout
  title="Granulated Sepiolite – Precision-Sized Granules"
  description="Premium granulated sepiolite in 0-2mm, 2-4mm, and 4-8mm fractions. Ideal for cat litter, agriculture, and industrial absorbent markets. FOB Mersin/Samsun."
  locale="en"
  alternates={{ en: "/products/granulated-sepiolite/", tr: "/tr/products/granule-sepiyolit/" }}
  schemaJson={schemaJson}
>
<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="../../">Home</a>
      <span class="sep">›</span>
      <a href="../">Products</a>
      <span class="sep">›</span>
      <span class="current">Granulated Sepiolite</span>
    </nav>
  </div>
</div>

<section class="product-hero">
  <div class="container">
    <div class="product-hero-grid">

      <div class="product-gallery">
        <div class="product-main-img" id="mainImg">
          <img width="675" height="900" src="/images/products/product-granulated.webp" alt="Granulated sepiolite – precision-sized mineral granules" id="mainImgSrc" />
        </div>
        <div class="product-thumbs">
          <div class="product-thumb active" onclick="switchImage(this, '/images/products/product-granulated.webp', 'Granulated Sepiolite')">
            <img width="675" height="900" src="/images/products/product-granulated.webp" alt="Granulated Sepiolite" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/mine/mine-landscape-08.webp', 'Sepiolite processing facility')">
            <img width="1600" height="1200" src="/images/mine/mine-landscape-08.webp" alt="Sepiolite processing facility" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-03.webp', 'Granulated Sepiolite sample')">
            <img width="506" height="900" src="/images/products/product-sample-03.webp" alt="Granulated Sepiolite sample" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-04.webp', 'Granulated Sepiolite detail')">
            <img width="506" height="900" src="/images/products/product-sample-04.webp" alt="Granulated Sepiolite detail" loading="lazy" />
          </div>
        </div>
      </div>

      <div class="product-info">
        <div class="product-badge">Processed</div>
        <h1 class="product-h1">Granulated <em>Sepiolite</em></h1>
        <p class="product-tagline">Precision-sized granules engineered for maximum absorption. Available in multiple size fractions with controlled moisture content and minimal dust generation.</p>

        <div class="key-specs">
          <div class="key-spec">
            <div class="key-spec-value">0–8mm</div>
            <div class="key-spec-label">Size Range</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">Low</div>
            <div class="key-spec-label">Dust Content</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">≤12%</div>
            <div class="key-spec-label">Moisture</div>
          </div>
        </div>

        <div class="price-box">
          <div class="price-box-header">
            <span class="price-label">Bulk Pricing</span>
            <span class="price-availability">In Stock</span>
          </div>
          <div class="price-value">TBD</div>
          <div class="price-unit">Price per metric ton · FOB Port of Mersin or FOB Samsun Port, Turkey · Contact for CIF pricing</div>
          <div class="price-features">
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Minimum order: 20 MT (one container)
            </div>
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Certificate of Analysis included with every shipment
            </div>
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Free samples available for qualified buyers
            </div>
          </div>
          <div class="price-actions">
            <a href="../../#contact" class="btn btn-primary">Request a Quote</a>
            <a href="../../#contact" class="btn btn-outline">Request Sample</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<section class="product-desc-section">
  <div class="container">
    <div class="product-desc-grid">
      <div class="product-desc">
        <div class="section-tag">Product Overview</div>
        <div class="divider"></div>
        <h2>Engineered Granules for <span>Maximum</span> Performance</h2>
        <p>Our granulated sepiolite is produced by crushing and screening raw ore into precisely controlled size fractions. The granulation process preserves the mineral's natural fibrous microstructure while creating uniform, free-flowing granules with exceptional absorption capacity.</p>
        <p>Available in three standard size fractions — 0–2mm (fine), 2–4mm (medium), and 4–8mm (coarse) — each optimized for specific end-use applications. Custom size fractions can be produced upon request for clients with specialized requirements.</p>
        <p>The low-dust formulation makes our granulated sepiolite particularly valued in the cat litter industry, where clean handling and superior odor control are essential. Agricultural clients benefit from the granules' slow-release carrier properties for fertilizers and pesticides.</p>
        <p>Each batch undergoes rigorous quality control including sieve analysis, moisture testing, and absorption capacity measurement. Consistent quality across shipments ensures your production line runs without interruption.</p>
      </div>
      <div>
        <div class="tech-specs-card">
          <h3>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L18 7V13L10 18L2 13V7L10 2Z" stroke="#C9922A" stroke-width="1.5" fill="none"/><circle cx="10" cy="10" r="3" fill="#C9922A"/></svg>
            Technical Specifications
          </h3>
          <div class="spec-row">
            <span class="spec-label">Product Form</span>
            <span class="spec-value">Granules</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Size Fractions</span>
            <span class="spec-value">0–2 / 2–4 / 4–8 mm</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Bulk Density</span>
            <span class="spec-value">0.5–0.7 g/cm³</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Absorption Capacity</span>
            <span class="spec-value">≥ 120% by weight</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Moisture</span>
            <span class="spec-value">≤ 12%</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">MgO</span>
            <span class="spec-value">≥ 18%</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">SiO₂</span>
            <span class="spec-value">≥ 54%</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Dust Content</span>
            <span class="spec-value">< 2%</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Color</span>
            <span class="spec-value">White to Light Cream</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Packaging</span>
            <span class="spec-value">25kg / 1 MT Bags</span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Delivery</span>
            <span class="spec-value">FOB Mersin / Samsun</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="usage-section">
  <div class="container">
    <div class="usage-header">
      <div class="section-tag" style="color:var(--gold-light);">Applications</div>
      <div class="divider divider--center"></div>
      <h2 class="section-title" style="color:var(--white);">Where Granulated Sepiolite <span>Is Used</span></h2>
    </div>
    <div class="usage-grid">
      <div class="usage-card reveal">
        <div class="usage-icon">🐾</div>
        <h3>Cat Litter & Pet Care</h3>
        <p>The primary market for granulated sepiolite. Our granules offer 3x absorption of standard clay litters with natural clumping and superior odor neutralization. Preferred across European and Middle Eastern markets.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🌾</div>
        <h3>Agricultural Carriers</h3>
        <p>Used as a carrier substrate for fertilizers, herbicides, and pesticides. The porous granule structure enables controlled slow-release delivery, reducing application frequency and environmental runoff.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🛢️</div>
        <h3>Industrial Absorbents</h3>
        <p>Deployed on factory floors and workshops for oil, chemical, and liquid spill cleanup. Granulated sepiolite absorbs quickly, encapsulates contaminants, and can be safely disposed or incinerated.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🏭</div>
        <h3>Animal Feed Additive</h3>
        <p>Used as an anti-caking agent and mycotoxin binder in animal feed formulations. The mineral's natural safety profile makes it ideal for livestock and poultry nutrition applications.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🧪</div>
        <h3>Water Treatment</h3>
        <p>Granulated sepiolite effectively removes heavy metals, dyes, and organic pollutants from industrial wastewater through its extensive micropore network and high surface area.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🔬</div>
        <h3>Laboratory & Filtration</h3>
        <p>Used as a filtration medium in laboratory and industrial settings. The controlled granule size enables precise flow rates and efficient separation of particulates from liquids.</p>
      </div>
    </div>
  </div>
</section>

<section class="advantages-section">
  <div class="container">
    <div class="advantages-grid">
      <div>
        <div class="section-tag">Why Choose Us</div>
        <div class="divider"></div>
        <h2 class="section-title">Key <span>Advantages</span></h2>
        <div class="advantage-list">
          <div class="advantage-item reveal">
            <div class="advantage-num">01</div>
            <div>
              <strong>Custom Size Fractions</strong>
              <p>We produce granules to your exact specification — from fine 0–2mm for premium cat litter to coarse 4–8mm for industrial absorbent applications.</p>
            </div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">02</div>
            <div>
              <strong>Minimal Dust Generation</strong>
              <p>Our advanced screening process achieves < 2% dust content, ensuring clean handling, packaging, and end-user experience.</p>
            </div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">03</div>
            <div>
              <strong>Consistent Batch Quality</strong>
              <p>Every shipment is sieve-tested and moisture-verified. We maintain ± 5% consistency on particle size distribution across orders.</p>
            </div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">04</div>
            <div>
              <strong>High Absorption Capacity</strong>
              <p>Granulated sepiolite absorbs ≥ 120% of its weight in liquid — outperforming bentonite, diatomite, and most synthetic absorbents.</p>
            </div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">05</div>
            <div>
              <strong>Scalable Supply</strong>
              <p>From single containers to full vessel loads, we maintain ready stock at our facility for rapid dispatch to any global destination.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="advantage-image">
        <img width="1600" height="1200" src="/images/mine/mine-landscape-09.webp" alt="Sepiolite mine – Zamana Turkey" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<section class="faq-section">
  <div class="container">
    <div class="faq-header">
      <div class="section-tag">Common Questions</div>
      <div class="divider divider--center"></div>
      <h2 class="section-title">Frequently Asked <span>Questions</span></h2>
    </div>
    <div class="faq-list">
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          What size fractions are available for granulated sepiolite?
          <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="faq-answer"><div class="faq-answer-inner">
          We offer three standard fractions: 0–2mm (fine), 2–4mm (medium), and 4–8mm (coarse). Custom fractions can be produced on request with minimum order quantities.
        </div></div>
      </div>
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          Is granulated sepiolite safe for use as cat litter?
          <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="faq-answer"><div class="faq-answer-inner">
          Yes, sepiolite is a naturally occurring, non-toxic mineral. It is widely used in Europe as a premium cat litter due to its high absorption, natural clumping, and odor control properties.
        </div></div>
      </div>
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          What is the minimum order for granulated sepiolite?
          <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="faq-answer"><div class="faq-answer-inner">
          Minimum order is 20 metric tons (one 20-foot container). We also accommodate larger orders in 40-foot containers or break-bulk shipments.
        </div></div>
      </div>
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          How does sepiolite compare to bentonite for cat litter?
          <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="faq-answer"><div class="faq-answer-inner">
          Sepiolite offers higher absorption capacity (120%+ vs 80% for bentonite), lighter weight, lower dust, and better odor control. It does not swell as much when wet, making it easier to clean.
        </div></div>
      </div>
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          Can you produce private-label cat litter products?
          <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="faq-answer"><div class="faq-answer-inner">
          We supply granulated sepiolite as a raw material in bulk. For private-label or retail packaging, we can discuss arrangements with qualified distributors.
        </div></div>
      </div>
    </div>
  </div>
</section>

<section class="related-section">
  <div class="container">
    <div class="related-header">
      <div class="section-tag">More Products</div>
      <div class="divider divider--center"></div>
      <h2 class="section-title">Explore Our Other <span>Grades</span></h2>
    </div>
    <div class="related-grid">
      <div class="related-card reveal">
        <div class="related-card-img">
          <img width="506" height="900" src="/images/products/product-raw-ore.webp" alt="Raw Sepiolite Ore" loading="lazy" />
        </div>
        <div class="related-card-body">
          <h3>Raw Sepiolite Ore</h3>
          <p>Directly mined sepiolite in natural block form with natural fiber structure intact.</p>
          <a href="../raw-sepiolite-ore/" class="related-link">View Product <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
        </div>
      </div>
      <div class="related-card reveal">
        <div class="related-card-img">
          <img width="1200" height="896" src="/images/products/product-milled-powder.webp" alt="Milled Sepiolite Powder" loading="lazy" />
        </div>
        <div class="related-card-body">
          <h3>Milled Sepiolite Powder</h3>
          <p>Ultra-fine micronized powder for paints, coatings, and pharmaceuticals.</p>
          <a href="../milled-sepiolite-powder/" class="related-link">View Product <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
        </div>
      </div>
      <div class="related-card reveal">
        <div class="related-card-img">
          <img width="1200" height="896" src="/images/products/product-drilling-grade.webp" alt="Drilling Grade Sepiolite" loading="lazy" />
        </div>
        <div class="related-card-body">
          <h3>Drilling Grade Sepiolite</h3>
          <p>Rheology modifier for oil and gas drilling fluids, stable up to 300°C.</p>
          <a href="../drilling-grade-sepiolite/" class="related-link">View Product <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
        </div>
      </div>
    </div>
  </div>
</section>





<script defer>
  function switchImage(thumb, src, alt) {
    document.getElementById('mainImgSrc').src = src;
    document.getElementById('mainImgSrc').alt = alt;
    document.querySelectorAll('.product-thumb').forEach(function(t) { t.classList.remove('active'); });
    thumb.classList.add('active');
  }
  function toggleFaq(el) {
    var item = el.parentElement;
    var wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
    if (!wasOpen) item.classList.add('open');
  }
  document.addEventListener('DOMContentLoaded', function () {
    var revealObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); revealObserver.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(function(el) { revealObserver.observe(el); });
    var navbar = document.getElementById('navbar');
    if (navbar) {
      window.addEventListener('scroll', function() { navbar.classList.toggle('scrolled', window.scrollY > 60); }, { passive: true });
    }
    document.addEventListener('click', function(e) {
      var ham = e.target.closest('#hamburger');
      if (ham) {
        var menu = document.getElementById('mobileMenu');
        var isOpen = menu && menu.classList.toggle('open');
        ham.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        if (menu) menu.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      }
      if (e.target.closest('#mobileMenu a')) {
        var menu2 = document.getElementById('mobileMenu');
        var ham2  = document.getElementById('hamburger');
        if (menu2) { menu2.classList.remove('open'); menu2.setAttribute('aria-hidden','true'); }
        if (ham2)  { ham2.setAttribute('aria-expanded','false'); }
      }
    });
  });
</script>
</Layout>

<style is:global>
/* ===== PRODUCT HERO ===== */
    .product-hero {
      padding: 3.5rem 0 4rem;
      background: var(--cream);
    }
    .product-hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem;
      align-items: start;
    }
    .product-gallery {
      position: sticky;
      top: 80px;
    }
    .product-main-img {
      border-radius: var(--radius-lg);
      overflow: hidden;
      aspect-ratio: 4/3;
      background: var(--white);
      box-shadow: var(--shadow-md);
      border: 1px solid var(--cream-dark);
    }
    .product-main-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .product-thumbs {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .product-thumb {
      border-radius: var(--radius);
      overflow: hidden;
      aspect-ratio: 1;
      cursor: pointer;
      border: 2px solid transparent;
      transition: var(--transition);
      background: var(--white);
    }
    .product-thumb:hover,
    .product-thumb.active {
      border-color: var(--gold);
      box-shadow: 0 4px 12px rgba(201,146,42,0.25);
    }
    .product-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .product-info {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .product-badge {
      display: inline-flex;
