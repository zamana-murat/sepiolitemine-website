---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/"},
    {"@type": "ListItem", "position": 2, "name": "Products", "item": "https://sepiolitemine.com/products/"},
    {"@type": "ListItem", "position": 3, "name": "Milled Sepiolite Powder", "item": "https://sepiolitemine.com/products/milled-sepiolite-powder/"}
  ]
},
  {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Milled Sepiolite Powder",
  "description": "Ultra-fine milled sepiolite powder from 5–200 microns. High surface area for paints, coatings, pharmaceuticals, cosmetics, and ceramics. FOB Mersin/Samsun.",
  "image": ["https://sepiolitemine.com/images/products/product-milled-powder.webp"],
  "sku": "SM-MILL-001",
  "brand": {"@type": "Brand", "name": "Sepiolite Mine"},
  "manufacturer": {"@type": "Organization", "name": "Zamana", "url": "https://zamana.com.tr"},
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://sepiolitemine.com/products/milled-sepiolite-powder/",
    "seller": {"@type": "Organization", "name": "Sepiolite Mine"}
  },
  "countryOfOrigin": {"@type": "Country", "name": "Turkey"}
},
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What particle sizes are available for milled sepiolite?",
      "acceptedAnswer": {"@type": "Answer", "text": "We offer grades ranging from 5 to 200 microns. Standard grades include ultra-fine (D50: 15μm), fine (D50: 25μm), medium (D50: 45μm), and coarse (D50: 100μm+). Custom milling is available."}
    },    {
      "@type": "Question",
      "name": "Is milled sepiolite suitable for food-contact applications?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sepiolite is approved for food-contact use in many jurisdictions. We can provide specific compliance documentation upon request for your target market."}
    },    {
      "@type": "Question",
      "name": "How does sepiolite powder compare to fumed silica as a thickener?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sepiolite provides similar thixotropic performance at lower cost. It offers better suspension of heavy pigments and is easier to disperse without specialized equipment."}
    },    {
      "@type": "Question",
      "name": "What is the shelf life of milled sepiolite powder?",
      "acceptedAnswer": {"@type": "Answer", "text": "When stored in sealed packaging in dry conditions, milled sepiolite has an indefinite shelf life. The mineral is chemically stable and does not degrade over time."}
    },    {
      "@type": "Question",
      "name": "Can you provide samples for formulation testing?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, we supply 1–5 kg samples of all powder grades with full technical data sheets. Contact our sales team to specify your required particle size."}
    }
  ]
}
];
---

<Layout
  title="Milled Sepiolite Powder – Micronized Fine Grade"
  description="Ultra-fine milled sepiolite powder from 5–200 microns. High surface area for paints, coatings, pharmaceuticals, cosmetics, and ceramics. FOB Mersin/Samsun."
  locale="en"
  alternates={{ en: "/products/milled-sepiolite-powder/", tr: "/tr/products/ogutulmus-sepiyolit-tozu/" }}
  schemaJson={schemaJson}
>
<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="../../">Home</a>
      <span class="sep">›</span>
      <a href="../">Products</a>
      <span class="sep">›</span>
      <span class="current">Milled Sepiolite Powder</span>
    </nav>
  </div>
</div>

<section class="product-hero">
  <div class="container">
    <div class="product-hero-grid">

      <div class="product-gallery">
        <div class="product-main-img" id="mainImg">
          <img width="1200" height="896" src="/images/products/product-milled-powder.webp" alt="Milled sepiolite powder – ultra-fine micronized mineral" id="mainImgSrc" />
        </div>
        <div class="product-thumbs">
          <div class="product-thumb active" onclick="switchImage(this, '/images/products/product-milled-powder.webp', 'Milled Sepiolite Powder')">
            <img width="1200" height="896" src="/images/products/product-milled-powder.webp" alt="Milled Sepiolite Powder" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/factory/factory-interior-02.webp', 'Sepiolite milling facility')">
            <img width="808" height="380" src="/images/factory/factory-interior-02.webp" alt="Sepiolite milling facility" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-03.webp', 'Milled Sepiolite Powder sample')">
            <img width="506" height="900" src="/images/products/product-sample-03.webp" alt="Milled Sepiolite Powder sample" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-04.webp', 'Milled Sepiolite Powder detail')">
            <img width="506" height="900" src="/images/products/product-sample-04.webp" alt="Milled Sepiolite Powder detail" loading="lazy" />
          </div>
        </div>
      </div>

      <div class="product-info">
        <div class="product-badge">Fine Grade</div>
        <h1 class="product-h1">Milled Sepiolite <em>Powder</em></h1>
        <p class="product-tagline">Ultra-fine micronized powder with precisely controlled particle distribution. Engineered for paints, coatings, pharmaceuticals, cosmetics, and advanced ceramic applications.</p>

        <div class="key-specs">
          <div class="key-spec">
            <div class="key-spec-value">5–200μm</div>
            <div class="key-spec-label">Particle Size</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">300m²/g</div>
            <div class="key-spec-label">Surface Area</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">99.5%</div>
            <div class="key-spec-label">Purity</div>
          </div>
        </div>

        <div class="price-box">
          <div class="price-box-header">
            <span class="price-label">Bulk Pricing</span>
            <span class="price-availability">In Stock</span>
          </div>
          <div class="price-value">TBD</div>
          <div class="price-unit">Price per metric ton · FOB Port of Mersin or FOB Samsun Port, Turkey · Contact for CIF pricing</div>
          <div class="price-features">
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
