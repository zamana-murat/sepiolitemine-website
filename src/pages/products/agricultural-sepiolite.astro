---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/"},
    {"@type": "ListItem", "position": 2, "name": "Products", "item": "https://sepiolitemine.com/products/"},
    {"@type": "ListItem", "position": 3, "name": "Agricultural Sepiolite", "item": "https://sepiolitemine.com/products/agricultural-sepiolite/"}
  ]
},
  {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Agricultural Sepiolite",
  "description": "Agricultural grade sepiolite for fertilizer carriers, soil amendment, and pesticide delivery. Improves water retention and nutrient efficiency. FOB Mersin/Samsun.",
  "image": ["https://sepiolitemine.com/images/products/product-agriculture.webp"],
  "sku": "SM-AGRI-001",
  "brand": {"@type": "Brand", "name": "Sepiolite Mine"},
  "manufacturer": {"@type": "Organization", "name": "Zamana", "url": "https://zamana.com.tr"},
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://sepiolitemine.com/products/agricultural-sepiolite/",
    "seller": {"@type": "Organization", "name": "Sepiolite Mine"}
  },
  "countryOfOrigin": {"@type": "Country", "name": "Turkey"}
},
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is agricultural sepiolite safe for organic farming?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, our agricultural grade is certified for organic farming use in the EU. It is a naturally occurring mineral with no synthetic additives or chemical treatments."}
    },    {
      "@type": "Question",
      "name": "What application rate is recommended for soil conditioning?",
      "acceptedAnswer": {"@type": "Answer", "text": "Typical application is 5–10% by volume mixed into the root zone. For sandy soils, higher rates provide greater benefit. Our technical team can advise for your specific soil type."}
    },    {
      "@type": "Question",
      "name": "Can sepiolite be used with liquid fertilizers?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, sepiolite granules readily absorb liquid fertilizers and convert them into a dry, free-flowing product that is easy to handle, store, and apply with standard equipment."}
    },    {
      "@type": "Question",
      "name": "Does sepiolite affect soil pH?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sepiolite has a slightly alkaline pH (7.5–9.0) which can be beneficial for acidic soils. In neutral to alkaline soils, the effect is minimal at recommended application rates."}
    },    {
      "@type": "Question",
      "name": "What is the minimum order for agricultural sepiolite?",
      "acceptedAnswer": {"@type": "Answer", "text": "Minimum order is 20 metric tons. Seasonal contracts and annual supply agreements are available with preferential pricing for agricultural distributors."}
    }
  ]
}
];
---

<Layout
  title="Agricultural Sepiolite – Soil & Carrier Grade"
  description="Agricultural grade sepiolite for fertilizer carriers, soil amendment, and pesticide delivery. Improves water retention and nutrient efficiency. FOB Mersin/Samsun."
  locale="en"
  alternates={{ en: "/products/agricultural-sepiolite/", tr: "/tr/products/tarimsal-sepiyolit/" }}
  schemaJson={schemaJson}
>
<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="../../">Home</a>
      <span class="sep">›</span>
      <a href="../">Products</a>
      <span class="sep">›</span>
      <span class="current">Agricultural Sepiolite</span>
    </nav>
  </div>
</div>

<section class="product-hero">
  <div class="container">
    <div class="product-hero-grid">

      <div class="product-gallery">
        <div class="product-main-img" id="mainImg">
          <img width="1200" height="896" src="/images/products/product-agriculture.webp" alt="Agricultural sepiolite – soil and carrier grade mineral" id="mainImgSrc" />
        </div>
        <div class="product-thumbs">
          <div class="product-thumb active" onclick="switchImage(this, '/images/products/product-agriculture.webp', 'Agricultural Sepiolite')">
            <img width="1200" height="896" src="/images/products/product-agriculture.webp" alt="Agricultural Sepiolite" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/mine/mine-landscape-07.webp', 'Sepiolite mine landscape')">
            <img width="1600" height="1200" src="/images/mine/mine-landscape-07.webp" alt="Sepiolite mine landscape" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-03.webp', 'Agricultural Sepiolite sample')">
            <img width="506" height="900" src="/images/products/product-sample-03.webp" alt="Agricultural Sepiolite sample" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-04.webp', 'Agricultural Sepiolite detail')">
            <img width="506" height="900" src="/images/products/product-sample-04.webp" alt="Agricultural Sepiolite detail" loading="lazy" />
          </div>
        </div>
      </div>

      <div class="product-info">
        <div class="product-badge">Agriculture</div>
        <h1 class="product-h1">Agricultural <em>Sepiolite</em></h1>
        <p class="product-tagline">Purpose-engineered carrier and soil conditioner for modern agriculture. Enhances fertilizer efficiency, improves soil structure, and enables controlled-release pesticide delivery.</p>

        <div class="key-specs">
          <div class="key-spec">
            <div class="key-spec-value">Carrier</div>
            <div class="key-spec-label">Primary Use</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">≥120%</div>
            <div class="key-spec-label">Absorption</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">Eco</div>
            <div class="key-spec-label">Certified</div>
          </div>
        </div>

        <div class="price-box">
          <div class="price-box-header">
            <span class="price-label">Bulk Pricing</span>
            <span class="price-availability">In Stock</span>
          </div>
          <div class="price-value">TBD</div>
          <div class="price-unit">Price per metric ton · FOB Port of Mersin or FOB Samsun Port, Turkey · Contact for CIF pricing</div>
          <div class="price-features">
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Minimum order: 20 MT (one container)
            </div>
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Certificate of Analysis included with every shipment
            </div>
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Free samples available for qualified buyers
            </div>
          </div>
          <div class="price-actions">
            <a href="../../#contact" class="btn btn-primary">Request a Quote</a>
            <a href="../../#contact" class="btn btn-outline">Request Sample</a>
          </div>
        </div>
