---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/"},
    {"@type": "ListItem", "position": 2, "name": "Products", "item": "https://sepiolitemine.com/#products"},
    {"@type": "ListItem", "position": 3, "name": "Raw Sepiolite Ore", "item": "https://sepiolitemine.com/products/raw-sepiolite-ore/"}
  ]
},
  {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Raw Sepiolite Ore",
  "description": "Premium raw sepiolite ore directly mined from Turkey's richest deposits. Unprocessed mineral in natural block and chunk form with 99%+ purity grade.",
  "image": ["https://sepiolitemine.com/images/products/product-raw-ore.webp"],
  "sku": "SM-RAW-001",
  "brand": {
    "@type": "Brand",
    "name": "Sepiolite Mine"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Zamana",
    "url": "https://zamana.com.tr"
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://sepiolitemine.com/products/raw-sepiolite-ore/",
    "seller": {
      "@type": "Organization",
      "name": "Sepiolite Mine"
    }
  },
  "material": "Hydrated Magnesium Silicate (Mg4Si6O15(OH)2·6H2O)",
  "countryOfOrigin": {
    "@type": "Country",
    "name": "Turkey"
  }
},
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the minimum order quantity for raw sepiolite ore?",
      "acceptedAnswer": {"@type": "Answer", "text": "Our minimum order quantity is 20 metric tons, which corresponds to one standard 20-foot container."}
    },
    {
      "@type": "Question",
      "name": "What packaging options are available for raw sepiolite ore?",
      "acceptedAnswer": {"@type": "Answer", "text": "Raw ore is available in 1-metric-ton jumbo bags (FIBC) or shipped loose in lined containers for maximum capacity."}
    },
    {
      "@type": "Question",
      "name": "Can I receive a sample before placing a bulk order?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, we provide complimentary samples to qualified buyers. Samples typically weigh 1-5 kg and include a Certificate of Analysis."}
    },
    {
      "@type": "Question",
      "name": "What is the typical lead time from order to shipment?",
      "acceptedAnswer": {"@type": "Answer", "text": "Standard lead time is 7-14 business days from order confirmation, depending on volume and stock levels."}
    },
    {
      "@type": "Question",
      "name": "What Incoterms do you offer for raw sepiolite shipments?",
      "acceptedAnswer": {"@type": "Answer", "text": "We offer FOB (Turkish port), CIF, and CFR terms with full export documentation and customs clearance."}
    }
  ]
}
];
---

<Layout
  title="Raw Sepiolite Ore – Premium Turkish Supply"
  description="Premium raw sepiolite ore directly from Turkey"
  locale="en"
  alternates={{ en: "/products/raw-sepiolite-ore/", tr: "/tr/products/ham-sepiyolit-cevheri/" }}
  schemaJson={schemaJson}
>
<!-- ── Shared header (injected by js/include.js) ── -->


<!-- BREADCRUMB -->
<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="../../">Home</a>
      <span class="sep">›</span>
      <a href="../../#products">Products</a>
      <span class="sep">›</span>
      <span class="current">Raw Sepiolite Ore</span>
    </nav>
  </div>
</div>

<!-- ===== PRODUCT HERO ===== -->
<section class="product-hero">
  <div class="container">
    <div class="product-hero-grid">

      <!-- Left: Gallery -->
      <div class="product-gallery">
        <div class="product-main-img" id="mainImg">
          <img width="506" height="900" src="/images/products/product-raw-ore.webp" alt="Raw sepiolite ore – natural mineral chunks from Turkish mine" id="mainImgSrc" />
        </div>
        <div class="product-thumbs">
          <div class="product-thumb active" onclick="switchImage(this, '/images/products/product-raw-ore.webp', 'Raw sepiolite ore chunks')">
            <img width="506" height="900" src="/images/products/product-raw-ore.webp" alt="Raw sepiolite ore" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/mine/mine-landscape-05.webp', 'Sepiolite ore at mine site')">
            <img width="960" height="1280" src="/images/mine/mine-landscape-05.webp" alt="Sepiolite ore at mine site" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-01.webp', 'Sepiolite ore sample close-up')">
            <img width="675" height="900" src="/images/products/product-sample-01.webp" alt="Sepiolite ore sample" loading="lazy" />
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-02.webp', 'Sepiolite ore sample detail')">
            <img width="675" height="900" src="/images/products/product-sample-02.webp" alt="Sepiolite ore sample detail" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Right: Product Info -->
      <div class="product-info">
        <div class="product-badge">Raw Material</div>
        <h1 class="product-h1">Raw Sepiolite <em>Ore</em></h1>
        <p class="product-tagline">
          Directly mined from Turkey's premier deposits — unprocessed sepiolite in natural block and chunk form, preserving its unique fibrous structure and exceptional purity.
        </p>

        <!-- Key Specs -->
        <div class="key-specs">
          <div class="key-spec">
            <div class="key-spec-value">≥18%</div>
            <div class="key-spec-label">MgO Content</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">≥54%</div>
            <div class="key-spec-label">SiO₂ Content</div>
          </div>
          <div class="key-spec">
            <div class="key-spec-value">99.2%</div>
            <div class="key-spec-label">Purity Grade</div>
          </div>
        </div>

        <!-- Price Box -->
        <div class="price-box">
          <div class="price-box-header">
            <span class="price-label">Bulk Pricing</span>
            <span class="price-availability">In Stock</span>
          </div>
          <div class="price-value">TBD</div>
          <div class="price-unit">Price per metric ton · FOB Port of Mersin or FOB Samsun Port, Turkey · Contact for CIF pricing</div>
          <div class="price-features">
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Minimum order: 20 MT (one container)
            </div>
            <div class="price-feature">
              <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
