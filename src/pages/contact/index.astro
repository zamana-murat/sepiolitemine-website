---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/" },
      { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://sepiolitemine.com/contact/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How quickly will I receive a response?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We respond to every enquiry within one business day (24 hours). Our sales team monitors all channels throughout business hours and processes urgent requests with priority. For matters outside business hours, expect a response first thing the next morning."
        }
      },
      {
        "@type": "Question",
        "name": "Can I request product samples?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, absolutely. We provide free product samples to qualified buyers. Simply specify which grade and form you'd like to evaluate (raw ore, granulated, powder, etc.), and we'll ship samples worldwide at no cost. Most samples arrive within 5–10 business days."
        }
      },
      {
        "@type": "Question",
        "name": "What information should I include in my enquiry?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To help us serve you faster, please provide: your company name and industry, the sepiolite grade and form you're interested in, estimated annual volume, target specifications (particle size, moisture, purity), preferred packaging, and any technical requirements. The more detail you provide, the more tailored our response."
        }
      },
      {
        "@type": "Question",
        "name": "Do you have sales representatives in my region?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We serve 45+ countries and work through a combination of direct sales, logistics partners, and regional distributors. For details on coverage in your area, use the contact form or call +90 530 490 4740 (WhatsApp available). We'll connect you with the right contact for your location."
        }
      },
      {
        "@type": "Question",
        "name": "What are your business hours?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Factory (Production & Quality Control): Monday–Saturday, 08:00–18:00 (Istanbul/Turkey time). Head Office (Sales & Administration): Monday–Friday, 09:00–18:00 (Istanbul/Turkey time). Messages and inquiries received outside these hours will be processed the next business day."
        }
      }
    ]
  }
];
---

<Layout
  title="Contact Us"
  description="Get in touch with Sepiolite Mine for sourcing inquiries, technical support, and product samples. 24-hour response guarantee. Phone, email, and online contact form available."
  locale="en"
  alternates={{ en: "/contact/", tr: "/tr/contact/" }}
  schemaJson={schemaJson}
>
<!-- ===== HEADER ===== -->
  

  <!-- ===== BREADCRUMB ===== -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep">&#8250;</span>
        <span class="current">Contact</span>
      </div>
    </div>
  </div>

  <!-- ===== HERO ===== -->
  <section class="contact-hero">
    <div class="container">
      <h1>Start Your Sourcing <span>Journey</span></h1>
      <p>We respond to every enquiry within 24 hours. Whether you're a new buyer requesting samples, an established importer seeking volume pricing, or a technical specialist with specification questions — our team is ready to help.</p>
    </div>
  </section>

  <!-- ===== CONTACT FORM & INFO ===== -->
  <section class="contact-main">
    <div class="container">
      <div class="contact-grid">

        <!-- Left Column: Contact Information -->
        <div class="contact-info-column reveal">
          <div class="info-block">
            <h3>Company Information</h3>
            <p><span class="info-label">Legal Entity</span>Zamana Danışmanlık</p>
          </div>

          <div class="info-block">
            <h3>Factory & Production</h3>
            <p><span class="info-label">Address</span>Başkent Organize Sanayi Atatürk Bulvarı No:48, Malıköy, Sincan / Ankara</p>
          </div>

          <div class="info-block">
            <h3>Head Office</h3>
            <p><span class="info-label">Address</span>Kızılay Mah. Fevziçakmak 1. Sokak No:15 D:7, Çankaya / Ankara</p>
          </div>

          <div class="info-block">
            <div class="contact-methods">
              <div class="contact-method">
                <span class="contact-method-label">Phone &amp; WhatsApp</span>
                <span class="contact-method-text">+90 530 490 4740</span>
              </div>
              <div class="contact-method">
                <span class="contact-method-label">Enquiries</span>
                <span class="contact-method-text">Use the form on this page — we respond within 24 hours</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Contact Form -->
        <div class="reveal">
          <div class="contact-form-card">
            <h2>Send Your Enquiry</h2>
            <form id="contactForm" onsubmit="handleFormSubmit(event)" novalidate>
              {/* Honeypot — hidden from humans, attractive to bots. Backend rejects any submission with this filled. */}
              <div aria-hidden="true" style="position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden;">
                <label for="website">Website (leave blank)</label>
                <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="fullName">Full Name <span class="required">*</span></label>
                  <input type="text" id="fullName" name="fullName" placeholder="Your full name" required />
                </div>
                <div class="form-group">
                  <label for="company">Company <span class="required">*</span></label>
                  <input type="text" id="company" name="company" placeholder="Company name" required />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="email">Email <span class="required">*</span></label>
                  <input type="email" id="email" name="email" placeholder="your@email.com" required />
                </div>
                <div class="form-group">
                  <label for="country">Country</label>
                  <input type="text" id="country" name="country" placeholder="Country" />
                </div>
              </div>

              <div class="form-group">
                <label for="product">Product of Interest <span class="required">*</span></label>
                <select id="product" name="product" required>
                  <option value="">— Select a product grade —</option>
                  <option value="raw-ore">Raw Sepiolite Ore</option>
                  <option value="granulated">Granulated Sepiolite</option>
                  <option value="milled-powder">Milled Sepiolite Powder</option>
                  <option value="drilling-grade">Drilling Grade</option>
                  <option value="agricultural-grade">Agricultural Grade</option>
                  <option value="construction-grade">Construction Grade</option>
                  <option value="custom">Custom/Other</option>
                </select>
              </div>

              <div class="form-group">
                <label for="volume">Estimated Annual Volume <span class="required">*</span></label>
                <select id="volume" name="volume" required>
                  <option value="">— Select volume range —</option>
                  <option value="trial-5-10">Trial Order 5–10 MT</option>
                  <option value="container-20">1 Container ~20 MT</option>
                  <option value="containers-2-5">2–5 Containers</option>
                  <option value="containers-5-10">5–10 Containers</option>
                  <option value="bulk-vessel">Bulk Vessel 3000+ MT</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" placeholder="Tell us about your project, specifications, timeline, or any questions..."></textarea>
              </div>

              <div class="form-privacy">
                <strong>Privacy &amp; Response:</strong> We respond to every enquiry within 24 hours. Your contact details and company information are never shared with third parties and are used solely to serve your sourcing needs.
              </div>

              <button type="submit" class="form-submit">Send Enquiry →</button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== WHY CONTACT US ===== -->
  <section class="why-contact-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Our Commitment</span>
        <h2 class="section-title">Why Contact <span>Us</span></h2>
      </div>

      <div class="why-contact-grid">
        <div class="why-card reveal">
          <div class="why-icon">⏱️</div>
          <h3>24-Hour Response</h3>
          <p>We reply to every enquiry within one business day. Your time matters—we'll get back to you fast with answers and options.</p>
        </div>

        <div class="why-card reveal">
          <div class="why-icon">📦</div>
          <h3>Free Samples</h3>
          <p>Request product samples from any grade. We ship worldwide at no cost for qualified buyers. Evaluate before committing.</p>
        </div>

        <div class="why-card reveal">
          <div class="why-icon">🔬</div>
          <h3>Technical Support</h3>
          <p>Our engineers guide you through product selection, specifications, and custom requirements. We ensure you get the right fit.</p>
        </div>

        <div class="why-card reveal">
          <div class="why-icon">⚙️</div>
          <h3>Custom Solutions</h3>
          <p>Bespoke particle sizes, moisture levels, packaging, and branding. We adapt our product to your exact needs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OFFICE LOCATIONS ===== -->
  <section class="locations-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Our Locations</span>
        <h2 class="section-title">Visit Us in <span>Ankara</span></h2>
      </div>

      <div class="locations-grid">
        <div class="location-card reveal">
          <div class="location-icon">🏭</div>
          <h3>Factory &amp; Plant</h3>
          <div class="location-subtitle">Production &amp; Quality Control</div>
          <p class="location-address">Başkent Organize Sanayi Atatürk Bulvarı No:48, Malıköy, Sincan / Ankara, Turkey</p>
          <div class="location-hours">
            <span class="location-hours-label">Business Hours</span>
            <span class="location-hours-text">Monday–Saturday, 08:00–18:00 (Istanbul Time)</span>
          </div>
        </div>

        <div class="location-card reveal">
          <div class="location-icon">🏢</div>
          <h3>Head Office</h3>
          <div class="location-subtitle">Sales &amp; Administration</div>
          <p class="location-address">Kızılay Mah. Fevziçakmak 1. Sokak No:15 D:7, Çankaya / Ankara, Turkey</p>
          <div class="location-hours">
            <span class="location-hours-label">Business Hours</span>
            <span class="location-hours-text">Monday–Friday, 09:00–18:00 (Istanbul Time)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="faq-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Common Questions</span>
        <h2 class="section-title">Frequently Asked <span>Questions</span></h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>How quickly will I receive a response?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
          <div class="faq-a">
            <p>We respond to every enquiry within one business day (24 hours). Our sales team monitors all channels throughout business hours and processes urgent requests with priority. For matters outside business hours, expect a response first thing the next morning.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>Can I request product samples?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
          <div class="faq-a">
            <p>Yes, absolutely. We provide free product samples to qualified buyers. Simply specify which grade and form you'd like to evaluate (raw ore, granulated, powder, etc.), and we'll ship samples worldwide at no cost. Most samples arrive within 5–10 business days.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>What information should I include in my enquiry?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
          <div class="faq-a">
            <p>To help us serve you faster, please provide: your company name and industry, the sepiolite grade and form you're interested in, estimated annual volume, target specifications (particle size, moisture, purity), preferred packaging, and any technical requirements. The more detail you provide, the more tailored our response.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>Do you have sales representatives in my region?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
          <div class="faq-a">
            <p>We serve 45+ countries and work through a combination of direct sales, logistics partners, and regional distributors. For details on coverage in your area, use the contact form above or call +90 530 490 4740 (WhatsApp available). We'll connect you with the right contact for your location.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>What are your business hours?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
          <div class="faq-a">
            <p>Factory (Production & Quality Control): Monday–Saturday, 08:00–18:00 (Istanbul/Turkey time). Head Office (Sales & Administration): Monday–Friday, 09:00–18:00 (Istanbul/Turkey time). Messages and inquiries received outside these hours will be processed the next business day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="contact-cta">
    <div class="container">
      <h2>Ready to Source Premium <span>Sepiolite?</span></h2>
      <p>Fill out our contact form above, and we'll provide a tailored quote, technical specifications, and sample options within 24 hours.</p>
      <div class="btn-group">
        <a href="#contactForm" class="btn btn-primary">Start Enquiry</a>
        <a href="../markets/" class="btn btn-outline">Explore Markets</a>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  

  <!-- ===== SCRIPTS ===== -->
  

  <script>
    // ===== Scroll Reveal Animation =====
    const observerOptions = { threshold: 0.15, rootMargin: '0px 0px -50px 0px' };
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ===== Form Handling — POST to /api/contact (Cloudflare Pages Function → Resend) =====
    async function handleFormSubmit(event) {
      event.preventDefault();
      var form = event.target;
      var card = form.closest('.contact-form-card');
      var submitBtn = form.querySelector('.form-submit');
      var data = new FormData(form);

      var productLabel = form.querySelector('#product').selectedOptions[0]?.text || '';
      var volumeLabel = form.querySelector('#volume').selectedOptions[0]?.text || '';

      var payload = {
        name: (data.get('fullName') || '').toString().trim(),
        email: (data.get('email') || '').toString().trim(),
        company: (data.get('company') || '').toString().trim(),
        country: (data.get('country') || '').toString().trim(),
        subject: productLabel || 'Sepiolite enquiry',
        message: [
          'Product:  ' + productLabel,
          'Volume:   ' + volumeLabel,
          '',
          (data.get('message') || '').toString().trim() || '(no message)',
        ].join('\n'),
        website: (data.get('website') || '').toString(), // honeypot
        locale: 'en',
      };

      submitBtn.disabled = true;
      var originalLabel = submitBtn.textContent;
      submitBtn.textContent = 'Sending…';

      try {
        var r = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var result = await r.json().catch(function () { return { ok: false }; });

        if (r.ok && result.ok) {
          card.innerHTML = '<div style="text-align:center;padding:3rem 1.5rem;">' +
            '<div style="font-size:3rem;margin-bottom:1rem;color:var(--gold);">&#10003;</div>' +
            '<h2 style="font-family:Playfair Display,serif;font-size:1.6rem;color:var(--earth);margin-bottom:1rem;">Enquiry Received</h2>' +
            '<p style="font-size:0.95rem;color:var(--text-light);line-height:1.7;max-width:400px;margin:0 auto 1.5rem;">Thank you for your interest. Our sales team will review your enquiry and respond within 24 hours.</p>' +
            '<p style="font-size:0.85rem;color:var(--stone);">You can also reach us at <strong>+90 530 490 4740</strong> (WhatsApp)</p>' +
            '</div>';
        } else {
          throw new Error(result.error || 'Submission failed');
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
        var existingErr = form.querySelector('.form-error');
        if (existingErr) existingErr.remove();
        var errBox = document.createElement('div');
        errBox.className = 'form-error';
        errBox.style.cssText = 'margin-top:1rem;padding:0.85rem 1rem;border-left:3px solid #b3261e;background:#fdecea;color:#5b1612;font-size:0.88rem;border-radius:0 6px 6px 0;';
        errBox.textContent = 'Could not send: ' + (err && err.message ? err.message : 'unknown error') + '. Please try again or call +90 530 490 4740.';
        form.appendChild(errBox);
      }
    }

    // ===== FAQ Toggle =====
    function toggleFaq(button) {
      const faqItem = button.parentElement;
      const answer = faqItem.querySelector('.faq-a');
      const isOpen = answer.classList.contains('open');

      // Close all other FAQs
      document.querySelectorAll('.faq-a.open').forEach(a => {
        a.classList.remove('open');
        a.parentElement.querySelector('.faq-q').classList.remove('active');
      });

      // Toggle current FAQ
      if (!isOpen) {
        answer.classList.add('open');
        button.classList.add('active');
      }
    }
  </script>
</Layout>

<style is:global>
/* ===== HERO ===== */
    .contact-hero {
      position: relative;
      padding: 6rem 0 5rem;
      background: linear-gradient(135deg, var(--earth) 0%, var(--earth-mid) 50%, var(--earth-soft) 100%);
      overflow: hidden;
    }
    .contact-hero::before {
      content: '';
      position: absolute; inset: 0;
      background: url('/images/mine/mine-aerial-02.webp') center/cover no-repeat;
      opacity: 0.15;
    }
    .contact-hero .container { position: relative; z-index: 2; text-align: center; }
    .contact-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 5vw, 3.8rem); color: var(--white); margin-bottom: 1.25rem; line-height: 1.12; }
    .contact-hero h1 span { color: var(--gold); }
    .contact-hero p { font-size: 1.1rem; color: rgba(255,255,255,0.75); max-width: 700px; margin: 0 auto; line-height: 1.7; }

    /* ===== CONTACT FORM SECTION ===== */
    .contact-main { padding: 5rem 0; background: var(--white); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: flex-start; }

    /* Left Column - Contact Information */
    .contact-info-column { display: flex; flex-direction: column; gap: 2rem; }

    .info-block {
      background: var(--cream);
      border-left: 4px solid var(--gold);
      padding: 2rem;
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
    }
    .info-block h3 { font-family: 'Playfair Display', serif; font-size: 0.95rem; color: var(--earth); margin-bottom: 1.25rem; font-weight: 700; }
    .info-block p { font-size: 0.85rem; line-height: 1.65; color: var(--text-light); margin-bottom: 0.75rem; }
    .info-block p:last-child { margin-bottom: 0; }
    .info-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.35rem; }

    .contact-methods {
      display: flex; flex-direction: column; gap: 1.5rem;
      padding-top: 1rem; border-top: 1px solid var(--cream-dark);
    }
    .contact-method { display: flex; flex-direction: column; }
    .contact-method-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
    .contact-method-text { font-size: 0.92rem; font-weight: 600; color: var(--earth); }
    .contact-method-sub { font-size: 0.78rem; color: var(--stone); margin-top: 0.25rem; }

    .email-svg {
      max-height: 24px;
      margin-top: 0.4rem;
    }

    /* Right Column - Contact Form */
    .contact-form-card {
      background: var(--cream);
      border-radius: var(--radius-lg);
      padding: 2.5rem;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--cream-dark);
    }
    .contact-form-card h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--earth); margin-bottom: 2rem; }

    .form-group { margin-bottom: 1.5rem; display: flex; flex-direction: column; }
    .form-group label { font-size: 0.82rem; font-weight: 600; color: var(--earth); margin-bottom: 0.5rem; }
    .form-group label .required { color: var(--gold); }

    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: 0.85rem 1rem;
      border: 1px solid var(--cream-dark);
      border-radius: 6px;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.9rem;
      color: var(--earth);
      background: var(--white);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(201,146,42,0.1);
    }
    .form-group textarea {
      resize: vertical;
      min-height: 120px;
      font-family: 'Inter', system-ui, sans-serif;
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 768px) { .form-row { grid-template-columns: 1fr; } }

    .form-privacy {
      font-size: 0.78rem;
      color: var(--stone);
      line-height: 1.6;
      padding: 1rem;
      background: rgba(201,146,42,0.05);
      border-radius: 6px;
      margin-bottom: 1.5rem;
    }

    .form-submit {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 2.5rem;
      background: var(--gold);
      color: var(--earth);
      border: none;
      border-radius: 6px;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      cursor: pointer;
      transition: all 0.3s ease;
      width: 100%;
      justify-content: center;
