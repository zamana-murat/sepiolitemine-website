---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: BRAND.name,
  url: siteUrl,
  description: BRAND.description,
  telephone: BRAND.contact.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Başkent Organize Sanayi Atatürk Bulvarı No:48',
    addressLocality: 'Sincan / Ankara',
    addressCountry: 'TR',
  },
  sameAs: ['https://www.linkedin.com/company/akmin'],
  parentOrganization: {
    '@type': 'Organization',
    name: 'Akmin Mining',
    url: 'https://akmin.com.tr',
  },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Sepiolite Mine — Akmin Mining',
  image: `${siteUrl}/images/mine/aerial-02-1280w.webp`,
  telephone: BRAND.contact.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Başkent Organize Sanayi Atatürk Bulvarı No:48',
    addressLocality: 'Sincan',
    addressRegion: 'Ankara',
    addressCountry: 'TR',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
  ],
};
---

<Layout
  title="Premium Turkish Sepiolite Supplier"
  description="Turkey's premier sepiolite producer. Premium raw and processed sepiolite for agriculture, oil & gas, construction, cat litter, and industrial markets globally."
  alternates={{ en: '/', tr: '/tr/' }}
  locale="en"
  noSuffix={true}
  schemaJson={[orgSchema, localBusinessSchema]}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/mine/aerial-02-1280w.webp" fetchpriority="high" />
  </Fragment>

  {/* ===== HERO ===== */}
  <section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-particles" id="particles"></div>
    <div class="container hero-content">
      <div class="hero-badge">Turkey's Premier Sepiolite Producer</div>
      <h1 class="hero-title">
        The Earth's Most<br/><em>Versatile Mineral</em><br/>Delivered Globally
      </h1>
      <p class="hero-desc">
        From the rich deposits of Turkey, Sepiolite Mine supplies premium raw and processed sepiolite to industries across the world — agriculture, oil &amp; gas, construction, environmental, and beyond.
      </p>
      <div class="hero-actions">
        <a href="#products" class="btn btn-primary">Explore Products ↓</a>
        <a href="/contact/" class="btn btn-outline">Request a Sample</a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-value">50+</div>
          <div class="hero-stat-label">Countries Served</div>
        </div>
        <div>
          <div class="hero-stat-value">15+</div>
          <div class="hero-stat-label">Industry Sectors</div>
        </div>
        <div>
          <div class="hero-stat-value">99.2%</div>
          <div class="hero-stat-label">Purity Grade</div>
        </div>
        <div>
          <div class="hero-stat-value">25+</div>
          <div class="hero-stat-label">Years Experience</div>
        </div>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="hero-scroll-line"></div>
    </div>
  </section>

  {/* ===== TICKER ===== */}
  <div class="ticker-strip">
    <div class="ticker-inner" id="ticker">
      <span>Raw Sepiolite</span><span>Granulated Sepiolite</span><span>Milled Powder</span>
      <span>Cat Litter Grade</span><span>Drilling Grade</span><span>Agriculture Grade</span>
      <span>Industrial Grade</span><span>Pharmaceutical Grade</span><span>Environmental Grade</span>
      <span>Sepiolite Turkey</span><span>Akmin Mining Group</span><span>sepiolitemine.com</span>
      <span>Raw Sepiolite</span><span>Granulated Sepiolite</span><span>Milled Powder</span>
      <span>Cat Litter Grade</span><span>Drilling Grade</span><span>Agriculture Grade</span>
      <span>Industrial Grade</span><span>Pharmaceutical Grade</span><span>Environmental Grade</span>
      <span>Sepiolite Turkey</span><span>Akmin Mining Group</span><span>sepiolitemine.com</span>
    </div>
  </div>

  {/* ===== ABOUT ===== */}
  <section id="about">
    <div class="container">
      <div class="grid-2">
        <div class="about-visual">
          <img src="/images/mine/cliff-1280w.webp" alt="Sepiolite Mine — Turkey" width="1280" height="960" loading="lazy"/>
          <div class="about-visual-badge">
            <strong>Est. 1995</strong>
            <span>Akmin Mining Co.</span>
          </div>
        </div>
        <div>
          <div class="section-tag">Our Story</div>
          <div class="divider"></div>
          <h2 class="section-title">Rooted in Earth,<br/>Reaching the <span>World</span></h2>
          <p class="section-subtitle">
            Sepiolite Mine is a dedicated sepiolite production and export division of <strong>Akmin Mining</strong>, operating at the heart of Turkey's richest mineral deposits. We mine, process, and deliver the finest quality sepiolite to clients in over 50 countries.
          </p>
          <p class="section-subtitle" style="margin-top:1rem;">
            Turkey holds the world's largest sepiolite reserves, and we are privileged stewards of those resources — committed to sustainable extraction, rigorous quality control, and customer-centric solutions.
          </p>
          <div class="about-features">
            <div class="about-feature">
              <div class="about-feature-icon">🏔️</div>
              <div class="about-feature-text">
                <strong>Prime Deposits</strong>
                <span>Direct access to Turkey's richest seams</span>
              </div>
            </div>
            <div class="about-feature">
              <div class="about-feature-icon">🔬</div>
              <div class="about-feature-text">
                <strong>ISO Certified Lab</strong>
                <span>Every batch tested and certified</span>
              </div>
            </div>
            <div class="about-feature">
              <div class="about-feature-icon">🌍</div>
              <div class="about-feature-text">
                <strong>Global Logistics</strong>
                <span>Bulk &amp; container shipping worldwide</span>
              </div>
            </div>
            <div class="about-feature">
              <div class="about-feature-icon">♻️</div>
              <div class="about-feature-text">
                <strong>Eco Mining</strong>
                <span>Responsible land restoration policy</span>
              </div>
            </div>
          </div>
          <div class="akmin-badge">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L18 7V13L10 18L2 13V7L10 2Z" stroke="#C9922A" stroke-width="1.5" fill="none"/><circle cx="10" cy="10" r="3" fill="#C9922A"/></svg>
            A division of <span>Akmin Mining</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===== PRODUCTS ===== */}
  <section id="products">
    <div class="container">
      <div class="products-header">
        <div class="section-tag">Product Range</div>
        <div class="divider divider--center"></div>
        <h2 class="section-title" style="text-align:center;">Premium <span>Sepiolite</span> Products</h2>
        <p class="section-subtitle" style="text-align:center;margin:0 auto;">
          From raw ore to precision-processed grades — our full product line is engineered to meet the exact specifications of each industry we serve.
        </p>
      </div>
      <div class="grid-3">

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/raw-ore-400w.webp" alt="Raw Sepiolite Ore" width="400" height="220" loading="lazy"/>
            <span class="product-card-tag">Raw Material</span>
          </div>
          <div class="product-card-body">
            <h3>Raw Sepiolite Ore</h3>
            <p>Directly mined sepiolite in natural block or chunk form. Ideal for clients who process in-house. High purity, unrefined, with natural fiber structure intact.</p>
            <div class="product-specs">
              <span class="product-spec">MgO ≥18%</span>
              <span class="product-spec">SiO₂ ≥54%</span>
              <span class="product-spec">Bulk Bags</span>
            </div>
            <a href="/products/raw-sepiolite-ore/" class="product-link">View Details <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/granulated-400w.webp" alt="Granulated Sepiolite" width="400" height="220" loading="lazy"/>
            <span class="product-card-tag">Processed</span>
          </div>
          <div class="product-card-body">
            <h3>Granulated Sepiolite</h3>
            <p>Precision-sized granules for cat litter, agriculture, and industrial absorbent markets. Available in 0–2mm, 2–4mm, and 4–8mm fractions with controlled moisture.</p>
            <div class="product-specs">
              <span class="product-spec">0–8mm</span>
              <span class="product-spec">Low Dust</span>
              <span class="product-spec">Custom Size</span>
            </div>
            <a href="/products/granulated-sepiolite/" class="product-link">View Details <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/milled-powder-800w.webp" alt="Milled Sepiolite Powder" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">Fine Grade</span>
          </div>
          <div class="product-card-body">
            <h3>Milled Sepiolite Powder</h3>
            <p>Ultra-fine micronized powder for paints, coatings, pharmaceuticals, and cosmetics. Controlled particle distribution from 5–200 microns with high surface area.</p>
            <div class="product-specs">
              <span class="product-spec">5–200μm</span>
              <span class="product-spec">High Surface</span>
              <span class="product-spec">Bags/BigBag</span>
            </div>
            <a href="/products/milled-sepiolite-powder/" class="product-link">View Details <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/drilling-grade-800w.webp" alt="Drilling Grade Sepiolite" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">Oil &amp; Gas</span>
          </div>
          <div class="product-card-body">
            <h3>Drilling Grade Sepiolite</h3>
            <p>API-compliant sepiolite for oil and gas drilling fluid applications. Provides stable rheology in saline and high-temperature environments where bentonite fails.</p>
            <div class="product-specs">
              <span class="product-spec">API Spec 13A</span>
              <span class="product-spec">Salt Tolerant</span>
              <span class="product-spec">50kg Bags</span>
            </div>
            <a href="/products/drilling-grade-sepiolite/" class="product-link">View Details <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/agriculture-800w.webp" alt="Agricultural Sepiolite" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">Agriculture</span>
          </div>
          <div class="product-card-body">
            <h3>Agricultural Sepiolite</h3>
            <p>Soil amendment and carrier grade for fertilizers, pesticides, and seed coatings. Improves soil structure, water retention, and nutrient delivery for enhanced yields.</p>
            <div class="product-specs">
              <span class="product-spec">Soil Grade</span>
              <span class="product-spec">Carrier</span>
              <span class="product-spec">Eco Cert.</span>
            </div>
            <a href="/products/agricultural-sepiolite/" class="product-link">View Details <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/construction-800w.webp" alt="Construction & Insulation Grade Sepiolite" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">Construction</span>
          </div>
          <div class="product-card-body">
            <h3>Construction &amp; Insulation Grade</h3>
            <p>Low thermal conductivity sepiolite for insulating boards, mortars, and fireproof coatings. Enhances workability and durability in cement and lime-based products.</p>
            <div class="product-specs">
              <span class="product-spec">Low λ</span>
              <span class="product-spec">Fireproof</span>
              <span class="product-spec">Bulk Delivery</span>
            </div>
            <a href="/products/construction-insulation-grade/" class="product-link">View Details <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ===== APPLICATIONS ===== */}
  <section id="applications" style="padding:6rem 0;background:var(--earth);">
    <div class="container">
      <div style="text-align:center;margin-bottom:3.5rem;">
        <div class="section-tag">Solutions</div>
        <div class="divider divider--center"></div>
        <h2 class="section-title section-title--white">Where Sepiolite <span>Transforms</span> Industries</h2>
        <p class="section-subtitle section-subtitle--white" style="margin:0 auto;">
          Our mineral's unique combination of high porosity, thermal stability, and chemical inertness makes it indispensable across more than 15 global industries.
        </p>
      </div>
      <div class="app-grid">
        <div class="app-card">
          <div class="app-icon">🐾</div>
          <h3>Pet Care &amp; Cat Litter</h3>
          <p>Superior odour control and moisture absorption. The fastest-growing application globally, with sepiolite outperforming clay competitors in clumping and hygiene.</p>
          <ul class="app-list">
            <li>Clumping &amp; non-clumping grades</li>
            <li>Odour neutralisation</li>
            <li>Low tracking, dust-free</li>
            <li>Custom fragrance options</li>
          </ul>
          <a href="/applications/pet-care-cat-litter/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🌾</div>
          <h3>Agriculture</h3>
          <p>Revolutionising soil science through superior water retention, fertiliser and pesticide carriers, and animal feed binders that improve nutrient bioavailability.</p>
          <ul class="app-list">
            <li>Soil conditioner</li>
            <li>Fertiliser/pesticide carrier</li>
            <li>Seed coating binder</li>
            <li>Feed additive (flow agent)</li>
          </ul>
          <a href="/applications/agriculture/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🛢️</div>
          <h3>Oil &amp; Gas Drilling</h3>
          <p>The only mineral that maintains stable rheology in saturated saltwater — making it essential for offshore and high-salinity drilling operations worldwide.</p>
          <ul class="app-list">
            <li>Salt-saturated mud systems</li>
            <li>High-temperature stability</li>
            <li>Spill absorption</li>
            <li>API 13A compliant</li>
          </ul>
          <a href="/applications/oil-gas-drilling/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🏗️</div>
          <h3>Construction</h3>
          <p>Thermal insulation, fire resistance, and improved workability in mortars, plasters, and concrete — delivering buildings that are safer, stronger, and more efficient.</p>
          <ul class="app-list">
            <li>Insulating bricks &amp; boards</li>
            <li>Lime mortar additive</li>
            <li>Rheology modifier</li>
            <li>Fireproof coatings</li>
          </ul>
          <a href="/applications/construction/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🌿</div>
          <h3>Environmental Remediation</h3>
          <p>A natural solution to pollution. Sepiolite's unparalleled adsorption capacity makes it ideal for wastewater treatment, heavy metal sequestration, and oil spill response.</p>
          <ul class="app-list">
            <li>Wastewater treatment</li>
            <li>Heavy metal removal</li>
            <li>Oil spill cleanup</li>
            <li>Air purification media</li>
          </ul>
          <a href="/applications/environmental-remediation/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🎨</div>
          <h3>Paints &amp; Coatings</h3>
          <p>Acts as a rheology modifier, anti-sagging agent, and matting agent in water-based and solvent-borne paints — improving texture without compromising opacity.</p>
          <ul class="app-list">
            <li>Anti-settling agent</li>
            <li>Thixotropic additive</li>
            <li>Matting effect</li>
            <li>Improved brushability</li>
          </ul>
          <a href="/applications/paints-coatings/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">⚗️</div>
          <h3>Catalysis &amp; Chemical</h3>
          <p>High surface area and thermal stability make sepiolite an outstanding catalyst support for hydrogenation, dehydrogenation, and oxidation reactions.</p>
          <ul class="app-list">
            <li>Catalyst carrier</li>
            <li>Zeolite substitute</li>
            <li>High-temp. reactions</li>
            <li>Selectivity enhancement</li>
          </ul>
          <a href="/applications/catalysis-chemical/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">💊</div>
          <h3>Pharma &amp; Cosmetics</h3>
          <p>GRAS-listed and biocompatible, sepiolite serves as an excipient, thickener, and carrier in pharmaceutical formulations, face masks, and personal care products.</p>
          <ul class="app-list">
            <li>Tablet excipient</li>
            <li>Cosmetic thickener</li>
            <li>Facial mask filler</li>
            <li>Drug delivery carrier</li>
          </ul>
          <a href="/applications/pharma-cosmetics/" class="app-link-home">Learn More →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🌱</div>
          <h3>Bioplastics (Emerging)</h3>
          <p>As sustainability drives innovation, sepiolite nano-fibres reinforce biodegradable polymers, improving mechanical strength while maintaining compostability.</p>
          <ul class="app-list">
            <li>PLA / PHA reinforcement</li>
            <li>Nano-filler</li>
            <li>Compostable-compatible</li>
            <li>Barrier improvement</li>
          </ul>
          <a href="/applications/bioplastics/" class="app-link-home">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  {/* ===== MARKETS / WHY CHOOSE US ===== */}
  <section id="markets" style="padding:6rem 0;background:var(--cream);">
    <div class="container">
      <div class="grid-2" style="gap:4rem;">
        <div>
          <div class="section-tag">Why Sepiolite Mine</div>
          <div class="divider"></div>
          <h2 class="section-title">A Partner You Can<br/>Build Your <span>Supply Chain</span> On</h2>
          <p class="section-subtitle">
            We don't just sell mineral — we deliver certainty. Our vertically integrated operation, from mine face to freight-on-board, ensures quality, consistency, and on-time delivery every time.
          </p>
          <div class="why-list">
            <div class="why-item">
              <div class="why-num">01</div>
              <div>
                <strong>Vertically Integrated</strong>
                <p>We own and operate our mines, processing facilities, and quality labs. No middlemen — full traceability from ore to shipment.</p>
              </div>
            </div>
            <div class="why-item">
              <div class="why-num">02</div>
              <div>
                <strong>Custom Formulation</strong>
                <p>Need a specific moisture level, particle size, or blend? Our R&amp;D team works with you to develop bespoke grades at commercial scale.</p>
              </div>
            </div>
            <div class="why-item">
              <div class="why-num">03</div>
              <div>
                <strong>Certifications</strong>
                <p>ISO 9001, REACH compliant, FDA-listed grades available. Full certificate of analysis with every shipment, no exceptions.</p>
              </div>
            </div>
            <div class="why-item">
              <div class="why-num">04</div>
              <div>
                <strong>Global Logistics</strong>
                <p>Containerised, bulk vessel, and big-bag shipments to any port. Our logistics team manages customs, documentation, and last-mile if needed.</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <div class="market-map-box">
            <div class="market-map-title">
              <span class="section-tag" style="margin:0;">Active Markets</span>
            </div>
            <div class="market-regions">
              <div class="market-region">
                <span class="region-dot"></span>
                <div>
                  <strong>Europe</strong>
                  <span>Germany, Netherlands, Spain, Italy, France, Poland…</span>
                </div>
              </div>
              <div class="market-region">
                <span class="region-dot"></span>
                <div>
                  <strong>Middle East &amp; North Africa</strong>
                  <span>UAE, Saudi Arabia, Egypt, Morocco, Israel…</span>
                </div>
              </div>
              <div class="market-region">
                <span class="region-dot"></span>
                <div>
                  <strong>Asia Pacific</strong>
                  <span>China, Japan, South Korea, India, Thailand…</span>
                </div>
              </div>
              <div class="market-region">
                <span class="region-dot"></span>
                <div>
                  <strong>Americas</strong>
                  <span>USA, Canada, Brazil, Mexico, Argentina…</span>
                </div>
              </div>
              <div class="market-region">
                <span class="region-dot"></span>
                <div>
                  <strong>Sub-Saharan Africa</strong>
                  <span>South Africa, Nigeria, Kenya, Ethiopia…</span>
                </div>
              </div>
            </div>
            <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--cream-dark);">
              <div style="display:flex;gap:2rem;">
                <div style="text-align:center;">
                  <div style="font-family:'Playfair Display',serif;font-size:2rem;color:var(--gold);font-weight:700;">50+</div>
                  <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--stone);">Countries</div>
                </div>
                <div style="text-align:center;">
                  <div style="font-family:'Playfair Display',serif;font-size:2rem;color:var(--gold);font-weight:700;">300+</div>
                  <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--stone);">Clients</div>
                </div>
                <div style="text-align:center;">
                  <div style="font-family:'Playfair Display',serif;font-size:2rem;color:var(--gold);font-weight:700;">120k</div>
                  <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--stone);">MT/Year</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===== SUSTAINABILITY ===== */}
  <section id="sustainability-home" style="padding:6rem 0;background:var(--earth-mid);position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:url('/images/mine/landscape-01-400w.webp') center/cover no-repeat;opacity:0.10;" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div style="text-align:center;margin-bottom:3.5rem;">
