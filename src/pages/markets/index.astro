---
import Layout from '@layouts/Layout.astro';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Markets', item: `${siteUrl}/markets/` },
  ],
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Sepiolite Mine – Akmin Mining',
  url: siteUrl,
  description:
    "Turkey's premier sepiolite producer and exporter serving 45+ countries worldwide with premium raw and processed sepiolite grades.",
  areaServed: [
    { '@type': 'Continent', name: 'Europe' },
    { '@type': 'Continent', name: 'Asia' },
    { '@type': 'Continent', name: 'Africa' },
    { '@type': 'Continent', name: 'North America' },
    { '@type': 'Continent', name: 'South America' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Which countries does Sepiolite Mine export to?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sepiolite Mine exports to over 45 countries across Europe (Germany, Netherlands, Spain, Italy, France, Poland, UK), Middle East & North Africa (UAE, Saudi Arabia, Egypt, Morocco), Asia Pacific (China, Japan, South Korea, India), the Americas (USA, Canada, Brazil, Mexico), and Sub-Saharan Africa (South Africa, Nigeria, Kenya).',
      },
    },
    {
      '@type': 'Question',
      name: 'What shipping methods does Sepiolite Mine offer?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We offer containerised shipments (20ft and 40ft), bulk vessel charter for large orders, big bag (FIBC) options, and palletised 25–50kg bags. All shipments include full documentation, certificate of analysis, and customs clearance support.',
      },
    },
    {
      '@type': 'Question',
      name: 'What are the Incoterms available?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We trade under EXW, FCA, FOB, CFR, CIF, and DAP Incoterms 2020. FOB Turkish port is the most common arrangement, but we can deliver CIF/DAP to any world port with competitive freight rates through our logistics partners.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the minimum order quantity for export?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The standard minimum order is one 20-foot container (~18–22 tonnes depending on product density). For new clients or trial orders, we can accommodate smaller quantities of 5–10 tonnes. Bulk vessel orders typically start at 3,000 tonnes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Sepiolite Mine provide private labelling?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. We offer full private-label and white-label packaging for all product lines. This includes custom bag designs (25kg, 50kg, big bag), branded pallets, and client-specific documentation. Minimum order for private-label packaging is one 20ft container.',
      },
    },
  ],
};

const regions = [
  {
    flag: '🇪🇺',
    name: 'Europe',
    subtitle: 'Our largest export market',
    desc: 'Europe accounts for 45% of our exports, driven by strong demand in pet care (cat litter), paints & coatings, and construction insulation. REACH-compliant grades available for all product lines.',
    countries: ['Germany', 'Netherlands', 'Spain', 'Italy', 'France', 'Poland', 'UK', 'Belgium'],
    stats: [{ num: '45%', label: 'Export Share' }, { num: '18', label: 'Countries' }],
  },
  {
    flag: '🇰🇼',
    name: 'Middle East & North Africa',
    subtitle: 'Fastest-growing corridor',
    desc: 'Oil & gas drilling, construction boom, and expanding pet care markets make MENA our fastest-growing region. Strategic proximity means 5–10 day delivery to any Gulf or North African port.',
    countries: ['UAE', 'Saudi Arabia', 'Egypt', 'Morocco', 'Israel', 'Qatar', 'Tunisia'],
    stats: [{ num: '25%', label: 'Export Share' }, { num: '12', label: 'Countries' }],
  },
  {
    flag: '🇯🇵',
    name: 'Asia Pacific',
    subtitle: 'High-growth industrial demand',
    desc: 'Rapidly industrialising economies drive demand for drilling-grade sepiolite, catalysis supports, and agricultural carriers. China, Japan, and South Korea are our top-3 Asian markets by volume.',
    countries: ['China', 'Japan', 'South Korea', 'India', 'Thailand', 'Vietnam'],
    stats: [{ num: '15%', label: 'Export Share' }, { num: '9', label: 'Countries' }],
  },
  {
    flag: '🇺🇸',
    name: 'The Americas',
    subtitle: 'Premium grade focus',
    desc: 'The US and Canada import high-purity drilling and pharmaceutical-grade sepiolite, while Brazil and Mexico are growing markets for agricultural and environmental applications.',
    countries: ['USA', 'Canada', 'Brazil', 'Mexico', 'Argentina', 'Colombia'],
    stats: [{ num: '10%', label: 'Export Share' }, { num: '8', label: 'Countries' }],
  },
  {
    flag: '🇿🇦',
    name: 'Sub-Saharan Africa',
    subtitle: 'Emerging opportunity',
    desc: 'Agriculture-driven demand for soil conditioners and fertiliser carriers is opening new markets across East and Southern Africa. Environmental remediation projects are also creating opportunities.',
    countries: ['South Africa', 'Nigeria', 'Kenya', 'Ethiopia', 'Tanzania'],
    stats: [{ num: '5%', label: 'Export Share' }, { num: '7', label: 'Countries' }],
  },
  {
    flag: '🇷🇺',
    name: 'CIS & Central Asia',
    subtitle: 'Drilling & industrial base',
    desc: 'Oil & gas-rich economies of the Caspian region and Central Asia are consistent importers of drilling-grade sepiolite and industrial absorbents. Land routes via Georgia offer cost-effective transport.',
    countries: ['Russia', 'Kazakhstan', 'Azerbaijan', 'Georgia', 'Uzbekistan'],
    stats: [{ num: '~5%', label: 'Export Share' }, { num: '6', label: 'Countries' }],
  },
];

const tradeRoutes = [
  { port: 'Rotterdam, Netherlands', region: "Europe's largest mineral hub", time: '7 days' },
  { port: 'Jebel Ali, UAE', region: 'Middle East & re-export gateway', time: '10 days' },
  { port: 'Shanghai, China', region: 'Asia Pacific primary port', time: '22 days' },
  { port: 'New York / Newark, USA', region: 'North America east coast', time: '18 days' },
  { port: 'Casablanca, Morocco', region: 'North Africa & agriculture corridor', time: '5 days' },
  { port: 'Santos, Brazil', region: 'South America primary port', time: '24 days' },
];

const incoterms = [
  { code: 'EXW', name: 'Ex Works', desc: 'Buyer arranges all transport from our plant gate. Lowest unit price — ideal for clients with established Turkish freight agents.' },
  { code: 'FCA', name: 'Free Carrier', desc: 'We deliver to your nominated carrier or forwarder. Goods cleared for export and loaded at our facility. A flexible mid-point option.' },
  { code: 'FOB', name: 'Free on Board', desc: 'Our most popular term. We handle everything until the goods are loaded on the vessel at the Turkish port. You manage ocean freight onward.' },
  { code: 'CFR', name: 'Cost & Freight', desc: 'We cover transport to the destination port. You handle insurance and unloading. Good when you want one landed cost quote without insurance complexity.' },
  { code: 'CIF', name: 'Cost, Insurance & Freight', desc: 'All-inclusive to destination port including marine insurance. The simplest option for buyers who want a single delivered price per tonne.' },
  { code: 'DAP', name: 'Delivered at Place', desc: 'Door-to-door delivery to your warehouse or plant. We handle all logistics including customs clearance at your end. Full peace of mind.' },
];

const faqs = [
  {
    q: 'Which countries does Sepiolite Mine export to?',
    a: "We export to over 45 countries across five continents. Our primary markets include Germany, Netherlands, Spain, Italy, and France in Europe; UAE, Saudi Arabia, Egypt, and Morocco in MENA; China, Japan, South Korea, and India in Asia Pacific; the USA, Canada, and Brazil in the Americas; and South Africa, Nigeria, and Kenya in Africa. We're always open to new markets and welcome enquiries from any country.",
  },
  {
    q: 'What shipping methods do you offer?',
    a: 'We offer containerised shipments (20ft and 40ft), bulk vessel charter for orders above 3,000 MT, and big bag (FIBC) options. Products can be palletised on 25 kg or 50 kg bags, or loaded loose in big bags of 1–1.5 MT each. All shipments include full documentation, certificate of analysis, and customs clearance support from our logistics team.',
  },
  {
    q: 'What Incoterms do you trade under?',
    a: 'We trade under Incoterms 2020: EXW, FCA, FOB, CFR, CIF, and DAP. FOB Turkish port (Gemlik or Mersin) is the most common arrangement, but we regularly ship CIF and DAP to clients who prefer a single delivered cost. Our logistics partners maintain competitive freight rates on all major shipping lanes.',
  },
  {
    q: 'What is the minimum order quantity?',
    a: 'The standard minimum is one 20-foot container, which holds approximately 18–22 tonnes depending on the product grade and packing type. For new clients or trial orders, we can accommodate smaller shipments of 5–10 tonnes. Bulk vessel orders typically start at 3,000 tonnes for Handy-size charters.',
  },
  {
    q: 'Do you provide private-label packaging?',
    a: 'Yes. We offer full private-label and white-label packaging for all product lines. This includes custom bag designs (25 kg, 50 kg, big bags), branded pallets, client-specific labels, and documentation under your company name. The minimum order for custom-printed packaging is one 20ft container. Lead time for new artwork approval is typically 2–3 weeks.',
  },
];
---

<Layout
  title="Global Markets — Sepiolite Export to 45+ Countries"
  description="Sepiolite Mine exports premium Turkish sepiolite to 45+ countries across Europe, Middle East, Asia Pacific, Americas, and Africa. Explore our regional presence, logistics capabilities, and market insights."
  locale="en"
  alternates={{ en: '/markets/', tr: '/tr/markets/' }}
  schemaJson={[breadcrumbSchema, organizationSchema, faqSchema]}
>
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li class="sep">›</li>
        <li aria-current="page">Markets</li>
      </ol>
    </div>
  </nav>

  <section class="hub-hero section section--dark">
    <div class="container container-narrow">
      <span class="section-tag">Global Presence</span>
      <h1>From Turkey to the <span class="accent">World</span></h1>
      <p class="lead">
        Strategically positioned at the crossroads of three continents, Sepiolite Mine delivers
        premium Turkish sepiolite to industrial partners across 45+ countries — with reliability,
        speed, and the quality that built our reputation over three decades.
      </p>
      <div class="hero-stats">
        <div class="hero-stat"><div class="num">45+</div><div class="label">Countries Served</div></div>
        <div class="hero-stat"><div class="num">300+</div><div class="label">Active Clients</div></div>
        <div class="hero-stat"><div class="num">120K</div><div class="label">MT Annual Capacity</div></div>
        <div class="hero-stat"><div class="num">5</div><div class="label">Continents Reached</div></div>
      </div>
    </div>
  </section>

  <section class="section strategic-section">
    <div class="container">
      <div class="strategic-grid">
        <div class="strategic-text">
          <span class="section-tag">Strategic Advantage</span>
          <h2>Turkey: The World's <span class="accent">Sepiolite Capital</span></h2>
          <p class="section-subtitle">
            Turkey holds an estimated 70% of global sepiolite reserves, concentrated in the
            Eskisehir-Sivrihisar basin. Our mines sit at the heart of this formation, giving us
            direct access to the planet's richest deposits and a logistical advantage few
            competitors can match.
          </p>
          <div class="advantage-list">
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">⚓</div>
              <div>
                <h4>Port Proximity</h4>
                <p>200 km to Gemlik port, 380 km to Mersin — Turkey's busiest mineral export terminals with daily container services to all major routes.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">🚀</div>
              <div>
                <h4>Rapid Transit Times</h4>
                <p>7–10 days to European ports, 14–18 days to the Americas, 20–25 days to Asia Pacific. Shorter transit means lower inventory costs for you.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">🏭</div>
              <div>
                <h4>Mine-to-Port Integration</h4>
                <p>Our processing plant is co-located with the mine. Ore goes from extraction to export-ready product in 48 hours, minimising lead times.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">📈</div>
              <div>
                <h4>Direct From Producer</h4>
                <p>No intermediaries. We control every step from extraction to FOB, ensuring transparent terms and consistent quality across all grades.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="map-visual">
          <div class="map-header">
            <div class="map-header-icon" aria-hidden="true">🌍</div>
            <h3>Key Trade Routes from Turkey</h3>
          </div>
          <div class="trade-routes">
            {tradeRoutes.map((r) => (
              <div class="trade-route">
                <span class="route-dot" aria-hidden="true"></span>
                <div class="route-info">
                  <strong>{r.port}</strong>
                  <span>{r.region}</span>
                </div>
                <span class="route-time">{r.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section regions-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Regional Markets</span>
        <h2>Where Our <span class="accent">Sepiolite</span> Goes</h2>
        <p>Each region has unique industrial demands and regulatory requirements. We tailor our product grades, packaging, and documentation to fit every market perfectly.</p>
      </div>

      <div class="regions-grid">
        {regions.map((region) => (
          <div class="region-card">
            <div class="region-card-header">
              <div class="region-card-flag" aria-hidden="true">{region.flag}</div>
              <h3>{region.name}</h3>
              <div class="region-subtitle">{region.subtitle}</div>
            </div>
            <div class="region-card-body">
              <p>{region.desc}</p>
              <div class="region-countries">
                {region.countries.map((c) => <span class="region-country">{c}</span>)}
              </div>
              <div class="region-stats">
                {region.stats.map((s) => (
                  <div class="region-stat">
                    <div class="region-stat-num">{s.num}</div>
                    <div class="region-stat-label">{s.label}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section logistics-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Logistics</span>
        <h2>End-to-End <span class="accent">Shipping</span> Solutions</h2>
      </div>

      <div class="logistics-grid">
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">📦</div>
          <h3>Containerised</h3>
          <p>Standard 20ft and 40ft containers for palletised bags (25–50 kg) or big bags (1–1.5 MT). Weekly sailings from Gemlik and Mersin ports to all major trade lanes.</p>
        </div>
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">🚢</div>
          <h3>Bulk Vessel</h3>
          <p>Handy-size to Panamax charter for large orders starting at 3,000 MT. Ideal for cat litter and construction-grade buyers with silo storage at destination.</p>
        </div>
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">📋</div>
          <h3>Documentation</h3>
          <p>Full export documentation: Bill of Lading, Certificate of Origin, Phytosanitary Certificate, Certificate of Analysis, MSDS, and customs declarations handled in-house.</p>
        </div>
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">🏷️</div>
          <h3>Private Label</h3>
          <p>Custom branding, packaging design, bag sizes, and pallet configurations. We can ship under your brand name with your specifications — turnkey white-label service.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark terms-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Trade Terms</span>
        <h2>Incoterms <span class="accent">2020</span> We Trade Under</h2>
      </div>

      <div class="terms-grid">
        {incoterms.map((t) => (
          <div class="term-card">
            <div class="term-code">{t.code}</div>
            <div class="term-name">{t.name}</div>
            <div class="term-desc">{t.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section insights-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Market Intelligence</span>
        <h2>Sepiolite Market <span class="accent">At a Glance</span></h2>
      </div>

      <div class="insights-grid">
        <div class="insight-card">
          <div class="insight-num">$340M</div>
          <h3>Global Market Size (2025)</h3>
          <p>The global sepiolite market is valued at approximately USD 340 million, with steady growth driven by expanding applications in pet care, drilling, and environmental sectors.</p>
        </div>
        <div class="insight-card">
          <div class="insight-num">4.8%</div>
          <h3>Annual Growth Rate (CAGR)</h3>
          <p>Projected 4.8% CAGR through 2030, fuelled by rising pet ownership in developing markets, growing environmental remediation needs, and the bioplastics revolution.</p>
        </div>
        <div class="insight-card">
          <div class="insight-num">70%</div>
          <h3>Turkey's Reserve Share</h3>
          <p>Turkey holds roughly 70% of the world's known sepiolite reserves, primarily in the Eskisehir and Konya provinces — making it the undisputed global leader in sepiolite mining.</p>
        </div>
        <div class="insight-card">
          <div class="insight-num">38%</div>
          <h3>Pet Care Segment Share</h3>
          <p>Cat litter and pet care products account for the largest single application segment, driven by the shift from clay-based to mineral-based premium litters across Europe and Asia.</p>
        </div>
        <div class="insight-card">
          <div class="insight-num">22%</div>
          <h3>Construction & Industrial</h3>
          <p>Construction insulation and industrial applications represent the second-largest segment, propelled by green building regulations demanding lightweight, fire-resistant mineral additives.</p>
        </div>
        <div class="insight-card">
          <div class="insight-num">+15%</div>
          <h3>Bioplastics Growth (YoY)</h3>
          <p>The fastest-growing application. Sepiolite nano-fibres as PLA/PHA reinforcement are creating a new demand vertical, with year-over-year growth exceeding 15% since 2023.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container container-narrow">
      <div class="section-header">
        <span class="section-tag">Frequently Asked</span>
        <h2>Trade & Export <span class="accent">FAQ</span></h2>
      </div>

      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a"><p>{item.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band section section--dark">
    <div class="container container-narrow">
      <h2>Ready to Start Trading?</h2>
      <p>Whether you need a trial container or a long-term supply contract, our commercial team is ready to build a partnership that works for your market.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn btn-primary">Request a Quote</a>
        <a href="/products/" class="btn btn-outline">View Products</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb-bar { background: var(--c-cream); border-bottom: 1px solid var(--c-cream-dark); padding-block: var(--s-3); }
  .breadcrumb { list-style: none; margin: 0; padding: 0; display: flex; gap: var(--s-2); font-size: 0.85rem; color: var(--c-text-muted); }
  .breadcrumb a { color: var(--c-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--c-gold-dark); }
  .breadcrumb [aria-current='page'] { color: var(--c-earth); font-weight: 500; }
  .breadcrumb .sep { color: var(--c-stone); }

  .hub-hero { text-align: center; padding-block: var(--s-7); }
  .hub-hero h1 { color: var(--c-white); margin-bottom: var(--s-3); }
  .hub-hero .accent { color: var(--c-gold); }
  .hub-hero .lead { color: var(--c-text-light); font-size: 1.1rem; line-height: 1.7; max-width: 720px; margin: 0 auto; }

  .hero-stats { display: flex; justify-content: center; gap: var(--s-6); margin-top: var(--s-6); flex-wrap: wrap; }
  .hero-stat { text-align: center; }
  .hero-stat .num { font-family: var(--font-serif); font-size: 2.4rem; font-weight: 800; color: var(--c-gold); line-height: 1; }
  .hero-stat .label { font-size: 0.78rem; color: var(--c-text-light); margin-top: 0.35rem; letter-spacing: 0.04em; }

  .accent { color: var(--c-gold-dark); }
  .section-tag { display: inline-block; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--c-gold-dark); margin-bottom: var(--s-2); }
  .section-header { text-align: center; margin-bottom: var(--s-6); }
  .section-header h2 { margin-bottom: var(--s-2); }
  .section-header p { color: var(--c-text-muted); max-width: 640px; margin: 0 auto; line-height: 1.7; }

  /* Strategic */
  .strategic-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-6); align-items: start; }
  .section-subtitle { font-size: 1.02rem; color: var(--c-text-muted); line-height: 1.75; margin-bottom: var(--s-4); }
  .advantage-list { display: flex; flex-direction: column; gap: var(--s-3); }
  .advantage-item { display: flex; gap: var(--s-3); align-items: flex-start; }
  .advantage-icon { width: 44px; height: 44px; background: rgba(201,146,42,0.14); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.1rem; }
  .advantage-item h4 { font-family: var(--font-serif); font-size: 1rem; color: var(--c-earth); margin: 0 0 0.3rem; }
  .advantage-item p { font-size: 0.88rem; color: var(--c-text-muted); line-height: 1.6; margin: 0; }

  .map-visual { background: var(--c-cream); border-radius: var(--r-card); padding: var(--s-5); border: 1px solid var(--c-cream-dark); }
  .map-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: var(--s-4); }
  .map-header-icon { width: 40px; height: 40px; background: var(--c-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--c-white); font-size: 1.1rem; }
  .map-header h3 { font-family: var(--font-serif); font-size: 1.2rem; color: var(--c-earth); margin: 0; }
  .trade-routes { display: flex; flex-direction: column; gap: var(--s-2); }
  .trade-route { display: flex; align-items: center; gap: var(--s-3); padding: 0.85rem 1rem; background: var(--c-white); border-radius: 8px; border: 1px solid var(--c-cream-dark); transition: border-color var(--t), box-shadow var(--t); }
  .trade-route:hover { border-color: var(--c-gold); box-shadow: var(--sh-soft); }
  .route-dot { width: 10px; height: 10px; background: var(--c-gold); border-radius: 50%; flex-shrink: 0; box-shadow: 0 0 0 3px rgba(201,146,42,0.2); }
  .route-info { flex: 1; }
  .route-info strong { display: block; font-size: 0.9rem; color: var(--c-earth); margin-bottom: 0.15rem; }
  .route-info span { font-size: 0.78rem; color: var(--c-stone); }
  .route-time { font-size: 0.74rem; font-weight: 700; color: var(--c-gold-dark); background: rgba(201,146,42,0.12); padding: 0.3rem 0.6rem; border-radius: 4px; white-space: nowrap; }

  /* Regions */
  .regions-section { background: var(--c-cream); }
