---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/" },
      { "@type": "ListItem", "position": 2, "name": "Markets", "item": "https://sepiolitemine.com/markets/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sepiolite Mine – Zamana",
    "url": "https://sepiolitemine.com",
    "description": "Turkey's premier sepiolite producer and exporter serving 45+ countries worldwide with premium raw and processed sepiolite grades.",
    "areaServed": [
      { "@type": "Continent", "name": "Europe" },
      { "@type": "Continent", "name": "Asia" },
      { "@type": "Continent", "name": "Africa" },
      { "@type": "Continent", "name": "North America" },
      { "@type": "Continent", "name": "South America" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which countries does Sepiolite Mine export to?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sepiolite Mine exports to over 45 countries across Europe (Germany, Netherlands, Spain, Italy, France, Poland, UK), Middle East & North Africa (UAE, Saudi Arabia, Egypt, Morocco), Asia Pacific (China, Japan, South Korea, India), the Americas (USA, Canada, Brazil, Mexico), and Sub-Saharan Africa (South Africa, Nigeria, Kenya)."
        }
      },
      {
        "@type": "Question",
        "name": "What shipping methods does Sepiolite Mine offer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We offer containerised shipments (20ft and 40ft), bulk vessel charter for large orders, big bag (FIBC) options, and palletised 25–50kg bags. All shipments include full documentation, certificate of analysis, and customs clearance support."
        }
      },
      {
        "@type": "Question",
        "name": "What are the Incoterms available?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We trade under EXW, FCA, FOB, CFR, CIF, and DAP Incoterms 2020. FOB Turkish port is the most common arrangement, but we can deliver CIF/DAP to any world port with competitive freight rates through our logistics partners."
        }
      },
      {
        "@type": "Question",
        "name": "What is the minimum order quantity for export?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The standard minimum order is one 20-foot container (~18–22 tonnes depending on product density). For new clients or trial orders, we can accommodate smaller quantities of 5–10 tonnes. Bulk vessel orders typically start at 3,000 tonnes."
        }
      },
      {
        "@type": "Question",
        "name": "Does Sepiolite Mine provide private labelling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We offer full private-label and white-label packaging for all product lines. This includes custom bag designs (25kg, 50kg, big bag), branded pallets, and client-specific documentation. Minimum order for private-label packaging is one 20ft container."
        }
      }
    ]
  }
];
---

<Layout
  title="Global Markets – Sepiolite Export to 45+ Countries"
  description="Sepiolite Mine exports premium Turkish sepiolite to 45+ countries across Europe, Middle East, Asia Pacific, Americas, and Africa. Explore our regional presence, logistics capabilities, and market insights."
  locale="en"
  alternates={{ en: "/markets/", tr: "/tr/markets/" }}
  schemaJson={schemaJson}
>
<!-- ===== HEADER ===== -->
  

  <!-- ===== BREADCRUMB ===== -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep">&#8250;</span>
        <span class="current">Markets</span>
      </div>
    </div>
  </div>

  <!-- ===== HERO ===== -->
  <section class="markets-hero">
    <div class="container">
      <span class="section-tag">Global Presence</span>
      <h1>From Turkey to the <span>World</span></h1>
      <p>Strategically positioned at the crossroads of three continents, Sepiolite Mine delivers premium Turkish sepiolite to industrial partners across 45+ countries — with reliability, speed, and the quality that built our reputation over three decades.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-num">45+</div>
          <div class="hero-stat-label">Countries Served</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">300+</div>
          <div class="hero-stat-label">Active Clients</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">120K</div>
          <div class="hero-stat-label">MT Annual Capacity</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">5</div>
          <div class="hero-stat-label">Continents Reached</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STRATEGIC POSITION ===== -->
  <section class="strategic-section">
    <div class="container">
      <div class="strategic-grid">
        <div class="strategic-text reveal">
          <span class="section-tag">Strategic Advantage</span>
          <h2 class="section-title">Turkey: The World's <span>Sepiolite Capital</span></h2>
          <p class="section-subtitle">Turkey holds an estimated 70% of global sepiolite reserves, concentrated in the Eskisehir-Sivrihisar basin. Our mines sit at the heart of this formation, giving us direct access to the planet's richest deposits and a logistical advantage few competitors can match.</p>
          <div class="advantage-list">
            <div class="advantage-item">
              <div class="advantage-icon">&#9875;</div>
              <div>
                <h4>Port Proximity</h4>
                <p>200 km to Gemlik port, 380 km to Mersin — Turkey's busiest mineral export terminals with daily container services to all major routes.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon">&#128640;</div>
              <div>
                <h4>Rapid Transit Times</h4>
                <p>7–10 days to European ports, 14–18 days to the Americas, 20–25 days to Asia Pacific. Shorter transit means lower inventory costs for you.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon">&#127981;</div>
              <div>
                <h4>Mine-to-Port Integration</h4>
                <p>Our processing plant is co-located with the mine. Ore goes from extraction to export-ready product in 48 hours, minimising lead times.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon">&#128200;</div>
              <div>
                <h4>Competitive Pricing</h4>
                <p>No intermediaries. We control every step from extraction to FOB, which translates into consistently competitive pricing across all grades.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="map-visual reveal">
          <div class="map-header">
            <div class="map-header-icon">&#127758;</div>
            <h3>Key Trade Routes from Turkey</h3>
          </div>
          <div class="trade-routes">
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Rotterdam, Netherlands</strong>
                <span>Europe's largest mineral hub</span>
              </div>
              <span class="route-time">7 days</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Jebel Ali, UAE</strong>
                <span>Middle East & re-export gateway</span>
              </div>
              <span class="route-time">10 days</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Shanghai, China</strong>
                <span>Asia Pacific primary port</span>
              </div>
              <span class="route-time">22 days</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>New York / Newark, USA</strong>
                <span>North America east coast</span>
              </div>
              <span class="route-time">18 days</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Casablanca, Morocco</strong>
                <span>North Africa & agriculture corridor</span>
              </div>
              <span class="route-time">5 days</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Santos, Brazil</strong>
                <span>South America primary port</span>
              </div>
              <span class="route-time">24 days</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== REGIONAL MARKETS ===== -->
  <section class="regions-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Regional Markets</span>
        <h2 class="section-title">Where Our <span>Sepiolite</span> Goes</h2>
        <p>Each region has unique industrial demands and regulatory requirements. We tailor our product grades, packaging, and documentation to fit every market perfectly.</p>
      </div>

      <div class="regions-grid">

        <!-- Europe -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127466;&#127482;</div>
            <h3>Europe</h3>
            <div class="region-subtitle">Our largest export market</div>
          </div>
          <div class="region-card-body">
            <p>Europe accounts for 45% of our exports, driven by strong demand in pet care (cat litter), paints & coatings, and construction insulation. REACH-compliant grades available for all product lines.</p>
            <div class="region-countries">
              <span class="region-country">Germany</span>
              <span class="region-country">Netherlands</span>
              <span class="region-country">Spain</span>
              <span class="region-country">Italy</span>
              <span class="region-country">France</span>
              <span class="region-country">Poland</span>
              <span class="region-country">UK</span>
              <span class="region-country">Belgium</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">45%</div>
                <div class="region-stat-label">Export Share</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">18</div>
                <div class="region-stat-label">Countries</div>
              </div>
            </div>
          </div>
        </div>

        <!-- MENA -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127472;&#127484;</div>
            <h3>Middle East &amp; North Africa</h3>
            <div class="region-subtitle">Fastest-growing corridor</div>
          </div>
          <div class="region-card-body">
            <p>Oil & gas drilling, construction boom, and expanding pet care markets make MENA our fastest-growing region. Strategic proximity means 5–10 day delivery to any Gulf or North African port.</p>
            <div class="region-countries">
              <span class="region-country">UAE</span>
              <span class="region-country">Saudi Arabia</span>
              <span class="region-country">Egypt</span>
              <span class="region-country">Morocco</span>
              <span class="region-country">Israel</span>
              <span class="region-country">Qatar</span>
              <span class="region-country">Tunisia</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">25%</div>
                <div class="region-stat-label">Export Share</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">12</div>
                <div class="region-stat-label">Countries</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Asia Pacific -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127471;&#127477;</div>
            <h3>Asia Pacific</h3>
            <div class="region-subtitle">High-growth industrial demand</div>
          </div>
          <div class="region-card-body">
            <p>Rapidly industrialising economies drive demand for drilling-grade sepiolite, catalysis supports, and agricultural carriers. China, Japan, and South Korea are our top-3 Asian markets by volume.</p>
            <div class="region-countries">
              <span class="region-country">China</span>
              <span class="region-country">Japan</span>
              <span class="region-country">South Korea</span>
              <span class="region-country">India</span>
              <span class="region-country">Thailand</span>
              <span class="region-country">Vietnam</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">15%</div>
                <div class="region-stat-label">Export Share</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">9</div>
                <div class="region-stat-label">Countries</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Americas -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127482;&#127480;</div>
            <h3>The Americas</h3>
            <div class="region-subtitle">Premium grade focus</div>
          </div>
          <div class="region-card-body">
            <p>The US and Canada import high-purity drilling and pharmaceutical-grade sepiolite, while Brazil and Mexico are growing markets for agricultural and environmental applications.</p>
            <div class="region-countries">
              <span class="region-country">USA</span>
              <span class="region-country">Canada</span>
              <span class="region-country">Brazil</span>
              <span class="region-country">Mexico</span>
              <span class="region-country">Argentina</span>
              <span class="region-country">Colombia</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">10%</div>
                <div class="region-stat-label">Export Share</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">8</div>
                <div class="region-stat-label">Countries</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sub-Saharan Africa -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127487;&#127462;</div>
            <h3>Sub-Saharan Africa</h3>
            <div class="region-subtitle">Emerging opportunity</div>
          </div>
          <div class="region-card-body">
            <p>Agriculture-driven demand for soil conditioners and fertiliser carriers is opening new markets across East and Southern Africa. Environmental remediation projects are also creating opportunities.</p>
            <div class="region-countries">
              <span class="region-country">South Africa</span>
              <span class="region-country">Nigeria</span>
              <span class="region-country">Kenya</span>
              <span class="region-country">Ethiopia</span>
              <span class="region-country">Tanzania</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">5%</div>
                <div class="region-stat-label">Export Share</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">7</div>
                <div class="region-stat-label">Countries</div>
              </div>
            </div>
          </div>
        </div>

        <!-- CIS / Central Asia -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127479;&#127482;</div>
            <h3>CIS &amp; Central Asia</h3>
            <div class="region-subtitle">Drilling & industrial base</div>
          </div>
          <div class="region-card-body">
            <p>Oil & gas-rich economies of the Caspian region and Central Asia are consistent importers of drilling-grade sepiolite and industrial absorbents. Land routes via Georgia offer cost-effective transport.</p>
            <div class="region-countries">
              <span class="region-country">Russia</span>
              <span class="region-country">Kazakhstan</span>
              <span class="region-country">Azerbaijan</span>
              <span class="region-country">Georgia</span>
              <span class="region-country">Uzbekistan</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">~5%</div>
                <div class="region-stat-label">Export Share</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">6</div>
                <div class="region-stat-label">Countries</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== LOGISTICS & SHIPPING ===== -->
  <section class="logistics-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Logistics</span>
        <h2 class="section-title">End-to-End <span>Shipping</span> Solutions</h2>
      </div>

      <div class="logistics-grid">
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128230;</div>
          <h3>Containerised</h3>
          <p>Standard 20ft and 40ft containers for palletised bags (25–50 kg) or big bags (1–1.5 MT). Weekly sailings from Gemlik and Mersin ports to all major trade lanes.</p>
        </div>
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128674;</div>
          <h3>Bulk Vessel</h3>
          <p>Handy-size to Panamax charter for large orders starting at 3,000 MT. Ideal for cat litter and construction-grade buyers with silo storage at destination.</p>
        </div>
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128203;</div>
          <h3>Documentation</h3>
          <p>Full export documentation: Bill of Lading, Certificate of Origin, Phytosanitary Certificate, Certificate of Analysis, MSDS, and customs declarations handled in-house.</p>
        </div>
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128737;&#65039;</div>
          <h3>Private Label</h3>
          <p>Custom branding, packaging design, bag sizes, and pallet configurations. We can ship under your brand name with your specifications — turnkey white-label service.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRADE TERMS ===== -->
  <section class="terms-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag" style="color:var(--gold-light);">Trade Terms</span>
        <h2 class="section-title" style="color:var(--white);">Incoterms <span>2020</span> We Trade Under</h2>
      </div>

      <div class="terms-grid">
        <div class="term-card reveal">
          <div class="term-code">EXW</div>
          <div class="term-name">Ex Works</div>
          <div class="term-desc">Buyer arranges all transport from our plant gate. Lowest unit price — ideal for clients with established Turkish freight agents.</div>
        </div>
        <div class="term-card reveal">
          <div class="term-code">FCA</div>
          <div class="term-name">Free Carrier</div>
          <div class="term-desc">We deliver to your nominated carrier or forwarder. Goods cleared for export and loaded at our facility. A flexible mid-point option.</div>
        </div>
        <div class="term-card reveal">
          <div class="term-code">FOB</div>
          <div class="term-name">Free on Board</div>
          <div class="term-desc">Our most popular term. We handle everything until the goods are loaded on the vessel at the Turkish port. You manage ocean freight onward.</div>
        </div>
        <div class="term-card reveal">
          <div class="term-code">CFR</div>
          <div class="term-name">Cost &amp; Freight</div>
          <div class="term-desc">We cover transport to the destination port. You handle insurance and unloading. Good when you want one landed cost quote without insurance complexity.</div>
        </div>
        <div class="term-card reveal">
          <div class="term-code">CIF</div>
          <div class="term-name">Cost, Insurance &amp; Freight</div>
          <div class="term-desc">All-inclusive to destination port including marine insurance. The simplest option for buyers who want a single delivered price per tonne.</div>
        </div>
        <div class="term-card reveal">
          <div class="term-code">DAP</div>
          <div class="term-name">Delivered at Place</div>
          <div class="term-desc">Door-to-door delivery to your warehouse or plant. We handle all logistics including customs clearance at your end. Full peace of mind.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MARKET INSIGHTS ===== -->
  <section class="insights-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Market Intelligence</span>
        <h2 class="section-title">Sepiolite Market <span>At a Glance</span></h2>
      </div>

      <div class="insights-grid">
        <div class="insight-card reveal">
          <div class="insight-num">$340M</div>
          <h3>Global Market Size (2025)</h3>
          <p>The global sepiolite market is valued at approximately USD 340 million, with steady growth driven by expanding applications in pet care, drilling, and environmental sectors.</p>
          <div class="insight-bar"><div class="insight-bar-fill" style="width:68%;"></div></div>
        </div>
        <div class="insight-card reveal">
          <div class="insight-num">4.8%</div>
          <h3>Annual Growth Rate (CAGR)</h3>
          <p>Projected 4.8% CAGR through 2030, fuelled by rising pet ownership in developing markets, growing environmental remediation needs, and the bioplastics revolution.</p>
          <div class="insight-bar"><div class="insight-bar-fill" style="width:48%;"></div></div>
        </div>
        <div class="insight-card reveal">
          <div class="insight-num">70%</div>
          <h3>Turkey's Reserve Share</h3>
          <p>Turkey holds roughly 70% of the world's known sepiolite reserves, primarily in the Eskisehir and Konya provinces — making it the undisputed global leader in sepiolite mining.</p>
          <div class="insight-bar"><div class="insight-bar-fill" style="width:70%;"></div></div>
        </div>
        <div class="insight-card reveal">
          <div class="insight-num">38%</div>
          <h3>Pet Care Segment Share</h3>
          <p>Cat litter and pet care products account for the largest single application segment, driven by the shift from clay-based to mineral-based premium litters across Europe and Asia.</p>
          <div class="insight-bar"><div class="insight-bar-fill" style="width:38%;"></div></div>
        </div>
        <div class="insight-card reveal">
          <div class="insight-num">22%</div>
          <h3>Construction & Industrial</h3>
          <p>Construction insulation and industrial applications represent the second-largest segment, propelled by green building regulations demanding lightweight, fire-resistant mineral additives.</p>
          <div class="insight-bar"><div class="insight-bar-fill" style="width:22%;"></div></div>
        </div>
        <div class="insight-card reveal">
          <div class="insight-num">+15%</div>
          <h3>Bioplastics Growth (YoY)</h3>
          <p>The fastest-growing application. Sepiolite nano-fibres as PLA/PHA reinforcement are creating a new demand vertical, with year-over-year growth exceeding 15% since 2023.</p>
          <div class="insight-bar"><div class="insight-bar-fill" style="width:15%;"></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="faq-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Frequently Asked</span>
        <h2 class="section-title">Trade &amp; Export <span>FAQ</span></h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            Which countries does Sepiolite Mine export to?
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
          <div class="faq-a">
            <p>We export to over 45 countries across five continents. Our primary markets include Germany, Netherlands, Spain, Italy, and France in Europe; UAE, Saudi Arabia, Egypt, and Morocco in MENA; China, Japan, South Korea, and India in Asia Pacific; the USA, Canada, and Brazil in the Americas; and South Africa, Nigeria, and Kenya in Africa. We're always open to new markets and welcome enquiries from any country.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            What shipping methods do you offer?
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
          <div class="faq-a">
            <p>We offer containerised shipments (20ft and 40ft), bulk vessel charter for orders above 3,000 MT, and big bag (FIBC) options. Products can be palletised on 25 kg or 50 kg bags, or loaded loose in big bags of 1–1.5 MT each. All shipments include full documentation, certificate of analysis, and customs clearance support from our logistics team.</p>
          </div>
        </div>
        <div class="faq-item">
