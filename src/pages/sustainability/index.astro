---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/" },
      { "@type": "ListItem", "position": 2, "name": "Sustainability", "item": "https://sepiolitemine.com/sustainability/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sepiolite Mine – Zamana",
    "url": "https://sepiolitemine.com",
    "description": "Turkey's premier sepiolite producer committed to responsible mining, zero lost-time incidents, and carbon neutrality by 2035.",
    "areaServed": [
      { "@type": "Continent", "name": "Europe" },
      { "@type": "Continent", "name": "Asia" },
      { "@type": "Continent", "name": "Africa" },
      { "@type": "Continent", "name": "North America" },
      { "@type": "Continent", "name": "South America" }
    ],
    "certifications": [
      "ISO 9001:2015",
      "ISO 14001:2015",
      "ISO 45001:2018",
      "REACH Compliance",
      "Mining License & EIA"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is sepiolite mining environmentally harmful?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Not when done responsibly. Sepiolite deposits are relatively shallow (50–150m), and unlike deep mining, our operations don't create subsidence or damage water tables. We practise progressive restoration: each extraction zone is immediately rehabilitated with native vegetation, soil amendment, and long-term monitoring. Our zero-discharge water systems ensure no environmental leakage. Mining is land-use intensive, but with proper closure planning, extracted land becomes productive again in 5–7 years."
        }
      },
      {
        "@type": "Question",
        "name": "What happens to the land after mining is complete?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our binding closure plans mandate full site restoration. Post-extraction zones are backfilled with approved materials, native flora is replanted according to regional biodiversity studies, soil is amended, and we maintain a 5-year post-closure monitoring program. Restored land is suitable for agriculture, reforestation, or habitat recreation depending on regional land-use planning. We've successfully rehabilitated 15 hectares to date and track all restoration progress publicly in our annual sustainability report."
        }
      },
      {
        "@type": "Question",
        "name": "Do you have ISO environmental certifications?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We hold ISO 14001:2015 Environmental Management System certification, ISO 9001:2015 Quality Management, and ISO 45001:2018 Occupational Health & Safety. We also comply with REACH (EU chemical regulation), maintain FDA-listed product grades, and hold a valid Mining License with approved Environmental Impact Assessment. All certifications are independently audited annually."
        }
      },
      {
        "@type": "Question",
        "name": "How do you manage water usage in mining operations?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our operations employ a zero-discharge closed-loop water circuit. All process water is recycled through settling and filtration systems — we achieve 100% recycling with no mineral waste discharged to waterways. Stormwater is managed via retention ponds and infiltration systems. We conduct quarterly third-party water quality audits and publish results in our annual sustainability report. Freshwater extraction from local aquifers is strictly regulated and approved by regional water authorities."
        }
      },
      {
        "@type": "Question",
        "name": "What is your carbon neutrality timeline?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our roadmap targets carbon neutrality by 2035. Current progress: 30% of energy now comes from on-site solar (Phase 2 completed 2023). Phase 3 (2026–2028) will add wind and grid renewable power. Fleet electrification pilots begin in 2026. By 2035, we aim for Scope 1 & 2 net-zero through a combination of renewables, energy efficiency, and verified carbon offsets. Annual progress reports are published on our sustainability hub."
        }
      }
    ]
  }
];
---

