---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sepiolitemine.com/" },
      { "@type": "ListItem", "position": 2, "name": "Applications", "item": "https://sepiolitemine.com/applications/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Sepiolite Applications",
    "numberOfItems": 9,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "url": "https://sepiolitemine.com/applications/pet-care-cat-litter/" },
      { "@type": "ListItem", "position": 2, "url": "https://sepiolitemine.com/applications/agriculture/" },
      { "@type": "ListItem", "position": 3, "url": "https://sepiolitemine.com/applications/oil-gas-drilling/" },
      { "@type": "ListItem", "position": 4, "url": "https://sepiolitemine.com/applications/construction/" },
      { "@type": "ListItem", "position": 5, "url": "https://sepiolitemine.com/applications/environmental-remediation/" },
      { "@type": "ListItem", "position": 6, "url": "https://sepiolitemine.com/applications/paints-coatings/" },
      { "@type": "ListItem", "position": 7, "url": "https://sepiolitemine.com/applications/catalysis-chemical/" },
      { "@type": "ListItem", "position": 8, "url": "https://sepiolitemine.com/applications/pharma-cosmetics/" },
      { "@type": "ListItem", "position": 9, "url": "https://sepiolitemine.com/applications/bioplastics/" }
    ]
  }
];
---

<Layout
  title="Sepiolite Applications – Industries We Serve"
  description="Discover how Turkish sepiolite serves 9+ industries — from pet care and agriculture to oil & gas drilling, construction, environmental remediation, and advanced materials. Explore application-specific solutions."
  locale="en"
  alternates={{ en: "/applications/", tr: "/tr/applications/" }}
  schemaJson={schemaJson}
>
<!-- ===== HEADER ===== -->
  

  <!-- ===== BREADCRUMB ===== -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep">&#8250;</span>
        <span class="current">Applications</span>
      </div>
    </div>
  </div>

  <!-- ===== HERO ===== -->
  <section class="apps-hero">
    <div class="container">
      <span class="section-tag">Industry Applications</span>
      <h1>One Mineral, <span>Infinite</span> Possibilities</h1>
      <p>Sepiolite's unique fibrous microstructure delivers extraordinary absorption, rheological control, and thermal resistance across a remarkably diverse range of industries.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-num">9+</div>
          <div class="hero-stat-label">Industries Served</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">200+</div>
          <div class="hero-stat-label">Client Companies</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">45+</div>
          <div class="hero-stat-label">Countries Reached</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">30+</div>
          <div class="hero-stat-label">Years of Expertise</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== APPLICATION GRID ===== -->
  <section class="apps-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Explore Applications</span>
        <h2 class="section-title">Sepiolite Solutions for <span>Every Industry</span></h2>
        <p>From household pet care to deep-well drilling, sepiolite's natural properties make it indispensable. Click any application to explore detailed specifications, benefits, and use cases.</p>
      </div>

      <div class="grid-3">

        <!-- 1. Pet Care & Cat Litter -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Top Seller</span>
            <div class="app-card-icon">&#128049;</div>
            <h3>Pet Care &amp; Cat Litter</h3>
          </div>
          <div class="app-card-body">
            <p>Ultra-absorbent, low-dust sepiolite granules for premium cat litter. Superior odour control, lightweight, and 100% natural — preferred by Europe's top pet care brands.</p>
            <div class="app-highlights">
              <span class="app-highlight">240% Absorption</span>
              <span class="app-highlight">Low Dust</span>
              <span class="app-highlight">Natural</span>
            </div>
            <a href="pet-care-cat-litter/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 2. Agriculture -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">High Growth</span>
            <div class="app-card-icon">&#127793;</div>
            <h3>Agriculture &amp; Soil Science</h3>
          </div>
          <div class="app-card-body">
            <p>Soil conditioner, fertiliser carrier, and pesticide binder. Sepiolite improves water retention by up to 40%, enhances nutrient delivery, and supports sustainable farming practices.</p>
            <div class="app-highlights">
              <span class="app-highlight">Soil Amendment</span>
              <span class="app-highlight">Carrier</span>
              <span class="app-highlight">Eco-Friendly</span>
            </div>
            <a href="agriculture/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 3. Oil & Gas Drilling -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Technical</span>
            <div class="app-card-icon">&#9981;&#65039;</div>
            <h3>Oil &amp; Gas Drilling</h3>
          </div>
          <div class="app-card-body">
            <p>API-compliant drilling fluid additive for saltwater, geothermal, and HDD applications. Maintains stable rheology where bentonite fails — up to 250°C and in saturated brines.</p>
            <div class="app-highlights">
              <span class="app-highlight">API 13A</span>
              <span class="app-highlight">Salt Tolerant</span>
              <span class="app-highlight">HT Stable</span>
            </div>
            <a href="oil-gas-drilling/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 4. Construction & Insulation -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Industrial</span>
            <div class="app-card-icon">&#127959;&#65039;</div>
            <h3>Construction &amp; Insulation</h3>
          </div>
          <div class="app-card-body">
            <p>Lightweight insulation boards, fireproof coatings, and workability-enhancing mortar additive. Low thermal conductivity and inherent fire resistance make sepiolite ideal for green building.</p>
            <div class="app-highlights">
              <span class="app-highlight">Fireproof</span>
              <span class="app-highlight">Low Density</span>
              <span class="app-highlight">Insulating</span>
            </div>
            <a href="construction/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 5. Environmental Remediation -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Green Tech</span>
            <div class="app-card-icon">&#127811;</div>
            <h3>Environmental Remediation</h3>
          </div>
          <div class="app-card-body">
            <p>Heavy metal adsorption, industrial spill cleanup, and wastewater treatment. Sepiolite's high CEC and fibrous channels trap contaminants at molecular level for lasting remediation.</p>
            <div class="app-highlights">
              <span class="app-highlight">Heavy Metals</span>
              <span class="app-highlight">Spill Control</span>
              <span class="app-highlight">Wastewater</span>
            </div>
            <a href="environmental-remediation/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 6. Paints & Coatings -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Specialty</span>
            <div class="app-card-icon">&#127912;</div>
            <h3>Paints &amp; Coatings</h3>
          </div>
          <div class="app-card-body">
            <p>Rheology modifier, anti-sag agent, and anti-settling additive for water-based and solvent paints. Provides thixotropy without affecting colour or finish quality.</p>
            <div class="app-highlights">
              <span class="app-highlight">Anti-Sag</span>
              <span class="app-highlight">Thixotropy</span>
              <span class="app-highlight">Low VOC</span>
            </div>
            <a href="paints-coatings/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 7. Catalysis & Chemical Processing -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Advanced</span>
            <div class="app-card-icon">&#9878;&#65039;</div>
            <h3>Catalysis &amp; Chemical</h3>
          </div>
          <div class="app-card-body">
            <p>Catalyst support, molecular sieve, and reaction medium. Sepiolite's 200+ m²/g surface area and tuneable pore structure make it a versatile platform for industrial catalysis.</p>
            <div class="app-highlights">
              <span class="app-highlight">Catalyst Support</span>
              <span class="app-highlight">High Surface</span>
              <span class="app-highlight">Porous</span>
            </div>
            <a href="catalysis-chemical/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 8. Pharma & Cosmetics -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Premium</span>
            <div class="app-card-icon">&#128138;</div>
            <h3>Pharma &amp; Cosmetics</h3>
          </div>
          <div class="app-card-body">
            <p>Excipient, suspension stabiliser, and active ingredient carrier for pharmaceuticals and cosmetics. USP/EP grade purity ensures compliance with the strictest regulatory standards.</p>
            <div class="app-highlights">
              <span class="app-highlight">USP Grade</span>
              <span class="app-highlight">Excipient</span>
              <span class="app-highlight">Stabiliser</span>
            </div>
            <a href="pharma-cosmetics/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <!-- 9. Bioplastics & Advanced Materials -->
        <div class="app-card reveal">
          <div class="app-card-header">
            <span class="app-card-tag">Emerging</span>
            <div class="app-card-icon">&#9851;&#65039;</div>
            <h3>Bioplastics &amp; Composites</h3>
          </div>
          <div class="app-card-body">
            <p>Natural nano-filler for bioplastics, PLA composites, and bio-based packaging. Enhances tensile strength, barrier properties, and biodegradation rate for next-generation sustainable materials.</p>
            <div class="app-highlights">
              <span class="app-highlight">Nano-Filler</span>
              <span class="app-highlight">PLA/PHA</span>
              <span class="app-highlight">Sustainable</span>
            </div>
            <a href="bioplastics/" class="app-link">Explore Application <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== WHY SEPIOLITE ===== -->
  <section class="why-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">The Sepiolite Advantage</span>
        <h2 class="section-title">Why Industries Choose <span>Sepiolite</span></h2>
      </div>

      <div class="why-grid">
        <div class="why-card reveal">
          <div class="why-icon">&#128167;</div>
          <h3>Superior Absorption</h3>
          <p>Absorbs up to 2.5x its weight in liquid thanks to a unique micro-channelled fibrous structure — outperforming bentonite, diatomite, and zeolite in most applications.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">&#128293;</div>
          <h3>Thermal Stability</h3>
          <p>Retains structural integrity up to 800°C and functional properties up to 250°C, making it ideal for high-temperature drilling, fireproofing, and refractory applications.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">&#129516;</div>
          <h3>Chemical Inertness</h3>
          <p>Non-reactive with most acids, alkalis, and solvents. Safe for pharmaceutical excipients, food-contact applications, and sensitive chemical processes.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">&#127758;</div>
          <h3>100% Natural</h3>
          <p>Mined and processed without synthetic additives. Fully biodegradable, non-toxic, and environmentally safe — supporting the global shift toward sustainable industrial materials.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="apps-cta">
    <div class="container">
      <h2>Don't See <span>Your Application</span>?</h2>
      <p>Our technical team can develop custom sepiolite grades tailored to your specific industrial requirements. Let's explore the possibilities together.</p>
      <div class="btn-group">
        <a href="/#contact" class="btn btn-primary">Contact Technical Sales</a>
        <a href="../products/" class="btn btn-outline-dark" style="border-color:rgba(255,255,255,0.4);color:#fff;">View All Products</a>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  

  <!-- ===== SCRIPTS ===== -->
</Layout>

<style is:global>
/* ===== HERO ===== */
    .apps-hero {
      position: relative;
      padding: 6rem 0 5rem;
      background: linear-gradient(135deg, var(--earth) 0%, var(--earth-mid) 50%, var(--earth-soft) 100%);
      overflow: hidden;
    }
    .apps-hero::before {
      content: '';
      position: absolute; inset: 0;
      background: url('/images/mine/mine-aerial-02.webp') center/cover no-repeat;
      opacity: 0.18;
    }
    .apps-hero .container { position: relative; z-index: 2; text-align: center; }
    .apps-hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      color: var(--white);
      margin-bottom: 1.25rem;
      line-height: 1.12;
    }
    .apps-hero h1 span { color: var(--gold); }
    .apps-hero p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.75);
      max-width: 680px;
      margin: 0 auto 2rem;
      line-height: 1.7;
    }
    .hero-stats {
      display: flex; justify-content: center; gap: 3rem; margin-top: 2.5rem; flex-wrap: wrap;
    }
    .hero-stat { text-align: center; }
    .hero-stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2.4rem; font-weight: 800; color: var(--gold); line-height: 1;
    }
    .hero-stat-label { font-size: 0.78rem; color: rgba(255,255,255,0.6); margin-top: 0.35rem; letter-spacing: 0.04em; }

    /* ===== APPLICATION GRID ===== */
    .apps-section { padding: 5rem 0 6rem; background: var(--white); }
    .apps-section .section-header { text-align: center; margin-bottom: 3.5rem; }
    .apps-section .section-header p { font-size: 1rem; color: var(--text-light); max-width: 640px; margin: 0 auto; line-height: 1.7; }
    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .app-card {
      background: var(--white);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--cream-dark);
      transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
      display: flex; flex-direction: column;
    }
    .app-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: var(--gold); }

    .app-card-header {
      position: relative;
      padding: 2.25rem 1.75rem 1.5rem;
      background: linear-gradient(135deg, var(--earth) 0%, var(--earth-soft) 100%);
      min-height: 140px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }
    .app-card-icon {
      width: 52px; height: 52px;
      background: rgba(201,146,42,0.15);
      border: 1px solid rgba(201,146,42,0.3);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.5rem;
    }
    .app-card-header h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--white);
      line-height: 1.25;
    }
    .app-card-tag {
      position: absolute; top: 1rem; right: 1rem;
      background: rgba(201,146,42,0.2);
      color: var(--gold-light);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.3rem 0.7rem;
      border-radius: 4px;
      backdrop-filter: blur(6px);
    }

    .app-card-body { padding: 1.75rem; flex: 1; display: flex; flex-direction: column; }
    .app-card-body p { font-size: 0.88rem; line-height: 1.7; color: var(--text-light); flex: 1; margin-bottom: 1.25rem; }
    .app-highlights { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem; }
    .app-highlight {
      font-size: 0.72rem; font-weight: 600;
      color: var(--gold-dark);
      background: rgba(201,146,42,0.1);
      padding: 0.3rem 0.7rem;
      border-radius: 4px;
      letter-spacing: 0.02em;
    }
    .app-link {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.85rem; font-weight: 600; color: var(--gold);
      transition: color 0.25s ease, gap 0.25s ease; margin-top: auto;
    }
    .app-link svg { width: 16px; height: 16px; }
    .app-link:hover { color: var(--gold-dark); gap: 0.75rem; }

    /* ===== WHY SEPIOLITE SECTION ===== */
    .why-section { padding: 5rem 0; background: var(--cream); }
    .why-section .section-header { text-align: center; margin-bottom: 3.5rem; }
    .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
    .why-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 2rem 1.5rem;
      text-align: center;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--cream-dark);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .why-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
    .why-icon {
      width: 56px; height: 56px;
      background: rgba(201,146,42,0.12);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.25rem;
      font-size: 1.4rem;
    }
    .why-card h3 { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--earth); margin-bottom: 0.75rem; }
    .why-card p { font-size: 0.85rem; color: var(--text-light); line-height: 1.65; }

    /* ===== CTA SECTION ===== */
    .apps-cta {
      padding: 5rem 0;
      background: linear-gradient(135deg, var(--earth) 0%, var(--earth-soft) 100%);
      text-align: center;
    }
    .apps-cta h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--white); margin-bottom: 1rem;
    }
    .apps-cta h2 span { color: var(--gold); }
    .apps-cta p {
      font-size: 1rem; color: rgba(255,255,255,0.7);
      max-width: 560px; margin: 0 auto 2rem; line-height: 1.7;
    }
    .apps-cta .btn-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .why-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .why-grid { grid-template-columns: 1fr; }
      .apps-hero { padding: 4rem 0 3.5rem; }
      .hero-stats { gap: 2rem; }
      .hero-stat-num { font-size: 1.8rem; }
    }
</style>
