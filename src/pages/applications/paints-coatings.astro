---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://sepiolitemine.com/"},{"@type":"ListItem","position":2,"name":"Applications","item":"https://sepiolitemine.com/applications/"},{"@type":"ListItem","position":3,"name":"Paints &amp; Coatings","item":"https://sepiolitemine.com/applications/paints-coatings/"}]},
  {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"At what stage should I add sepiolite to my paint formulation?","acceptedAnswer":{"@type":"Answer","text":"For best results, add sepiolite during the grinding/dispersion stage with pigments at high shear. If adding at let-down, pre-disperse in a small volume of the binder or use our pre-dispersed paste to ensure full delamination of the needle bundles."}},{"@type":"Question","name":"Will sepiolite affect the colour of my paint?","acceptedAnswer":{"@type":"Answer","text":"Sepiolite is an off-white to light cream mineral. At typical dosages (0.5–3%), colour impact is minimal in tinted formulations. In pure white paints, it may cause a very slight warm shift that can be compensated with minor tinting adjustments."}},{"@type":"Question","name":"How does sepiolite compare to fumed silica for rheology control?","acceptedAnswer":{"@type":"Answer","text":"Both create thixotropic networks, but through different mechanisms. Fumed silica works through hydrogen bonding (best in polar systems), while sepiolite works through physical entanglement (effective in all systems). Sepiolite is typically 40–60% cheaper per unit of thixotropic effect."}},{"@type":"Question","name":"Can I use sepiolite in UV-curable coatings?","acceptedAnswer":{"@type":"Answer","text":"Yes. Sepiolite is transparent to UV radiation and does not inhibit photoinitiator activity. It provides effective anti-settling and sag resistance in UV-curable formulations including inks, overprint varnishes, and wood coatings."}},{"@type":"Question","name":"What is the minimum order for technical-grade powder?","acceptedAnswer":{"@type":"Answer","text":"Minimum order is 1 pallet (40 × 25kg bags = 1 tonne). For pre-dispersed paste, minimum is 500kg. Sample quantities of 5–10kg are available for laboratory evaluation."}}]}
];
---

<Layout
  title="Sepiolite for Paints &amp; Coatings – Applications"
  description="Sepiolite rheology modifier for paints, coatings, and adhesives. Anti-sag, anti-settling, matting agent with excellent thixotropic properties."
  locale="en"
  alternates={{ en: "/applications/paints-coatings/", tr: "/tr/applications/boya-kaplama/" }}
  schemaJson={schemaJson}
>
<div class="breadcrumb-bar"><div class="container"><div class="breadcrumb">
    <a href="../../">Home</a><span class="sep">›</span>
    <a href="../">Applications</a><span class="sep">›</span>
    <span class="current">Paints &amp; Coatings</span>
  </div></div></div>

  <section class="app-hero">
    <div class="container">
      <span class="section-tag">Coatings</span>
      <h1>Sepiolite for <span>Paints &amp; Coatings</span></h1>
      <p class="hero-subtitle">Rheology Control &amp; Anti-Sagging for Premium Finishes</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-num">0.5–3%</div>
          <div class="hero-stat-label">Typical Dosage</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">95%</div>
          <div class="hero-stat-label">Anti-Settle Effect</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">10x</div>
          <div class="hero-stat-label">Thixotropic Index</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">Zero</div>
          <div class="hero-stat-label">VOC Contribution</div>
        </div>
      </div>
    </div>
  </section>

  <section class="intro-section">
    <div class="container">
      <p class="intro-text">In the paints and coatings industry, sepiolite serves as a multifunctional additive that controls rheology, prevents settling, provides anti-sag behaviour, and creates matting effects. Its unique needle-like crystal structure builds a three-dimensional network in liquid systems that is easily broken by stirring (shear-thinning) but rapidly rebuilds at rest (thixotropy) — giving formulators precise control over application and appearance properties.</p>
    </div>
  </section>

  <section class="benefits-section">
    <div class="container">
      <div style="text-align:center;margin-bottom:1rem">
        <span class="section-tag">Key Benefits</span>
        <h2 class="section-title">Why Sepiolite for <span>Paints &amp; Coatings</span></h2>
      </div>
      <div class="benefits-grid">
      <div class="benefit-card reveal">
        <div class="benefit-icon">🔄</div>
        <h3>Thixotropic Rheology Control</h3>
        <p>Sepiolite needles interlock to form a gel network at rest, preventing pigment settling and drip. Under shear (brushing, rolling, spraying), the network breaks apart for smooth application. Recovery is rapid — within seconds the gel reforms, preventing runs and sags.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">⬇️</div>
        <h3>Anti-Settling Agent</h3>
        <p>Heavy pigments like titanium dioxide, zinc oxide, and iron oxides tend to settle during storage. Just 0.5–1% sepiolite by weight creates a permanent suspension network that keeps pigments uniformly dispersed throughout the shelf life of the product.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">🏗️</div>
        <h3>Anti-Sag Performance</h3>
        <p>On vertical surfaces, paints containing sepiolite resist sagging even at high film thicknesses. This allows single-coat coverage applications that would be impossible with conventional rheology modifiers, reducing labour time and material consumption.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">✨</div>
        <h3>Matting Effect</h3>
        <p>At dosages of 2–5%, sepiolite creates a natural matte finish by disrupting surface gloss through micro-roughness. Unlike silica matting agents, sepiolite provides simultaneous rheology control and matting in a single additive, simplifying formulations.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">🧪</div>
        <h3>Compatible with All Systems</h3>
        <p>Sepiolite works in water-based, solvent-borne, and high-solids coating systems. It is compatible with all common binder types (acrylics, alkyds, epoxies, polyurethanes) and does not interfere with colorants, biocides, or other functional additives.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">🌿</div>
        <h3>Zero VOC Contribution</h3>
        <p>As an inorganic mineral, sepiolite contributes zero volatile organic compounds to the formulation — supporting compliance with increasingly strict VOC regulations in the coatings industry worldwide.</p>
      </div>
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="container" style="text-align:center">
      <span class="section-tag">Our Process</span>
      <h2 class="section-title">From Mine to <span>Your Application</span></h2>
      <div class="process-steps">
        <div class="process-step reveal">
          <div class="process-num">01</div>
          <div class="process-content">
            <h3>Micronisation</h3>
            <p>Sepiolite is processed to ultra-fine particle size (&lt;10µm) through jet milling to ensure complete dispersion in liquid coating systems without visible texture.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">02</div>
          <div class="process-content">
            <h3>Surface Treatment (optional)</h3>
            <p>For solvent-borne systems, sepiolite can be surface-treated with organosilanes to improve compatibility and dispersion in non-polar media.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">03</div>
          <div class="process-content">
            <h3>Pre-Dispersion</h3>
            <p>For easier incorporation, we offer pre-dispersed sepiolite pastes (50% solids in water or solvent) that can be added directly to the grind or let-down stage.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">04</div>
          <div class="process-content">
            <h3>Technical Formulation</h3>
            <p>Our coatings laboratory develops application-specific formulations and provides detailed incorporation guidelines for each coating type.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">05</div>
          <div class="process-content">
            <h3>Quality &amp; Consistency</h3>
            <p>Particle size distribution, moisture, and rheological performance are tested on every batch to ensure batch-to-batch consistency in your production.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="specs-section">
    <div class="container" style="text-align:center">
      <span class="section-tag">Technical Data</span>
      <h2 class="section-title">Typical <span>Specifications</span></h2>
      <table class="specs-table">
        <thead><tr><th>Parameter</th><th>Value</th></tr></thead>
        <tbody>
          <tr><td>Particle Size (D50)</td><td>4–8 µm</td></tr>
          <tr><td>Moisture</td><td>&lt; 8%</td></tr>
          <tr><td>pH (10% slurry)</td><td>8.0–9.5</td></tr>
          <tr><td>Bulk Density</td><td>0.15–0.25 g/cm³</td></tr>
          <tr><td>Oil Absorption</td><td>140–180 g/100g</td></tr>
          <tr><td>Typical Dosage</td><td>0.5–5% on total formulation</td></tr>
          <tr><td>Packaging</td><td>25kg bags / 500kg big bags</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="faq-section">
    <div class="container" style="text-align:center">
      <span class="section-tag">FAQ</span>
      <h2 class="section-title">Frequently Asked <span>Questions</span></h2>
      <div class="faq-list">
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>At what stage should I add sepiolite to my paint formulation?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>For best results, add sepiolite during the grinding/dispersion stage with pigments at high shear. If adding at let-down, pre-disperse in a small volume of the binder or use our pre-dispersed paste to ensure full delamination of the needle bundles.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>Will sepiolite affect the colour of my paint?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Sepiolite is an off-white to light cream mineral. At typical dosages (0.5–3%), colour impact is minimal in tinted formulations. In pure white paints, it may cause a very slight warm shift that can be compensated with minor tinting adjustments.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>How does sepiolite compare to fumed silica for rheology control?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Both create thixotropic networks, but through different mechanisms. Fumed silica works through hydrogen bonding (best in polar systems), while sepiolite works through physical entanglement (effective in all systems). Sepiolite is typically 40–60% cheaper per unit of thixotropic effect.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>Can I use sepiolite in UV-curable coatings?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Yes. Sepiolite is transparent to UV radiation and does not inhibit photoinitiator activity. It provides effective anti-settling and sag resistance in UV-curable formulations including inks, overprint varnishes, and wood coatings.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>What is the minimum order for technical-grade powder?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Minimum order is 1 pallet (40 × 25kg bags = 1 tonne). For pre-dispersed paste, minimum is 500kg. Sample quantities of 5–10kg are available for laboratory evaluation.</p></div>
      </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Explore <span>Sepiolite</span> for Your Application?</h2>
      <p>Our technical team provides samples, specifications, and formulation guidance tailored to your industry needs.</p>
      <div class="btn-group">
        <a href="../../#contact" class="btn btn-primary">Request Samples</a>
        <a href="../" class="btn btn-outline-dark" style="border-color:rgba(255,255,255,0.4);color:#fff;">All Applications</a>
      </div>
    </div>
  </section>

  <section class="related-section">
    <div class="container">
      <div style="text-align:center;margin-bottom:1rem">
        <span class="section-tag">Explore More</span>
        <h2 class="section-title">Related <span>Products</span></h2>
      </div>
      <div class="related-grid">
      <a href="../../products/milled-sepiolite-powder/" class="related-card reveal">
        <div class="related-img"><img width="1200" height="896" src="/images/products/product-milled-powder.webp" alt="Milled Sepiolite Powder" loading="lazy"/></div>
        <h4>Milled Sepiolite Powder</h4>
        <span class="related-link">View Product →</span>
      </a>
      <a href="../../products/raw-sepiolite-ore/" class="related-card reveal">
        <div class="related-img"><img width="506" height="900" src="/images/products/product-raw-ore.webp" alt="Raw Sepiolite Ore" loading="lazy"/></div>
        <h4>Raw Sepiolite Ore</h4>
        <span class="related-link">View Product →</span>
      </a>
      <a href="../../products/granulated-sepiolite/" class="related-card reveal">
        <div class="related-img"><img width="675" height="900" src="/images/products/product-granulated.webp" alt="Granulated Sepiolite" loading="lazy"/></div>
        <h4>Granulated Sepiolite</h4>
        <span class="related-link">View Product →</span>
      </a>
      </div>
      <div style="text-align:center;margin-top:3.5rem">
        <h3 style="font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--earth);margin-bottom:1.5rem">Related <span style="color:var(--gold)">Applications</span></h3>
      </div>
      <div class="related-grid" style="grid-template-columns:repeat(2,1fr);max-width:600px;margin:0 auto">
      <a href="../construction/" class="related-app-card reveal">
        <div class="related-app-icon">🏗️</div>
        <h4>Construction</h4>
        <span class="related-link">Learn More →</span>
      </a>
      <a href="../pharma-cosmetics/" class="related-app-card reveal">
        <div class="related-app-icon">💊</div>
        <h4>Pharma &amp; Cosmetics</h4>
        <span class="related-link">Learn More →</span>
      </a>
      </div>
    </div>
  </section>

  
  
  <script>
  (function(){'use strict';
    var nb=document.getElementById('navbar');if(nb)window.addEventListener('scroll',function(){nb.classList.toggle('scrolled',window.scrollY>30)});
    var hb=document.getElementById('hamburger'),mm=document.getElementById('mobileMenu');
    if(hb&&mm)hb.addEventListener('click',function(){var e=hb.getAttribute('aria-expanded')==='true';hb.setAttribute('aria-expanded',String(!e));mm.classList.toggle('open')});
    var ro=new IntersectionObserver(function(ent){ent.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');ro.unobserve(e.target)}})},{threshold:0.15});
    document.querySelectorAll('.reveal').forEach(function(el){ro.observe(el)});
  })();
  function toggleFaq(btn){var a=btn.nextElementSibling;var exp=btn.getAttribute('aria-expanded')==='true';btn.setAttribute('aria-expanded',String(!exp));a.style.maxHeight=exp?'0':a.scrollHeight+'px'}
  </script>
</Layout>

<style>
.app-hero{position:relative;padding:5rem 0 4.5rem;background:linear-gradient(135deg,var(--earth) 0%,var(--earth-mid) 50%,var(--earth-soft) 100%);overflow:hidden}
    .app-hero::before{content:'';position:absolute;inset:0;background:url('/images/mine/mine-landscape-06.webp') center/cover no-repeat;opacity:0.15}
    .app-hero .container{position:relative;z-index:2}
    .app-hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.5rem);color:var(--white);margin-bottom:0.75rem;line-height:1.12}
    .app-hero h1 span{color:var(--gold)}
    .app-hero .hero-subtitle{font-size:1.15rem;color:rgba(255,255,255,0.7);max-width:640px;line-height:1.7;margin-bottom:2rem}
    .hero-stats{display:flex;gap:3rem;flex-wrap:wrap;margin-top:2rem}
    .hero-stat{text-align:center}.hero-stat-num{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:800;color:var(--gold);line-height:1}.hero-stat-label{font-size:0.75rem;color:rgba(255,255,255,0.55);margin-top:0.3rem;letter-spacing:0.04em}
    .intro-section{padding:4.5rem 0;background:var(--white)}
    .intro-text{font-size:1.05rem;line-height:1.85;color:var(--text-mid);max-width:860px;margin:0 auto;text-align:center}
    .benefits-section{padding:5rem 0;background:var(--cream)}
    .benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3rem}
    .benefit-card{background:var(--white);border-radius:var(--radius-lg);padding:2.25rem;border:1px solid var(--cream-dark);transition:transform 0.4s ease,box-shadow 0.4s ease}
    .benefit-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--gold)}
    .benefit-icon{font-size:2.2rem;margin-bottom:1.25rem}
    .benefit-card h3{font-family:'Playfair Display',serif;font-size:1.15rem;color:var(--earth);margin-bottom:0.75rem}
    .benefit-card p{font-size:0.87rem;line-height:1.75;color:var(--text-light)}
    .process-section{padding:5rem 0;background:var(--white)}
    .process-steps{max-width:780px;margin:2.5rem auto 0;display:flex;flex-direction:column;gap:0}
    .process-step{display:flex;gap:1.75rem;padding:1.75rem 0;border-bottom:1px solid var(--cream-dark)}
    .process-step:last-child{border-bottom:none}
    .process-num{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:800;color:var(--gold);opacity:0.4;line-height:1;flex-shrink:0;width:40px}
    .process-content h3{font-size:1rem;font-weight:700;color:var(--earth);margin-bottom:0.4rem}
    .process-content p{font-size:0.88rem;line-height:1.75;color:var(--text-light)}
    .specs-section{padding:5rem 0;background:var(--cream)}
    .specs-table{max-width:700px;margin:2rem auto 0;border-collapse:collapse;width:100%}
    .specs-table th,.specs-table td{padding:0.85rem 1.25rem;text-align:left;border-bottom:1px solid var(--cream-dark);font-size:0.88rem}
    .specs-table th{background:var(--earth);color:var(--gold);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-size:0.75rem}
    .specs-table td:first-child{font-weight:600;color:var(--earth);width:45%}
    .specs-table td:last-child{color:var(--text-mid)}
    .specs-table tr:hover td{background:rgba(201,146,42,0.05)}
    .faq-section{padding:5rem 0;background:var(--white)}
    .faq-list{max-width:780px;margin:2rem auto 0;display:flex;flex-direction:column;gap:0.75rem}
    .faq-item{background:var(--cream);border-radius:var(--radius);overflow:hidden;border:1px solid var(--cream-dark);transition:border-color 0.3s}
    .faq-item:hover{border-color:var(--gold)}
    .faq-q{display:flex;align-items:center;justify-content:space-between;width:100%;padding:1.15rem 1.5rem;font-size:0.92rem;font-weight:600;color:var(--earth);text-align:left;gap:1rem;background:none;border:none;cursor:pointer;font-family:inherit}
    .faq-q svg{flex-shrink:0;transition:transform 0.3s ease;color:var(--gold)}
    .faq-q[aria-expanded="true"] svg{transform:rotate(180deg)}
    .faq-a{max-height:0;overflow:hidden;transition:max-height 0.4s ease,padding 0.4s ease}
    .faq-a p{padding:0 1.5rem 1.25rem;font-size:0.88rem;line-height:1.75;color:var(--text-light)}
    .related-section{padding:5rem 0;background:var(--cream)}
    .related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:2.5rem}
    .related-card{background:var(--white);border-radius:var(--radius);overflow:hidden;border:1px solid var(--cream-dark);transition:transform 0.35s,box-shadow 0.35s;display:flex;flex-direction:column}
    .related-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);border-color:var(--gold)}
    .related-img{height:160px;overflow:hidden}.related-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s}.related-card:hover .related-img img{transform:scale(1.06)}
    .related-card h4{padding:1.25rem 1.25rem 0.35rem;font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--earth)}
    .related-link{padding:0 1.25rem 1.25rem;font-size:0.82rem;font-weight:600;color:var(--gold);display:block;margin-top:auto}
    .related-app-card{background:var(--white);border-radius:var(--radius);padding:2rem;border:1px solid var(--cream-dark);transition:transform 0.35s,box-shadow 0.35s;display:flex;flex-direction:column;align-items:center;text-align:center}
    .related-app-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);border-color:var(--gold)}
    .related-app-icon{font-size:2.5rem;margin-bottom:1rem}
    .related-app-card h4{font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--earth);margin-bottom:0.5rem}
    .cta-section{padding:5rem 0;background:linear-gradient(135deg,var(--earth) 0%,var(--earth-soft) 100%);text-align:center}
    .cta-section h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);color:var(--white);margin-bottom:1rem}.cta-section h2 span{color:var(--gold)}
    .cta-section p{font-size:1rem;color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto 2rem;line-height:1.7}
    .btn-group{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    @media(max-width:1024px){.benefits-grid,.related-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:768px){.benefits-grid,.related-grid{grid-template-columns:1fr}.hero-stats{gap:2rem}.process-step{flex-direction:column;gap:0.5rem}}
</style>
