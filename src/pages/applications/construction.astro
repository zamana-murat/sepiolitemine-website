---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://sepiolitemine.com/"},{"@type":"ListItem","position":2,"name":"Applications","item":"https://sepiolitemine.com/applications/"},{"@type":"ListItem","position":3,"name":"Construction","item":"https://sepiolitemine.com/applications/construction/"}]},
  {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much sepiolite should I add to lime mortar?","acceptedAnswer":{"@type":"Answer","text":"Typical dosage is 3–8% by weight of binder (lime). Start at 5% for a standard improving mix. Higher ratios increase thixotropy and sag resistance but may reduce compressive strength slightly. Our technical team can optimise the mix for your specific application."}},{"@type":"Question","name":"Is sepiolite suitable for external insulation systems (ETICS)?","acceptedAnswer":{"@type":"Answer","text":"Yes. Sepiolite-based insulating renders and boards are used in external thermal insulation composite systems. The mineral&#x27;s fire resistance (A1) is a significant advantage over EPS-based systems, particularly in high-rise buildings where fire regulations restrict combustible insulation."}},{"@type":"Question","name":"Can sepiolite replace asbestos in construction products?","acceptedAnswer":{"@type":"Answer","text":"Sepiolite has been successfully used as an asbestos replacement in many construction applications since the 1980s. Its fibrous structure provides similar reinforcement and thermal properties, but sepiolite fibres are non-carcinogenic and completely safe for human health."}},{"@type":"Question","name":"What is the difference between construction-grade and drilling-grade sepiolite?","acceptedAnswer":{"@type":"Answer","text":"Construction grade is optimised for fibre length preservation and low dust, providing reinforcement and workability in solid products. Drilling grade is optimised for maximum viscosity yield in liquid suspension. Different processing parameters produce different performance profiles."}},{"@type":"Question","name":"Do you provide technical support for product development?","acceptedAnswer":{"@type":"Answer","text":"Yes. Our technical team has extensive experience formulating sepiolite into construction products. We provide mix design guidance, laboratory testing, and can arrange pilot production trials. We work with manufacturers across Europe and the Middle East."}}]}
];
---

<Layout
  title="Sepiolite for Construction – Applications"
  description="Sepiolite improves construction materials with low thermal conductivity, fire resistance, and enhanced workability in mortars, plasters, and insulating products."
  locale="en"
  alternates={{ en: "/applications/construction/", tr: "/tr/applications/insaat/" }}
  schemaJson={schemaJson}
>
<div class="breadcrumb-bar"><div class="container"><div class="breadcrumb">
    <a href="../../">Home</a><span class="sep">›</span>
    <a href="../">Applications</a><span class="sep">›</span>
    <span class="current">Construction</span>
  </div></div></div>

  <section class="app-hero">
    <div class="container">
      <span class="section-tag">Construction</span>
      <h1>Sepiolite for <span>Construction</span></h1>
      <p class="hero-subtitle">Natural Insulation, Fireproofing &amp; Workability Enhancement</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-num">0.06</div>
          <div class="hero-stat-label">W/m·K Conductivity</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">1000°C</div>
          <div class="hero-stat-label">Fire Resistance</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">30%</div>
          <div class="hero-stat-label">Better Workability</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">0</div>
          <div class="hero-stat-label">Toxic Emissions</div>
        </div>
      </div>
    </div>
  </section>

  <section class="intro-section">
    <div class="container">
      <p class="intro-text">Sepiolite brings unique advantages to the construction industry through its extremely low thermal conductivity, inherent fire resistance, and remarkable ability to improve the workability of cement, lime, and gypsum-based products. From insulating boards to fireproof coatings to heritage restoration mortars, sepiolite enhances building material performance while maintaining a fully natural, non-toxic composition.</p>
    </div>
  </section>

  <section class="benefits-section">
    <div class="container">
      <div style="text-align:center;margin-bottom:1rem">
        <span class="section-tag">Key Benefits</span>
        <h2 class="section-title">Why Sepiolite for <span>Construction</span></h2>
      </div>
      <div class="benefits-grid">
      <div class="benefit-card reveal">
        <div class="benefit-icon">🌡️</div>
        <h3>Thermal Insulation</h3>
        <p>With a thermal conductivity of just 0.06 W/m·K, sepiolite is one of the most effective natural insulating minerals. Mixed into boards, panels, and coatings, it creates building envelope solutions that significantly reduce heating and cooling energy consumption.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">🔥</div>
        <h3>Fire Resistance</h3>
        <p>Sepiolite is inherently non-combustible and retains structural integrity at temperatures exceeding 1000°C. It is classified A1 (non-combustible) under EN 13501-1 and is used in passive fire protection systems, fireproof coatings, and fire-rated partition boards.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">🏠</div>
        <h3>Mortar &amp; Plaster Improvement</h3>
        <p>Adding 3–8% sepiolite to cement or lime mortars dramatically improves workability, open time, and sag resistance. The fibrous particles create a thixotropic network that allows easy spreading while preventing slump on vertical surfaces.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">🏛️</div>
        <h3>Heritage &amp; Restoration</h3>
        <p>Sepiolite is the material of choice for restoration of historic lime-based structures. It improves the working properties of traditional hydraulic lime mortars without introducing modern chemicals, maintaining breathability and compatibility with ancient stonework.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">⚡</div>
        <h3>Lightweight Precast Elements</h3>
        <p>Sepiolite-filled concrete and gypsum products are 20–30% lighter than conventional equivalents at comparable strength. This reduces structural load, transportation costs, and installation labour while improving thermal and acoustic performance.</p>
      </div>
      <div class="benefit-card reveal">
        <div class="benefit-icon">🌿</div>
        <h3>Non-Toxic &amp; Sustainable</h3>
        <p>Unlike many synthetic insulation materials (XPS, EPS, spray foam), sepiolite contains no volatile organic compounds, no CFCs, no HFCs, and produces zero toxic emissions during fire. It is a 100% natural mineral that can be safely disposed of at end-of-life.</p>
      </div>
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="container" style="text-align:center">
      <span class="section-tag">Our Process</span>
      <h2 class="section-title">From Mine to <span>Your Application</span></h2>
      <div class="process-steps">
        <div class="process-step reveal">
          <div class="process-num">01</div>
          <div class="process-content">
            <h3>Grade Selection</h3>
            <p>Construction-grade sepiolite requires specific fibre length and purity characteristics. We select ore from deposits that produce optimal fibre-to-particle ratios for building material applications.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">02</div>
          <div class="process-content">
            <h3>Controlled Processing</h3>
            <p>The ore is carefully dried and processed to maintain the fibrous structure that provides reinforcement and thixotropy. Aggressive milling would destroy these properties.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">03</div>
          <div class="process-content">
            <h3>Custom Particle Engineering</h3>
            <p>We produce multiple particle grades: fine powder (&lt;75µm) for coatings and mortars, medium grades (75–500µm) for board manufacture, and coarse fibre (1–3mm) for lightweight concrete.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">04</div>
          <div class="process-content">
            <h3>Application Testing</h3>
            <p>Our technical lab tests each batch in actual mortar, plaster, and board formulations. We provide mix design guidance and can develop custom specifications for specific applications.</p>
          </div>
        </div>
        <div class="process-step reveal">
          <div class="process-num">05</div>
          <div class="process-content">
            <h3>Delivery &amp; Support</h3>
            <p>Available in 25kg bags or 1-tonne big bags. Our technical team provides on-site trials and mix design support for new product development.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="specs-section">
    <div class="container" style="text-align:center">
      <span class="section-tag">Technical Data</span>
      <h2 class="section-title">Typical <span>Specifications</span></h2>
      <table class="specs-table">
        <thead><tr><th>Parameter</th><th>Value</th></tr></thead>
        <tbody>
          <tr><td>Thermal Conductivity</td><td>0.06 W/m·K (loose fill)</td></tr>
          <tr><td>Fire Classification</td><td>A1 (non-combustible, EN 13501-1)</td></tr>
          <tr><td>Fibre Length</td><td>1–10 µm (mean)</td></tr>
          <tr><td>Particle Sizes</td><td>&lt;75µm / 75–500µm / 1–3mm</td></tr>
          <tr><td>Dosage in Mortar</td><td>3–8% by weight of binder</td></tr>
          <tr><td>pH</td><td>7.5–8.5</td></tr>
          <tr><td>Packaging</td><td>25kg bags / 1t big bags</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="faq-section">
    <div class="container" style="text-align:center">
      <span class="section-tag">FAQ</span>
      <h2 class="section-title">Frequently Asked <span>Questions</span></h2>
      <div class="faq-list">
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>How much sepiolite should I add to lime mortar?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Typical dosage is 3–8% by weight of binder (lime). Start at 5% for a standard improving mix. Higher ratios increase thixotropy and sag resistance but may reduce compressive strength slightly. Our technical team can optimise the mix for your specific application.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>Is sepiolite suitable for external insulation systems (ETICS)?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Yes. Sepiolite-based insulating renders and boards are used in external thermal insulation composite systems. The mineral&#x27;s fire resistance (A1) is a significant advantage over EPS-based systems, particularly in high-rise buildings where fire regulations restrict combustible insulation.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>Can sepiolite replace asbestos in construction products?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Sepiolite has been successfully used as an asbestos replacement in many construction applications since the 1980s. Its fibrous structure provides similar reinforcement and thermal properties, but sepiolite fibres are non-carcinogenic and completely safe for human health.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>What is the difference between construction-grade and drilling-grade sepiolite?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Construction grade is optimised for fibre length preservation and low dust, providing reinforcement and workability in solid products. Drilling grade is optimised for maximum viscosity yield in liquid suspension. Different processing parameters produce different performance profiles.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false">
          <span>Do you provide technical support for product development?</span>
          <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="faq-a"><p>Yes. Our technical team has extensive experience formulating sepiolite into construction products. We provide mix design guidance, laboratory testing, and can arrange pilot production trials. We work with manufacturers across Europe and the Middle East.</p></div>
      </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Explore <span>Sepiolite</span> for Your Application?</h2>
      <p>Our technical team provides samples, specifications, and formulation guidance tailored to your industry needs.</p>
      <div class="btn-group">
        <a href="../../#contact" class="btn btn-primary">Request Samples</a>
        <a href="../" class="btn btn-outline-dark" style="border-color:rgba(255,255,255,0.4);color:#fff;">All Applications</a>
      </div>
    </div>
  </section>

  <section class="related-section">
    <div class="container">
      <div style="text-align:center;margin-bottom:1rem">
        <span class="section-tag">Explore More</span>
        <h2 class="section-title">Related <span>Products</span></h2>
      </div>
      <div class="related-grid">
      <a href="../../products/construction-insulation-grade/" class="related-card reveal">
        <div class="related-img"><img width="1200" height="896" src="/images/products/product-construction.webp" alt="Construction &amp; Insulation Grade" loading="lazy"/></div>
        <h4>Construction &amp; Insulation Grade</h4>
        <span class="related-link">View Product →</span>
      </a>
      <a href="../../products/milled-sepiolite-powder/" class="related-card reveal">
        <div class="related-img"><img width="1200" height="896" src="/images/products/product-milled-powder.webp" alt="Milled Sepiolite Powder" loading="lazy"/></div>
        <h4>Milled Sepiolite Powder</h4>
        <span class="related-link">View Product →</span>
      </a>
      <a href="../../products/raw-sepiolite-ore/" class="related-card reveal">
        <div class="related-img"><img width="506" height="900" src="/images/products/product-raw-ore.webp" alt="Raw Sepiolite Ore" loading="lazy"/></div>
        <h4>Raw Sepiolite Ore</h4>
        <span class="related-link">View Product →</span>
      </a>
      </div>
      <div style="text-align:center;margin-top:3.5rem">
        <h3 style="font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--earth);margin-bottom:1.5rem">Related <span style="color:var(--gold)">Applications</span></h3>
      </div>
      <div class="related-grid" style="grid-template-columns:repeat(2,1fr);max-width:600px;margin:0 auto">
      <a href="../agriculture/" class="related-app-card reveal">
        <div class="related-app-icon">🌾</div>
        <h4>Agriculture</h4>
        <span class="related-link">Learn More →</span>
      </a>
      <a href="../paints-coatings/" class="related-app-card reveal">
        <div class="related-app-icon">🎨</div>
        <h4>Paints &amp; Coatings</h4>
        <span class="related-link">Learn More →</span>
      </a>
      </div>
    </div>
  </section>

  
  
  <script>
  (function(){'use strict';
    var nb=document.getElementById('navbar');if(nb)window.addEventListener('scroll',function(){nb.classList.toggle('scrolled',window.scrollY>30)});
    var hb=document.getElementById('hamburger'),mm=document.getElementById('mobileMenu');
    if(hb&&mm)hb.addEventListener('click',function(){var e=hb.getAttribute('aria-expanded')==='true';hb.setAttribute('aria-expanded',String(!e));mm.classList.toggle('open')});
    var ro=new IntersectionObserver(function(ent){ent.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');ro.unobserve(e.target)}})},{threshold:0.15});
    document.querySelectorAll('.reveal').forEach(function(el){ro.observe(el)});
  })();
  function toggleFaq(btn){var a=btn.nextElementSibling;var exp=btn.getAttribute('aria-expanded')==='true';btn.setAttribute('aria-expanded',String(!exp));a.style.maxHeight=exp?'0':a.scrollHeight+'px'}
  </script>
</Layout>

<style is:global>
.app-hero{position:relative;padding:5rem 0 4.5rem;background:linear-gradient(135deg,var(--earth) 0%,var(--earth-mid) 50%,var(--earth-soft) 100%);overflow:hidden}
    .app-hero::before{content:'';position:absolute;inset:0;background:url('/images/mine/mine-landscape-04.webp') center/cover no-repeat;opacity:0.15}
    .app-hero .container{position:relative;z-index:2}
    .app-hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.5rem);color:var(--white);margin-bottom:0.75rem;line-height:1.12}
    .app-hero h1 span{color:var(--gold)}
    .app-hero .hero-subtitle{font-size:1.15rem;color:rgba(255,255,255,0.7);max-width:640px;line-height:1.7;margin-bottom:2rem}
    .hero-stats{display:flex;gap:3rem;flex-wrap:wrap;margin-top:2rem}
    .hero-stat{text-align:center}.hero-stat-num{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:800;color:var(--gold);line-height:1}.hero-stat-label{font-size:0.75rem;color:rgba(255,255,255,0.55);margin-top:0.3rem;letter-spacing:0.04em}
    .intro-section{padding:4.5rem 0;background:var(--white)}
    .intro-text{font-size:1.05rem;line-height:1.85;color:var(--text-mid);max-width:860px;margin:0 auto;text-align:center}
    .benefits-section{padding:5rem 0;background:var(--cream)}
    .benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3rem}
    .benefit-card{background:var(--white);border-radius:var(--radius-lg);padding:2.25rem;border:1px solid var(--cream-dark);transition:transform 0.4s ease,box-shadow 0.4s ease}
    .benefit-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--gold)}
    .benefit-icon{font-size:2.2rem;margin-bottom:1.25rem}
    .benefit-card h3{font-family:'Playfair Display',serif;font-size:1.15rem;color:var(--earth);margin-bottom:0.75rem}
    .benefit-card p{font-size:0.87rem;line-height:1.75;color:var(--text-light)}
    .process-section{padding:5rem 0;background:var(--white)}
    .process-steps{max-width:780px;margin:2.5rem auto 0;display:flex;flex-direction:column;gap:0}
    .process-step{display:flex;gap:1.75rem;padding:1.75rem 0;border-bottom:1px solid var(--cream-dark)}
    .process-step:last-child{border-bottom:none}
    .process-num{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:800;color:var(--gold);opacity:0.4;line-height:1;flex-shrink:0;width:40px}
    .process-content h3{font-size:1rem;font-weight:700;color:var(--earth);margin-bottom:0.4rem}
    .process-content p{font-size:0.88rem;line-height:1.75;color:var(--text-light)}
    .specs-section{padding:5rem 0;background:var(--cream)}
    .specs-table{max-width:700px;margin:2rem auto 0;border-collapse:collapse;width:100%}
    .specs-table th,.specs-table td{padding:0.85rem 1.25rem;text-align:left;border-bottom:1px solid var(--cream-dark);font-size:0.88rem}
    .specs-table th{background:var(--earth);color:var(--gold);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-size:0.75rem}
    .specs-table td:first-child{font-weight:600;color:var(--earth);width:45%}
    .specs-table td:last-child{color:var(--text-mid)}
    .specs-table tr:hover td{background:rgba(201,146,42,0.05)}
    .faq-section{padding:5rem 0;background:var(--white)}
    .faq-list{max-width:780px;margin:2rem auto 0;display:flex;flex-direction:column;gap:0.75rem}
    .faq-item{background:var(--cream);border-radius:var(--radius);overflow:hidden;border:1px solid var(--cream-dark);transition:border-color 0.3s}
    .faq-item:hover{border-color:var(--gold)}
    .faq-q{display:flex;align-items:center;justify-content:space-between;width:100%;padding:1.15rem 1.5rem;font-size:0.92rem;font-weight:600;color:var(--earth);text-align:left;gap:1rem;background:none;border:none;cursor:pointer;font-family:inherit}
    .faq-q svg{flex-shrink:0;transition:transform 0.3s ease;color:var(--gold)}
    .faq-q[aria-expanded="true"] svg{transform:rotate(180deg)}
    .faq-a{max-height:0;overflow:hidden;transition:max-height 0.4s ease,padding 0.4s ease}
    .faq-a p{padding:0 1.5rem 1.25rem;font-size:0.88rem;line-height:1.75;color:var(--text-light)}
    .related-section{padding:5rem 0;background:var(--cream)}
    .related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:2.5rem}
    .related-card{background:var(--white);border-radius:var(--radius);overflow:hidden;border:1px solid var(--cream-dark);transition:transform 0.35s,box-shadow 0.35s;display:flex;flex-direction:column}
    .related-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);border-color:var(--gold)}
    .related-img{height:160px;overflow:hidden}.related-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s}.related-card:hover .related-img img{transform:scale(1.06)}
    .related-card h4{padding:1.25rem 1.25rem 0.35rem;font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--earth)}
    .related-link{padding:0 1.25rem 1.25rem;font-size:0.82rem;font-weight:600;color:var(--gold);display:block;margin-top:auto}
    .related-app-card{background:var(--white);border-radius:var(--radius);padding:2rem;border:1px solid var(--cream-dark);transition:transform 0.35s,box-shadow 0.35s;display:flex;flex-direction:column;align-items:center;text-align:center}
    .related-app-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);border-color:var(--gold)}
    .related-app-icon{font-size:2.5rem;margin-bottom:1rem}
    .related-app-card h4{font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--earth);margin-bottom:0.5rem}
    .cta-section{padding:5rem 0;background:linear-gradient(135deg,var(--earth) 0%,var(--earth-soft) 100%);text-align:center}
    .cta-section h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);color:var(--white);margin-bottom:1rem}.cta-section h2 span{color:var(--gold)}
    .cta-section p{font-size:1rem;color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto 2rem;line-height:1.7}
    .btn-group{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    @media(max-width:1024px){.benefits-grid,.related-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:768px){.benefits-grid,.related-grid{grid-template-columns:1fr}.hero-stats{gap:2rem}.process-step{flex-direction:column;gap:0.5rem}}
</style>
