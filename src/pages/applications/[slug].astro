---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import ApplicationHero from '@components/ApplicationHero.astro';
import ApplicationSections from '@components/ApplicationSections.astro';
import { BRAND } from '@config/brand';

export async function getStaticPaths() {
  const apps = await getCollection('applications', (a) => a.data.locale === 'en' && !a.data.draft);
  return apps.map((a) => ({
    params: { slug: a.slug },
    props: { entry: a },
  }));
}

const { entry } = Astro.props;
const { data: application } = entry;
const { Content } = await render(entry);

const recSlugs = application.recommendedProducts ?? [];
const recEntries = await Promise.all(
  recSlugs.map((s) => getEntry('products', s).catch(() => null))
);

const related = recEntries
  .filter((e): e is NonNullable<typeof e> => e != null)
  .map((e) => ({
    slug: e.slug,
    title: e.data.title,
    heroImage: e.data.heroImage,
    href: `/products/${e.slug}/`,
  }));

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const appUrl = `${siteUrl}/applications/${entry.slug}/`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Applications', item: `${siteUrl}/applications/` },
    { '@type': 'ListItem', position: 3, name: application.title, item: appUrl },
  ],
};

const faqSchema = application.faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: application.faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    }
  : null;

const schemaJson = [breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---

<Layout
  title={application.title}
  description={application.description}
  ogImage={`applications/${entry.slug}`}
  locale="en"
  alternates={{
    en: `/applications/${entry.slug}/`,
    tr: `/tr/applications/${application.altSlug}/`,
  }}
  schemaJson={schemaJson}
>
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li class="sep">›</li>
        <li><a href="/applications/">Applications</a></li>
        <li class="sep">›</li>
        <li aria-current="page">{application.title}</li>
      </ol>
    </div>
  </nav>

  <ApplicationHero application={application} locale="en" />
  <ApplicationSections application={application} locale="en" contactHref="/contact/" related={related}>
    <Content slot="body" />
  </ApplicationSections>
</Layout>

<style>
  .breadcrumb-bar {
    background: var(--c-cream);
    border-bottom: 1px solid var(--c-cream-dark);
    padding-block: var(--s-3);
  }

  .breadcrumb {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    font-size: 0.85rem;
    color: var(--c-text-muted);
  }

  .breadcrumb a {
    color: var(--c-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--c-gold-dark);
    text-decoration: underline;
  }

  .breadcrumb [aria-current='page'] {
    color: var(--c-earth);
    font-weight: 500;
  }

  .breadcrumb .sep {
    color: var(--c-stone);
  }
</style>
