---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://sepiolitemine.com/tr/" },
      { "@type": "ListItem", "position": 2, "name": "Küresel Pazarlar", "item": "https://sepiolitemine.com/tr/markets/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sepiolite Mine – Zamana",
    "url": "https://sepiolitemine.com",
    "description": "Türkiye'nin önde gelen sepiyolit üreticisi ve ihracatçısı, dünya genelinde 45'ten fazla ülkeye premium ham ve işlenmiş sepiyolit kademeleri sunmaktadır.",
    "areaServed": [
      { "@type": "Continent", "name": "Europe" },
      { "@type": "Continent", "name": "Asia" },
      { "@type": "Continent", "name": "Africa" },
      { "@type": "Continent", "name": "North America" },
      { "@type": "Continent", "name": "South America" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Sepiolite Mine hangi ülkelere ihracat yapmaktadır?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sepiolite Mine, Avrupa (Almanya, Hollanda, İspanya, İtalya, Fransa, Polonya, İngiltere), Orta Doğu ve Kuzey Afrika (BAE, Suudi Arabistan, Mısır, Fas), Asya Pasifik (Çin, Japonya, Güney Kore, Hindistan), Amerika (ABD, Kanada, Brezilya, Meksika) ve Sahra Altı Afrika (Güney Afrika, Nijerya, Kenya) dahil 45'ten fazla ülkeye ihracat yapmaktadır."
        }
      },
      {
        "@type": "Question",
        "name": "Sepiolite Mine hangi nakliye yöntemlerini sunmaktadır?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "20 ayak ve 40 ayak konteynerli sevkiyatlar, büyük siparişler için dökme gemi kiraları, büyük çuval (FIBC) seçenekleri ve paletlenmiş 25–50 kg çuvallar sunmaktayız. Tüm sevkiyatlar, tam dokümantasyon, analiz sertifikası ve gümrük takas desteğini kapsamaktadır."
        }
      },
      {
        "@type": "Question",
        "name": "Hangi Incoterms koşulları geçerlidir?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Incoterms 2020 kapsamında EXW, FCA, FOB, CFR, CIF ve DAP koşullarıyla işlem yapmaktayız. Türk limanı FOB en yaygın düzenlemedir; ancak lojistik ortaklarımız aracılığıyla rekabetçi navlun fiyatlarıyla dünyanın her limanına CIF/DAP olarak teslimat yapabiliriz."
        }
      },
      {
        "@type": "Question",
        "name": "İhracat için minimum sipariş miktarı nedir?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standart minimum sipariş, ürün yoğunluğuna bağlı olarak yaklaşık 18–22 ton kapasiteli bir 20 ayaklık konteynere karşılık gelmektedir. Yeni müşteriler veya deneme siparişleri için 5–10 ton gibi daha küçük miktarlara da uyum sağlayabiliriz. Dökme gemi siparişleri genellikle 3.000 tondan başlamaktadır."
        }
      },
      {
        "@type": "Question",
        "name": "Özel etiketleme hizmeti sunuyor musunuz?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Evet. Tüm ürün hatları için tam özel etiket ve beyaz etiket ambalajlama sunuyoruz. Özel çuval tasarımları (25 kg, 50 kg, büyük çuval), markalı paletler ve müşteriye özel dokümantasyon bunların arasındadır. Özel baskılı ambalaj için minimum sipariş bir 20 ayaklık konteynere karşılık gelmektedir."
        }
      }
    ]
  }
];
---

<Layout
  title="Küresel Pazarlar – 45+ Ülkeye Sepiyolit İhracatı"
  description="Sepiolite Mine, premium Türk sepiyolitini Avrupa, Orta Doğu, Asya Pasifik, Amerika ve Afrika dahil 45"
  locale="tr"
  alternates={{ en: "/markets/", tr: "/tr/markets/" }}
  schemaJson={schemaJson}
>
<!-- ===== HEADER ===== -->
  

  <!-- ===== BREADCRUMB ===== -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/tr/">Ana Sayfa</a>
        <span class="sep">&#8250;</span>
        <span class="current">Küresel Pazarlar</span>
      </div>
    </div>
  </div>

  <!-- ===== HERO ===== -->
  <section class="markets-hero">
    <div class="container">
      <span class="section-tag">Küresel Varlık</span>
      <h1>Türkiye'den <span>Dünyaya</span></h1>
      <p>Üç kıtanın kesişme noktasında stratejik konumuyla Sepiolite Mine, güvenilirlik, hız ve otuz yıllık itibarın simgesi olan kaliteyle 45'ten fazla ülkedeki sanayi ortaklarına premium Türk sepiyoliti ulaştırmaktadır.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-num">45+</div>
          <div class="hero-stat-label">Hizmet Verilen Ülke</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">300+</div>
          <div class="hero-stat-label">Aktif Müşteri</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">120K</div>
          <div class="hero-stat-label">MT Yıllık Kapasite</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">5</div>
          <div class="hero-stat-label">Kıta</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STRATEGIC POSITION ===== -->
  <section class="strategic-section">
    <div class="container">
      <div class="strategic-grid">
        <div class="strategic-text reveal">
          <span class="section-tag">Stratejik Avantaj</span>
          <h2 class="section-title">Türkiye: Dünyanın <span>Sepiyolit Başkenti</span></h2>
          <p class="section-subtitle">Türkiye, küresel sepiyolit rezervlerinin tahminen %70'ini barındırmakta ve bu rezervler Eskişehir-Sivrihisar havzasında yoğunlaşmaktadır. Madenlerimiz bu formasyonun tam merkezinde yer almakta; bize gezegenin en zengin yataklarına doğrudan erişim ve çok az rakibin eşleşebileceği bir lojistik avantaj sunmaktadır.</p>
          <div class="advantage-list">
            <div class="advantage-item">
              <div class="advantage-icon">&#9875;</div>
              <div>
                <h4>Limana Yakınlık</h4>
                <p>Gemlik limanına 200 km, Mersin'e 380 km mesafede - Türkiye'nin en işlek mineral ihracat terminalleri, tüm önemli güzergahlara günlük konteyner seferleriyle hizmet vermektedir.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon">&#128640;</div>
              <div>
                <h4>Hızlı Transit Süreleri</h4>
                <p>Avrupa limanlarına 7–10 gün, Amerika'ya 14–18 gün, Asya Pasifik'e 20–25 gün. Daha kısa transit süreleri, sizin için daha düşük stok maliyetleri anlamına gelir.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon">&#127981;</div>
              <div>
                <h4>Maden-Liman Entegrasyonu</h4>
                <p>İşleme tesisimiz maden sahasıyla aynı konumdadır. Cevher, çıkarılmadan ihracata hazır ürüne 48 saat içinde ulaşır; bu da temin sürelerini en aza indirir.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon">&#128200;</div>
              <div>
                <h4>Rekabetçi Fiyatlandırma</h4>
                <p>Aracı yok. Çıkarımdan FOB'a kadar her adımı biz yönetiyoruz; bu da tüm kademelerde tutarlı biçimde rekabetçi fiyatlandırmaya dönüşüyor.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="map-visual reveal">
          <div class="map-header">
            <div class="map-header-icon">&#127758;</div>
            <h3>Türkiye'den Başlıca Ticaret Güzergahları</h3>
          </div>
          <div class="trade-routes">
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Rotterdam, Hollanda</strong>
                <span>Avrupa'nın en büyük mineral merkezi</span>
              </div>
              <span class="route-time">7 gün</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Jebel Ali, BAE</strong>
                <span>Orta Doğu ve yeniden ihracat kapısı</span>
              </div>
              <span class="route-time">10 gün</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Şanghay, Çin</strong>
                <span>Asya Pasifik ana limanı</span>
              </div>
              <span class="route-time">22 gün</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>New York / Newark, ABD</strong>
                <span>Kuzey Amerika doğu yakası</span>
              </div>
              <span class="route-time">18 gün</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Kazablanka, Fas</strong>
                <span>Kuzey Afrika ve tarım koridoru</span>
              </div>
              <span class="route-time">5 gün</span>
            </div>
            <div class="trade-route">
              <span class="route-dot"></span>
              <div class="route-info">
                <strong>Santos, Brezilya</strong>
                <span>Güney Amerika ana limanı</span>
              </div>
              <span class="route-time">24 gün</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== REGIONAL MARKETS ===== -->
  <section class="regions-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Bölgesel Pazarlar</span>
        <h2 class="section-title">Sepiyolitlerimizin <span>Ulaştığı Yerler</span></h2>
        <p>Her bölgenin kendine özgü endüstriyel talepleri ve mevzuat gereksinimleri vardır. Ürün kalitelerimizi, ambalajlamamızı ve dokümantasyonumuzu her pazara mükemmel biçimde uyarlıyoruz.</p>
      </div>

      <div class="regions-grid">

        <!-- Avrupa -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127466;&#127482;</div>
            <h3>Avrupa</h3>
            <div class="region-subtitle">En büyük ihracat pazarımız</div>
          </div>
          <div class="region-card-body">
            <p>Avrupa, ihracatımızın %45'ini oluşturmakta; başta evcil hayvan bakımı (kedi kumu), boya ve kaplama ile inşaat yalıtımı sektörlerindeki güçlü talep bu payı desteklemektedir. Tüm ürün hatları için REACH uyumlu kaliteler mevcuttur.</p>
            <div class="region-countries">
              <span class="region-country">Almanya</span>
              <span class="region-country">Hollanda</span>
              <span class="region-country">İspanya</span>
              <span class="region-country">İtalya</span>
              <span class="region-country">Fransa</span>
              <span class="region-country">Polonya</span>
              <span class="region-country">İngiltere</span>
              <span class="region-country">Belçika</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">45%</div>
                <div class="region-stat-label">İhracat Payı</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">18</div>
                <div class="region-stat-label">Ülke</div>
              </div>
            </div>
          </div>
        </div>

        <!-- MENA -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127472;&#127484;</div>
            <h3>Orta Doğu &amp; Kuzey Afrika</h3>
            <div class="region-subtitle">En hızlı büyüyen koridor</div>
          </div>
          <div class="region-card-body">
            <p>Petrol ve gaz sondajı, inşaat patlaması ve büyüyen evcil hayvan bakımı pazarları, MENA'yı en hızlı büyüyen bölgemiz haline getirmektedir. Stratejik yakınlığımız sayesinde herhangi bir Körfez veya Kuzey Afrika limanına 5–10 günde teslimat yapılabilmektedir.</p>
            <div class="region-countries">
              <span class="region-country">BAE</span>
              <span class="region-country">Suudi Arabistan</span>
              <span class="region-country">Mısır</span>
              <span class="region-country">Fas</span>
              <span class="region-country">İsrail</span>
              <span class="region-country">Katar</span>
              <span class="region-country">Tunus</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">25%</div>
                <div class="region-stat-label">İhracat Payı</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">12</div>
                <div class="region-stat-label">Ülke</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Asia Pacific -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127471;&#127477;</div>
            <h3>Asya Pasifik</h3>
            <div class="region-subtitle">Yüksek büyümeli sanayi talebi</div>
          </div>
          <div class="region-card-body">
            <p>Hızla sanayileşen ekonomiler, sondaj kalitesi sepiyolit, kataliz destekleri ve tarımsal taşıyıcılara olan talebi artırmaktadır. Çin, Japonya ve Güney Kore, hacim bazında ilk üç Asya pazarımızdır.</p>
            <div class="region-countries">
              <span class="region-country">Çin</span>
              <span class="region-country">Japonya</span>
              <span class="region-country">Güney Kore</span>
              <span class="region-country">Hindistan</span>
              <span class="region-country">Tayland</span>
              <span class="region-country">Vietnam</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">15%</div>
                <div class="region-stat-label">İhracat Payı</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">9</div>
                <div class="region-stat-label">Ülke</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Americas -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127482;&#127480;</div>
            <h3>Amerika Kıtası</h3>
            <div class="region-subtitle">Premium kalite odağı</div>
          </div>
          <div class="region-card-body">
            <p>ABD ve Kanada yüksek saflıkta sondaj ve eczacılık kalitesi sepiyolit ithal ederken Brezilya ve Meksika, tarımsal ve çevresel uygulamalar için büyüyen pazarlar haline gelmektedir.</p>
            <div class="region-countries">
              <span class="region-country">ABD</span>
              <span class="region-country">Kanada</span>
              <span class="region-country">Brezilya</span>
              <span class="region-country">Meksika</span>
              <span class="region-country">Arjantin</span>
              <span class="region-country">Kolombiya</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">10%</div>
                <div class="region-stat-label">İhracat Payı</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">8</div>
                <div class="region-stat-label">Ülke</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sub-Saharan Africa -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127487;&#127462;</div>
            <h3>Sahra Altı Afrika</h3>
            <div class="region-subtitle">Gelişen fırsat</div>
          </div>
          <div class="region-card-body">
            <p>Toprak düzenleyicileri ve gübre taşıyıcılarına yönelik tarım kaynaklı talep, Doğu ve Güney Afrika'da yeni pazarlar açmaktadır. Çevre rehabilitasyon projeleri de ek fırsatlar yaratmaktadır.</p>
            <div class="region-countries">
              <span class="region-country">Güney Afrika</span>
              <span class="region-country">Nijerya</span>
              <span class="region-country">Kenya</span>
              <span class="region-country">Etiyopya</span>
              <span class="region-country">Tanzanya</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">5%</div>
                <div class="region-stat-label">İhracat Payı</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">7</div>
                <div class="region-stat-label">Ülke</div>
              </div>
            </div>
          </div>
        </div>

        <!-- CIS / Central Asia -->
        <div class="region-card reveal">
          <div class="region-card-header">
            <div class="region-card-flag">&#127479;&#127482;</div>
            <h3>BDT &amp; Orta Asya</h3>
            <div class="region-subtitle">Sondaj ve sanayi tabanı</div>
          </div>
          <div class="region-card-body">
            <p>Hazar bölgesi ve Orta Asya'nın petrol ve gazca zengin ekonomileri, sondaj kalitesi sepiyolit ve endüstriyel absorbanların tutarlı ithalatçılarıdır. Gürcistan üzerinden kara güzergahları maliyet etkin taşıma imkânı sunmaktadır.</p>
            <div class="region-countries">
              <span class="region-country">Rusya</span>
              <span class="region-country">Kazakistan</span>
              <span class="region-country">Azerbaycan</span>
              <span class="region-country">Gürcistan</span>
              <span class="region-country">Özbekistan</span>
            </div>
            <div class="region-stats">
              <div class="region-stat">
                <div class="region-stat-num">~5%</div>
                <div class="region-stat-label">İhracat Payı</div>
              </div>
              <div class="region-stat">
                <div class="region-stat-num">6</div>
                <div class="region-stat-label">Ülke</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== LOGISTICS & SHIPPING ===== -->
  <section class="logistics-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Lojistik</span>
        <h2 class="section-title">Uçtan Uca <span>Nakliye</span> Çözümleri</h2>
      </div>

      <div class="logistics-grid">
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128230;</div>
          <h3>Konteynerli Sevkiyat</h3>
          <p>Paletlenmiş çuvallar (25–50 kg) veya büyük çuvallar (1–1,5 MT) için standart 20 ayak ve 40 ayak konteynerler. Gemlik ve Mersin limanlarından tüm başlıca ticaret hatlarına haftalık seferler.</p>
        </div>
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128674;</div>
          <h3>Dökme Gemi</h3>
          <p>3.000 MT'den başlayan büyük siparişler için Handy-size'dan Panamax'a gemi kiralama. Varış noktasında silo deposu olan kedi kumu ve inşaat kalitesi alıcılar için idealdir.</p>
        </div>
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128203;</div>
          <h3>Dokümantasyon</h3>
          <p>Tam ihracat belgesi: Konşimento, Menşe Sertifikası, Fitosanitasyon Sertifikası, Analiz Sertifikası, MSDS ve gümrük beyanları şirket bünyesinde hazırlanmaktadır.</p>
        </div>
        <div class="logistics-card reveal">
          <div class="logistics-icon">&#128737;&#65039;</div>
          <h3>Özel Etiket</h3>
          <p>Özel markalaşma, ambalaj tasarımı, çuval boyutları ve palet konfigürasyonları. Ürünleri kendi marka adınızla ve özelliklerinize göre sevk edebiliriz - anahtar teslim beyaz etiket hizmeti.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRADE TERMS ===== -->
  <section class="terms-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag" style="color:var(--gold-light);">Ticaret Koşulları</span>
        <h2 class="section-title" style="color:var(--white);">Uyguladığımız <span>Incoterms 2020</span></h2>
      </div>

      <div class="terms-grid">
        <div class="term-card reveal">
          <div class="term-code">EXW</div>
          <div class="term-name">İşyerinde Teslim</div>
          <div class="term-desc">Alıcı tesisimizin kapısından itibaren tüm taşıma işlemlerini düzenler. En düşük birim fiyat - köklü Türk nakliye acentesi olan müşteriler için idealdir.</div>
        </div>
        <div class="term-card reveal">
          <div class="term-code">FCA</div>
          <div class="term-name">Taşıyıcıya Teslim</div>
          <div class="term-desc">Teslimatı belirlediğiniz taşıyıcı veya navlun şirketine yapıyoruz. Mallar ihracat için gümrüklenmiş ve tesisimizde yüklenmiş olarak teslim edilir. Esnek bir orta yol seçeneğidir.</div>
        </div>
        <div class="term-card reveal">
          <div class="term-code">FOB</div>
          <div class="term-name">Gemiye Teslim</div>
