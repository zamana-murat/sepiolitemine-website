---
import Layout from '@layouts/Layout.astro';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: `${siteUrl}/tr/` },
    { '@type': 'ListItem', position: 2, name: 'Küresel Pazarlar', item: `${siteUrl}/tr/markets/` },
  ],
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Sepiolite Mine, Akmin Mining',
  url: siteUrl,
  description:
    "Türkiye'nin önde gelen sepiyolit üreticisi ve ihracatçısı, dünya genelinde 45'ten fazla ülkeye premium ham ve işlenmiş sepiyolit kademeleri sunmaktadır.",
  areaServed: [
    { '@type': 'Continent', name: 'Europe' },
    { '@type': 'Continent', name: 'Asia' },
    { '@type': 'Continent', name: 'Africa' },
    { '@type': 'Continent', name: 'North America' },
    { '@type': 'Continent', name: 'South America' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Sepiolite Mine hangi ülkelere ihracat yapmaktadır?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Sepiolite Mine, Avrupa (Almanya, Hollanda, İspanya, İtalya, Fransa, Polonya, İngiltere), Orta Doğu ve Kuzey Afrika (BAE, Suudi Arabistan, Mısır, Fas), Asya Pasifik (Çin, Japonya, Güney Kore, Hindistan), Amerika (ABD, Kanada, Brezilya, Meksika) ve Sahra Altı Afrika (Güney Afrika, Nijerya, Kenya) dahil 45'ten fazla ülkeye ihracat yapmaktadır.",
      },
    },
    {
      '@type': 'Question',
      name: 'Sepiolite Mine hangi nakliye yöntemlerini sunmaktadır?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '20 ayak ve 40 ayak konteynerli sevkiyatlar, büyük siparişler için dökme gemi kiraları, büyük çuval (FIBC) seçenekleri ve paletlenmiş 25–50 kg çuvallar sunmaktayız. Tüm sevkiyatlar, tam dokümantasyon, analiz sertifikası ve gümrük takas desteğini kapsamaktadır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Hangi Incoterms koşulları geçerlidir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Incoterms 2020 kapsamında EXW, FCA, FOB, CFR, CIF ve DAP koşullarıyla işlem yapmaktayız. Türk limanı FOB en yaygın düzenlemedir; ancak lojistik ortaklarımız aracılığıyla rekabetçi navlun fiyatlarıyla dünyanın her limanına CIF/DAP olarak teslimat yapabiliriz.',
      },
    },
    {
      '@type': 'Question',
      name: 'İhracat için minimum sipariş miktarı nedir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Standart minimum sipariş, ürün yoğunluğuna bağlı olarak yaklaşık 18–22 ton kapasiteli bir 20 ayaklık konteynere karşılık gelmektedir. Yeni müşteriler veya deneme siparişleri için 5–10 ton gibi daha küçük miktarlara da uyum sağlayabiliriz. Dökme gemi siparişleri genellikle 3.000 tondan başlamaktadır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Özel etiketleme hizmeti sunuyor musunuz?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Evet. Tüm ürün hatları için tam özel etiket ve beyaz etiket ambalajlama sunuyoruz. Özel çuval tasarımları (25 kg, 50 kg, büyük çuval), markalı paletler ve müşteriye özel dokümantasyon bunların arasındadır. Özel baskılı ambalaj için minimum sipariş bir 20 ayaklık konteynere karşılık gelmektedir.',
      },
    },
  ],
};

const regions = [
  {
    flag: '🇪🇺',
    name: 'Avrupa',
    subtitle: 'En büyük ihracat pazarımız',
    desc: "Avrupa, ihracatımızın %45'ini oluşturmakta; başta evcil hayvan bakımı (kedi kumu), boya ve kaplama ile inşaat yalıtımı sektörlerindeki güçlü talep bu payı desteklemektedir. Tüm ürün hatları için REACH uyumlu kaliteler mevcuttur.",
    countries: ['Almanya', 'Hollanda', 'İspanya', 'İtalya', 'Fransa', 'Polonya', 'İngiltere', 'Belçika'],
    stats: [{ num: '%45', label: 'İhracat Payı' }, { num: '18', label: 'Ülke' }],
  },
  {
    flag: '🇰🇼',
    name: 'Orta Doğu & Kuzey Afrika',
    subtitle: 'En hızlı büyüyen koridor',
    desc: "Petrol ve gaz sondajı, inşaat patlaması ve büyüyen evcil hayvan bakımı pazarları, MENA'yı en hızlı büyüyen bölgemiz haline getirmektedir. Stratejik yakınlığımız sayesinde herhangi bir Körfez veya Kuzey Afrika limanına 5–10 günde teslimat yapılabilmektedir.",
    countries: ['BAE', 'Suudi Arabistan', 'Mısır', 'Fas', 'İsrail', 'Katar', 'Tunus'],
    stats: [{ num: '%25', label: 'İhracat Payı' }, { num: '12', label: 'Ülke' }],
  },
  {
    flag: '🇯🇵',
    name: 'Asya Pasifik',
    subtitle: 'Yüksek büyümeli sanayi talebi',
    desc: 'Hızla sanayileşen ekonomiler, sondaj kalitesi sepiyolit, kataliz destekleri ve tarımsal taşıyıcılara olan talebi artırmaktadır. Çin, Japonya ve Güney Kore, hacim bazında ilk üç Asya pazarımızdır.',
    countries: ['Çin', 'Japonya', 'Güney Kore', 'Hindistan', 'Tayland', 'Vietnam'],
    stats: [{ num: '%15', label: 'İhracat Payı' }, { num: '9', label: 'Ülke' }],
  },
  {
    flag: '🇺🇸',
    name: 'Amerika Kıtası',
    subtitle: 'Premium kalite odağı',
    desc: 'ABD ve Kanada yüksek saflıkta sondaj ve eczacılık kalitesi sepiyolit ithal ederken Brezilya ve Meksika, tarımsal ve çevresel uygulamalar için büyüyen pazarlar haline gelmektedir.',
    countries: ['ABD', 'Kanada', 'Brezilya', 'Meksika', 'Arjantin', 'Kolombiya'],
    stats: [{ num: '%10', label: 'İhracat Payı' }, { num: '8', label: 'Ülke' }],
  },
  {
    flag: '🇿🇦',
    name: 'Sahra Altı Afrika',
    subtitle: 'Gelişen fırsat',
    desc: "Toprak düzenleyicileri ve gübre taşıyıcılarına yönelik tarım kaynaklı talep, Doğu ve Güney Afrika'da yeni pazarlar açmaktadır. Çevre rehabilitasyon projeleri de ek fırsatlar yaratmaktadır.",
    countries: ['Güney Afrika', 'Nijerya', 'Kenya', 'Etiyopya', 'Tanzanya'],
    stats: [{ num: '%5', label: 'İhracat Payı' }, { num: '7', label: 'Ülke' }],
  },
  {
    flag: '🇷🇺',
    name: 'BDT & Orta Asya',
    subtitle: 'Sondaj ve sanayi tabanı',
    desc: "Hazar bölgesi ve Orta Asya'nın petrol ve gazca zengin ekonomileri, sondaj kalitesi sepiyolit ve endüstriyel absorbanların tutarlı ithalatçılarıdır. Gürcistan üzerinden kara güzergahları maliyet etkin taşıma imkânı sunmaktadır.",
    countries: ['Rusya', 'Kazakistan', 'Azerbaycan', 'Gürcistan', 'Özbekistan'],
    stats: [{ num: '~%5', label: 'İhracat Payı' }, { num: '6', label: 'Ülke' }],
  },
];

const tradeRoutes = [
  { port: 'Rotterdam, Hollanda', region: "Avrupa'nın en büyük mineral merkezi", time: '7 gün' },
  { port: 'Jebel Ali, BAE', region: 'Orta Doğu ve yeniden ihracat kapısı', time: '10 gün' },
  { port: 'Şanghay, Çin', region: 'Asya Pasifik ana limanı', time: '22 gün' },
  { port: 'New York / Newark, ABD', region: 'Kuzey Amerika doğu yakası', time: '18 gün' },
  { port: 'Kazablanka, Fas', region: 'Kuzey Afrika ve tarım koridoru', time: '5 gün' },
  { port: 'Santos, Brezilya', region: 'Güney Amerika ana limanı', time: '24 gün' },
];

const incoterms = [
  { code: 'EXW', name: 'İşyerinde Teslim', desc: 'Alıcı tesisimizin kapısından itibaren tüm taşıma işlemlerini düzenler. En düşük birim fiyat; köklü Türk nakliye acentesi olan müşteriler için idealdir.' },
  { code: 'FCA', name: 'Taşıyıcıya Teslim', desc: 'Teslimatı belirlediğiniz taşıyıcı veya navlun şirketine yapıyoruz. Mallar ihracat için gümrüklenmiş ve tesisimizde yüklenmiş olarak teslim edilir. Esnek bir orta yol seçeneğidir.' },
  { code: 'FOB', name: 'Gemiye Teslim', desc: 'En yaygın koşulumuz. Mallar Türk limanında gemiye yüklenene kadar tüm işlemleri biz üstleniriz; deniz nakliyesini siz yönetirsiniz.' },
  { code: 'CFR', name: 'Navlun Dahil Teslim', desc: 'Varış limanına kadar taşıma masraflarını karşılıyoruz. Sigorta ve boşaltma sizin sorumluluğunuzdadır. Sigorta karmaşıklığı olmadan tek bir teslim maliyet teklifi isteyenler için uygundur.' },
  { code: 'CIF', name: 'Navlun ve Sigorta Dahil', desc: 'Deniz sigortası dahil varış limanına kadar her şey dahil. Ton başına tek bir teslim fiyatı isteyen alıcılar için en basit seçenek.' },
  { code: 'DAP', name: 'Belirlenen Yere Teslim', desc: 'Deponuza veya teslimat adresinize kapıya teslimat. Varış noktasındaki gümrük işlemleri dahil tüm lojistiği biz üstleniriz. Tam gönül rahatlığı.' },
];

const faqs = [
  {
    q: 'Sepiolite Mine hangi ülkelere ihracat yapmaktadır?',
    a: "Beş kıtada 45'ten fazla ülkeye ihracat yapıyoruz. Başlıca pazarlarımız şunlardır: Avrupa'da Almanya, Hollanda, İspanya, İtalya ve Fransa; MENA'da BAE, Suudi Arabistan, Mısır ve Fas; Asya Pasifik'te Çin, Japonya, Güney Kore ve Hindistan; Amerika'da ABD, Kanada ve Brezilya; Afrika'da ise Güney Afrika, Nijerya ve Kenya. Her ülkeden gelen sorgulamaları memnuniyetle karşılıyoruz.",
  },
  {
    q: 'Hangi nakliye yöntemlerini sunuyorsunuz?',
    a: "Konteynerli sevkiyatlar (20 ve 40 ayak), 3.000 MT üzeri siparişler için dökme gemi kiraları ve büyük çuval (FIBC) seçenekleri sunmaktayız. Ürünler 25 kg veya 50 kg çuvallarda paletlenerek ya da 1–1,5 MT'lık büyük çuvallarla sevk edilebilir. Tüm sevkiyatlar, tam dokümantasyon, analiz sertifikası ve lojistik ekibimizden gümrük takas desteğini kapsar.",
  },
  {
    q: 'Hangi Incoterms koşulları altında işlem yapıyorsunuz?',
    a: 'Incoterms 2020 kapsamında EXW, FCA, FOB, CFR, CIF ve DAP koşullarıyla işlem yapıyoruz. FOB Türk limanı (Gemlik veya Mersin) en yaygın düzenlemedir; ancak tek bir teslim maliyet isteyen müşterilere CIF ve DAP olarak da düzenli sevkiyat yapıyoruz. Lojistik ortaklarımız tüm başlıca nakliye hatlarında rekabetçi navlun fiyatlarını korumaktadır.',
  },
  {
    q: 'Minimum sipariş miktarı nedir?',
    a: 'Standart minimum, ürün kalitesine ve ambalaj türüne bağlı olarak yaklaşık 18–22 ton kapasiteli bir 20 ayaklık konteynere karşılık gelmektedir. Yeni müşteriler veya deneme siparişleri için 5–10 tonluk daha küçük sevkiyatlara uyum sağlayabiliriz. Dökme gemi siparişleri genellikle Handy-size kiralamalar için 3.000 tondan başlamaktadır.',
  },
  {
    q: 'Özel etiketli ambalaj sunuyor musunuz?',
    a: 'Evet. Tüm ürün hatları için tam özel etiket ve beyaz etiket ambalajlama sunuyoruz. Özel çuval tasarımları (25 kg, 50 kg, büyük çuval), markalı paletler, müşteriye özel etiketler ve şirket adınız altında hazırlanan belgeler bunlara dahildir. Özel baskılı ambalaj için minimum sipariş bir 20 ayaklık konteynere karşılık gelmektedir. Yeni baskı onayı için bekleme süresi genellikle 2–3 haftadır.',
  },
];
---

<Layout
  title="Küresel Pazarlar, 45+ Ülkeye Sepiyolit İhracatı"
  description="Sepiolite Mine, premium Türk sepiyolitini Avrupa, Orta Doğu, Asya Pasifik, Amerika ve Afrika dahil 45'ten fazla ülkeye ihraç etmektedir. Bölgesel varlığımızı, lojistik kapasitemizi ve pazar görüşlerimizi keşfedin."
  locale="tr"
  alternates={{ en: '/markets/', tr: '/tr/markets/' }}
  schemaJson={[breadcrumbSchema, organizationSchema, faqSchema]}
>
  <nav class="breadcrumb-bar" aria-label="Kırıntı yolu">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/tr/">Ana Sayfa</a></li>
        <li class="sep">›</li>
        <li aria-current="page">Küresel Pazarlar</li>
      </ol>
    </div>
  </nav>

  <section class="hub-hero section section--dark">
    <div class="container container-narrow">
      <span class="section-tag">Küresel Varlık</span>
      <h1>Türkiye'den <span class="accent">Dünyaya</span></h1>
      <p class="lead">
        Üç kıtanın kesişme noktasında stratejik konumuyla Sepiolite Mine; güvenilirlik, hız ve
        otuz yıllık itibarın simgesi olan kaliteyle 45'ten fazla ülkedeki sanayi ortaklarına
        premium Türk sepiyoliti ulaştırmaktadır.
      </p>
      <div class="hero-stats">
        <div class="hero-stat"><div class="num">45+</div><div class="label">Hizmet Verilen Ülke</div></div>
        <div class="hero-stat"><div class="num">300+</div><div class="label">Aktif Müşteri</div></div>
        <div class="hero-stat"><div class="num">120K</div><div class="label">MT Yıllık Kapasite</div></div>
        <div class="hero-stat"><div class="num">5</div><div class="label">Kıta</div></div>
      </div>
    </div>
  </section>

  <section class="section strategic-section">
    <div class="container">
      <div class="strategic-grid">
        <div class="strategic-text">
          <span class="section-tag">Stratejik Avantaj</span>
          <h2>Türkiye: Dünyanın <span class="accent">Sepiyolit Başkenti</span></h2>
          <p class="section-subtitle">
            Türkiye, küresel sepiyolit rezervlerinin tahminen %70'ini barındırmakta ve bu
            rezervler Eskişehir-Sivrihisar havzasında yoğunlaşmaktadır. Madenlerimiz bu
            formasyonun tam merkezinde yer almakta; bize gezegenin en zengin yataklarına doğrudan
            erişim ve çok az rakibin eşleşebileceği bir lojistik avantaj sunmaktadır.
          </p>
          <div class="advantage-list">
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">⚓</div>
              <div>
                <h4>Limana Yakınlık</h4>
                <p>Gemlik limanına 200 km, Mersin'e 380 km mesafede; Türkiye'nin en işlek mineral ihracat terminalleri, tüm önemli güzergahlara günlük konteyner seferleriyle hizmet vermektedir.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">🚀</div>
              <div>
                <h4>Hızlı Transit Süreleri</h4>
                <p>Avrupa limanlarına 7–10 gün, Amerika'ya 14–18 gün, Asya Pasifik'e 20–25 gün. Daha kısa transit süreleri, sizin için daha düşük stok maliyetleri anlamına gelir.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">🏭</div>
              <div>
                <h4>Maden-Liman Entegrasyonu</h4>
                <p>İşleme tesisimiz maden sahasıyla aynı konumdadır. Cevher, çıkarılmadan ihracata hazır ürüne 48 saat içinde ulaşır; bu da temin sürelerini en aza indirir.</p>
              </div>
            </div>
            <div class="advantage-item">
              <div class="advantage-icon" aria-hidden="true">📈</div>
              <div>
                <h4>Doğrudan Üreticiden</h4>
                <p>Aracı yok. Çıkarımdan FOB'a kadar her adımı biz yönetiyoruz; bu da tüm kademelerde tutarlı ve şeffaf koşullara dönüşüyor.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="map-visual">
          <div class="map-header">
            <div class="map-header-icon" aria-hidden="true">🌍</div>
            <h3>Türkiye'den Başlıca Ticaret Güzergahları</h3>
          </div>
          <div class="trade-routes">
            {tradeRoutes.map((r) => (
              <div class="trade-route">
                <span class="route-dot" aria-hidden="true"></span>
                <div class="route-info">
                  <strong>{r.port}</strong>
                  <span>{r.region}</span>
                </div>
                <span class="route-time">{r.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section regions-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Bölgesel Pazarlar</span>
        <h2>Sepiyolitlerimizin <span class="accent">Ulaştığı Yerler</span></h2>
        <p>Her bölgenin kendine özgü endüstriyel talepleri ve mevzuat gereksinimleri vardır. Ürün kalitelerimizi, ambalajlamamızı ve dokümantasyonumuzu her pazara mükemmel biçimde uyarlıyoruz.</p>
      </div>

      <div class="regions-grid">
        {regions.map((region) => (
          <div class="region-card">
            <div class="region-card-header">
              <div class="region-card-flag" aria-hidden="true">{region.flag}</div>
              <h3>{region.name}</h3>
              <div class="region-subtitle">{region.subtitle}</div>
            </div>
            <div class="region-card-body">
              <p>{region.desc}</p>
              <div class="region-countries">
                {region.countries.map((c) => <span class="region-country">{c}</span>)}
              </div>
              <div class="region-stats">
                {region.stats.map((s) => (
                  <div class="region-stat">
                    <div class="region-stat-num">{s.num}</div>
                    <div class="region-stat-label">{s.label}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section logistics-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Lojistik</span>
        <h2>Uçtan Uca <span class="accent">Nakliye</span> Çözümleri</h2>
      </div>

      <div class="logistics-grid">
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">📦</div>
          <h3>Konteynerli Sevkiyat</h3>
          <p>Paletlenmiş çuvallar (25–50 kg) veya büyük çuvallar (1–1,5 MT) için standart 20 ayak ve 40 ayak konteynerler. Gemlik ve Mersin limanlarından tüm başlıca ticaret hatlarına haftalık seferler.</p>
        </div>
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">🚢</div>
          <h3>Dökme Gemi</h3>
          <p>3.000 MT'den başlayan büyük siparişler için Handy-size'dan Panamax'a gemi kiralama. Varış noktasında silo deposu olan kedi kumu ve inşaat kalitesi alıcılar için idealdir.</p>
        </div>
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">📋</div>
          <h3>Dokümantasyon</h3>
          <p>Tam ihracat belgesi: Konşimento, Menşe Sertifikası, Fitosanitasyon Sertifikası, Analiz Sertifikası, MSDS ve gümrük beyanları şirket bünyesinde hazırlanmaktadır.</p>
        </div>
        <div class="logistics-card">
          <div class="logistics-icon" aria-hidden="true">🏷️</div>
          <h3>Özel Etiket</h3>
          <p>Özel markalaşma, ambalaj tasarımı, çuval boyutları ve palet konfigürasyonları. Ürünleri kendi marka adınızla ve özelliklerinize göre sevk edebiliriz; anahtar teslim beyaz etiket hizmeti.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark terms-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Ticaret Koşulları</span>
        <h2>Uyguladığımız <span class="accent">Incoterms 2020</span></h2>
      </div>

      <div class="terms-grid">
        {incoterms.map((t) => (
          <div class="term-card">
            <div class="term-code">{t.code}</div>
            <div class="term-name">{t.name}</div>
            <div class="term-desc">{t.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section insights-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Pazar İstihbaratı</span>
        <h2>Sepiyolit Pazarına <span class="accent">Genel Bakış</span></h2>
      </div>

      <div class="insights-grid">
        <div class="insight-card">
          <div class="insight-num">$340M</div>
          <h3>Küresel Pazar Büyüklüğü (2025)</h3>
