---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<Layout
  title="Sondaj Kalitesi Sepiyolit – API Uyumlu Sondaj Sıvısı Katkısı"
  description="Petrol ve gaz sondaj sıvısı uygulamaları için API Spec 13A uyumlu sepiyolit - bentonitin yetersiz kaldığı tuzlu ve yüksek sıcaklık ortamlarında kararlı reoloji sağlar."
  locale="tr"
  alternates={{ en: "/products/drilling-grade-sepiolite/", tr: "/tr/products/sondaj-kalitesi-sepiyolit/" }}
>
<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/tr/">Ana Sayfa</a>
      <span class="sep">›</span>
      <a href="/tr/products/">Ürünler</a>
      <span class="sep">›</span>
      <span class="current">Sondaj Kalitesi Sepiyolit</span>
    </nav>
  </div>
</div>

<section class="product-hero">
  <div class="container">
    <div class="product-hero-grid">
      <div class="product-gallery">
        <div class="product-main-img" id="mainImg">
          <img width="1200" height="896" src="/images/products/product-drilling-grade.webp" alt="Sondaj Kalitesi Sepiyolit" id="mainImgSrc"/>
        </div>
        <div class="product-thumbs">
          <div class="product-thumb active" onclick="switchImage(this, '/images/products/product-drilling-grade.webp', 'Sondaj Kalitesi Sepiyolit')">
            <img width="1200" height="896" src="/images/products/product-drilling-grade.webp" alt="Sondaj Kalitesi Sepiyolit" loading="lazy"/>
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/mine/mine-landscape-05.webp', 'Maden sahası')">
            <img width="960" height="1280" src="/images/mine/mine-landscape-05.webp" alt="Maden sahası" loading="lazy"/>
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-01.webp', 'Sondaj Kalitesi Sepiyolit örneği')">
            <img width="675" height="900" src="/images/products/product-sample-01.webp" alt="Sondaj Kalitesi Sepiyolit örneği" loading="lazy"/>
          </div>
          <div class="product-thumb" onclick="switchImage(this, '/images/products/product-sample-02.webp', 'Sondaj Kalitesi Sepiyolit detay')">
            <img width="675" height="900" src="/images/products/product-sample-02.webp" alt="Sondaj Kalitesi Sepiyolit detay" loading="lazy"/>
          </div>
        </div>
      </div>
      <div class="product-info">
        <div class="product-badge">Petrol &amp; Gaz</div>
        <h1 class="product-h1">Sondaj Kalitesi <em>Sepiyolit</em></h1>
        <p class="product-tagline">Petrol ve gaz sondaj sıvısı uygulamaları için API Spec 13A uyumlu sepiyolit - bentonitin yetersiz kaldığı tuzlu ve yüksek sıcaklık ortamlarında kararlı reoloji sağlar.</p>
        <div class="key-specs">
          <div class="key-spec"><div class="key-spec-value">API 13A</div><div class="key-spec-label">Spesifikasyon</div></div>
          <div class="key-spec"><div class="key-spec-value">300°C</div><div class="key-spec-label">Termal Limit</div></div>
          <div class="key-spec"><div class="key-spec-value">Tuz</div><div class="key-spec-label">Tolerans</div></div>
        </div>
        <div class="price-box">
          <div class="price-box-header">
            <span class="price-label">Toplu Fiyatlandırma</span>
            <span class="price-availability">Stokta Mevcut</span>
          </div>
          <div class="price-value">TBD</div>
          <div class="price-unit">Metrik ton başına fiyat · FOB Mersin Limanı · Hacme göre fiyat değişir</div>
          <div class="price-features"><div class="price-feature"><svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Minimum sipariş: 10 MT</div><div class="price-feature"><svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Ambalaj: 25 kg veya 50 kg çuval</div><div class="price-feature"><svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> API Spec 13A Bölüm 3 uyumluluğu belgelenmiş</div><div class="price-feature"><svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Her sevkiyatla birlikte test raporu verilir</div></div>
          <div class="price-actions">
            <a href="/tr/contact/" class="btn btn-primary">Teklif İste</a>
            <a href="/tr/contact/" class="btn btn-outline">Numune İste</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="product-desc-section">
  <div class="container">
    <div class="product-desc-grid">
      <div class="product-desc">
        <div class="section-tag">Ürüne Genel Bakış</div>
        <div class="divider"></div>
        <h2>Zorlu Kuyu Koşullarında <span>Reoloji Kararlılığı</span></h2>
        <p>Sondaj kalitesi sepiyolit, özellikle yüksek tuz içeriği veya yüksek sıcaklık nedeniyle bentonitin yetersiz kaldığı sondaj sıvısı uygulamaları için optimize edilmiştir. Benzersiz lif yapısı, tuz konsantrasyonundan bağımsız olarak kararlı viskozite sağlar ve bu özellik onu tuzlu oluşum sondajlarında vazgeçilmez kılar.</p>
<p>Sepiyolitin 300°C'ye kadar termal kararlılığı, yüksek sıcaklıklarda performans gösteren tuz toleranslı bentonit yerini alır; bu durum özellikle derin deniz sondajı ve jeotermal kuyu uygulamaları için kritiktir. Yüksek sıcaklıklarda viskozite kaybı yaşanmaz.</p>
<p>API Spec 13A Bölüm 3 standartlarına uygun sondaj kalitesi sepiyolitimiz, her üretim partisi için API yetkilendirme testleri yaptırmaktadır. Viskozite, jel dayanımı ve su kaybı değerleri belgelenerek müşterilere test raporları gönderilmektedir.</p>
<p>Ürün 50 kg'lık çuvallarda paketlenir ve depolama ile taşıma sırasında nem absorbsiyonunu önlemek için nemden korunan ambalaj kullanılır.</p>
      </div>
      <div>
        <div class="tech-specs-card">
          <h3>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L18 7V13L10 18L2 13V7L10 2Z" stroke="#C9922A" stroke-width="1.5" fill="none"/><circle cx="10" cy="10" r="3" fill="#C9922A"/></svg>
            Teknik Özellikler
          </h3>
          <div class="spec-row"><span class="spec-label">Standart</span><span class="spec-value">API Spec 13A Bölüm 3</span></div><div class="spec-row"><span class="spec-label">Parçacık Boyutu</span><span class="spec-value">≤ 74 µm (No.200 elek)</span></div><div class="spec-row"><span class="spec-label">Nem İçeriği</span><span class="spec-value">≤ 13%</span></div><div class="spec-row"><span class="spec-label">Viskozite (600 rpm)</span><span class="spec-value">≥ 30 cP</span></div><div class="spec-row"><span class="spec-label">Jel Dayanımı (10 dk)</span><span class="spec-value">≥ 3 lb/100ft²</span></div><div class="spec-row"><span class="spec-label">Filtrat Kaybı (API)</span><span class="spec-value">≤ 15 ml</span></div><div class="spec-row"><span class="spec-label">Termal Kararlılık</span><span class="spec-value">300°C'ye kadar</span></div><div class="spec-row"><span class="spec-label">Tuz Toleransı</span><span class="spec-value">Doymuş NaCl'e kadar</span></div><div class="spec-row"><span class="spec-label">MgO</span><span class="spec-value">≥ 18%</span></div><div class="spec-row"><span class="spec-label">SiO₂</span><span class="spec-value">≥ 54%</span></div><div class="spec-row"><span class="spec-label">Ambalaj</span><span class="spec-value">25 kg / 50 kg Çuval</span></div><div class="spec-row"><span class="spec-label">Teslimat</span><span class="spec-value">FOB Mersin / Samsun</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="usage-section">
  <div class="container">
    <div class="usage-header">
      <div class="section-tag" style="color:var(--gold-light);">Uygulama Alanları</div>
      <div class="divider divider--center"></div>
      <h2 class="section-title" style="color:var(--white);">Sondaj Kalitesi Sepiyolit <span>Nerelerde Kullanılır?</span></h2>
    </div>
    <div class="usage-grid">
      <div class="usage-card reveal">
        <div class="usage-icon">🛢️</div>
        <h3>Tuzlu Oluşum Sondajı</h3>
        <p>Tuz domlu oluşumlarda veya yüksek tuz içerikli sondaj sıvılarında bentonit yerine kullanılır. Tuz varlığında dahi reoloji parametrelerini kararlı tutar.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🌡️</div>
        <h3>Yüksek Sıcaklık Sondajı</h3>
        <p>300°C'ye kadar sıcaklıklarda kararlı viskozite ve jel dayanımı sunar. Derin kuyular ve jeotermal uygulamalar için tercih edilen reoloji düzenleyicisidir.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🌊</div>
        <h3>Derin Deniz Sondajı</h3>
        <p>Yüksek basınç ve düşük sıcaklıkta etkin reoloji profili sayesinde derin deniz sondajı uygulamalarında kullanılır. Gaz hidratlı ortamlarda da stabil kalır.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">⚡</div>
        <h3>Jeotermal Kuyu Sondajı</h3>
        <p>Yüksek sıcaklıklı jeotermal rezervuarların araştırılmasında sondaj sıvısı katkısı olarak kullanılır. Isıya karşı benzersiz dayanımı bu uygulamada kritik avantaj sağlar.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🔧</div>
        <h3>Tamamlama Sıvıları</h3>
        <p>Kuyu tamamlama ve işleme sıvılarında viskozite düzenleyici. Tuzlu bryndlerde ve yüksek sıcaklık ortamlarında stabil kalma özelliği avantaj sağlar.</p>
      </div>
      <div class="usage-card reveal">
        <div class="usage-icon">🏗️</div>
        <h3>HDD ve Yatay Sondaj</h3>
        <p>Yatay yönlü sondaj uygulamalarında delik stabilitesi ve dönme momenti azaltımı için sondaj sıvısı katkısı. Kaya ve karma oluşumlarda etkin performans.</p>
      </div></div>
  </div>
</section>

<section class="advantages-section">
  <div class="container">
    <div class="advantages-grid">
      <div>
        <div class="section-tag">Neden API Uyumlu Ürünümüz</div>
        <div class="divider"></div>
        <h2 class="section-title">Sondaj Sıvısında <span>Teknik Üstünlük</span></h2>
        <div class="advantage-list">
          <div class="advantage-item reveal">
            <div class="advantage-num">01</div>
            <div><strong>API Spec 13A Uyumluluğu</strong><p>Her üretim partisi, API yetkilendirme testlerinden geçirilir ve uygunluk belgesiyle birlikte müşterilere gönderilir. Küresel petrol ve gaz operasyonlarının standartlarına tam uyum sağlanır.</p></div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">02</div>
            <div><strong>Tuz Toleransı</strong><p>Bentonit, 10.000 ppm üzerinde NaCl konsantrasyonlarında reoloji özelliklerini kaybeder. Sepiyolit, doymuş tuz çözeltilerine kadar performansını korur; bu, özellikle Körfez Bölgesi ve Kuzey Afrika sondaj operasyonları için kritik bir avantajdır.</p></div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">03</div>
            <div><strong>Termal Kararlılık</strong><p>300°C termal dayanım sınırı, sepiyoliti yüksek sıcaklıklı ortamlarda bentonit ile değiştirilemez kılar. Jeotermal ve derin kuyu uygulamaları için ideal seçenektir.</p></div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">04</div>
            <div><strong>Doğrudan Maden Tedariki</strong><p>Türkiye'nin Eskişehir bölgesindeki madenlerden doğrudan tedarik, kalite tutarlılığı ve rekabetçi fiyatlandırma sağlar. Aracı gerektirmeyen tedarik zinciri fiyatı düşürür.</p></div>
          </div>
          <div class="advantage-item reveal">
            <div class="advantage-num">05</div>
            <div><strong>Teknik Destek</strong><p>Sondaj mühendislerimiz, formülasyon optimizasyonu ve saha sorunlarının çözümü konusunda teknik destek sunar. Özel test çalışmaları ve değerlendirme partileri temin edilebilir.</p></div>
          </div></div>
      </div>
      <div class="advantage-image">
        <img width="960" height="1280" src="/images/mine/mine-landscape-05.webp" alt="Türkiye'de sepiyolit madeni" loading="lazy"/>
      </div>
    </div>
  </div>
</section>

<section class="faq-section">
  <div class="container">
    <div class="faq-header">
      <div class="section-tag">Sık Sorulan Sorular</div>
      <div class="divider divider--center"></div>
      <h2 class="section-title">Sıkça Sorulan <span>Sorular</span></h2>
    </div>
    <div class="faq-list">
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">API Spec 13A belgesi nedir ve ürünleriniz uyumlu mu? <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="faq-answer"><div class="faq-answer-inner">API Spec 13A, petrol ve gaz sektöründe sondaj sıvısı katkılarını düzenleyen Amerikan Petrol Enstitüsü standardıdır. Sondaj kalitesi sepiyolitimiz, bu standardın Bölüm 3 gereksinimlerine uygundur ve her partide uygunluk belgesi sağlanmaktadır.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">Bentonite göre sepiyolitin avantajı nedir? <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="faq-answer"><div class="faq-answer-inner">Bentonit tuzlu suya maruz kaldığında şişer ve reolojisini kaybeder, yüksek sıcaklıklarda da performansı düşer. Sepiyolit, doymuş tuz ortamlarında ve 300°C'ye kadar sıcaklıklarda kararlı reoloji profili korur. Bu nedenle tuz domları, yüksek sıcaklıklı derin kuyular ve jeotermal sondajlarda tercih edilir.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">Minimum sipariş miktarı nedir? <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="faq-answer"><div class="faq-answer-inner">Sondaj kalitesi sepiyolit için minimum sipariş miktarı 10 metrik tondur. Değerlendirme amacıyla daha küçük partiler temin edilebilir; bu durumda ekstra paketleme maliyeti uygulanır.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">Hangi ambalaj seçenekleri mevcuttur? <svg class="faq-chevron" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="faq-answer"><div class="faq-answer-inner">Standart ambalaj 50 kg'lık kraft çuvaldır. 25 kg çuval seçeneği de mevcuttur. Her iki ambalaj da nakliye sırasında nem absorbsiyonunu önlemek için nem bariyer kaplama içerir.</div></div>
      </div></div>
  </div>
</section>

<section class="related-section">
  <div class="container">
    <div class="related-header">
      <div class="section-tag">Diğer Ürünler</div>
      <div class="divider divider--center"></div>
      <h2 class="section-title">Diğer <span>Kademelerimiz</span></h2>
    </div>
    <div class="related-grid">
      <div class="related-card reveal">
        <div class="related-card-img"><img width="506" height="900" src="/images/products/product-raw-ore.webp" alt="Ham Sepiyolit Cevheri" loading="lazy"/></div>
        <div class="related-card-body">
          <h3>Ham Sepiyolit Cevheri</h3>
          <p>Kendi işleme tesisleriniz için Türkiye'nin en saf sepiyoliti - doğrudan maden çıkışı.</p>
          <a href="/tr/products/ham-sepiyolit-cevheri/" class="related-link">Ürünü Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
        </div>
      </div>
      <div class="related-card reveal">
        <div class="related-card-img"><img width="1200" height="896" src="/images/products/product-milled-powder.webp" alt="Öğütülmüş Sepiyolit Tozu" loading="lazy"/></div>
        <div class="related-card-body">
          <h3>Öğütülmüş Sepiyolit Tozu</h3>
          <p>Boya, kaplama ve ilaç uygulamaları için ultra ince mikronize toz.</p>
          <a href="/tr/products/ogutulmus-sepiyolit-tozu/" class="related-link">Ürünü Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
        </div>
      </div>
      <div class="related-card reveal">
        <div class="related-card-img"><img width="1200" height="896" src="/images/products/product-construction.webp" alt="İnşaat ve Yalıtım Kalitesi" loading="lazy"/></div>
        <div class="related-card-body">
          <h3>İnşaat ve Yalıtım Kalitesi</h3>
          <p>Yalıtım levhaları ve yangın geçirmez kaplamalar için düşük ısıl iletkenlikli sepiyolit.</p>
          <a href="/tr/products/insaat-yalitim-kalitesi/" class="related-link">Ürünü Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
        </div>
      </div></div>
  </div>
</section>


  
  <script>
  function switchImage(thumb, src, alt) {
    document.getElementById('mainImgSrc').src = src;
    document.getElementById('mainImgSrc').alt = alt;
    document.querySelectorAll('.product-thumb').forEach(function(t) { t.classList.remove('active'); });
    thumb.classList.add('active');
  }
  function toggleFaq(el) {
    var item = el.parentElement;
    var wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
    if (!wasOpen) item.classList.add('open');
  }
  document.addEventListener('DOMContentLoaded', function () {
    var navbar = document.getElementById('navbar');
    if (navbar) { window.addEventListener('scroll', function() { navbar.classList.toggle('scrolled', window.scrollY > 30); }); }
    var hamburger = document.getElementById('hamburger');
    var mobileMenu = document.getElementById('mobileMenu');
    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', function() {
        var exp = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!exp));
        mobileMenu.classList.toggle('open');
        mobileMenu.setAttribute('aria-hidden', String(exp));
      });
    }
    var langBtn = document.querySelector('.lang-btn');
    var langDropdown = document.querySelector('.lang-dropdown');
    if (langBtn && langDropdown) {
      langBtn.addEventListener('click', function(e) { e.stopPropagation(); var isOpen = langDropdown.classList.contains('open'); langDropdown.classList.toggle('open', !isOpen); langBtn.setAttribute('aria-expanded', String(!isOpen)); });
      document.addEventListener('click', function() { langDropdown.classList.remove('open'); langBtn.setAttribute('aria-expanded', 'false'); });
    }
    var obs = new IntersectionObserver(function(entries) { entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }); }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });
  });
  </script>
</Layout>

<style>
/* PRODUCT HERO */
    .product-hero { padding: 4rem 0 5rem; background: linear-gradient(135deg, var(--earth) 0%, var(--earth-mid) 40%, var(--earth-soft) 100%); }
    .product-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
    .product-gallery { position: sticky; top: 80px; }
    .product-main-img { border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4/3; background: rgba(255,255,255,0.05); border: 1px solid rgba(201,146,42,0.2); }
    .product-main-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .product-thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-top: 0.75rem; }
    .product-thumb { border-radius: 8px; overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s ease; aspect-ratio: 1; }
    .product-thumb.active { border-color: var(--gold); }
    .product-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .product-info { padding-top: 0.5rem; }
    .product-badge { display: inline-block; padding: 0.4rem 1rem; border-radius: 4px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; background: rgba(201,146,42,0.15); color: var(--gold-light); border: 1px solid rgba(201,146,42,0.3); margin-bottom: 1rem; }
