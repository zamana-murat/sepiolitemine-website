---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://sepiolitemine.com/tr/" },
      { "@type": "ListItem", "position": 2, "name": "İletişim", "item": "https://sepiolitemine.com/tr/contact/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Sepiolite Mine – Zamana",
    "url": "https://sepiolitemine.com",
    "telephone": "+905304904740",
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "Başkent Organize Sanayi Atatürk Bulvarı No:48, Malıköy",
        "addressLocality": "Sincan / Ankara",
        "addressCountry": "TR"
      }
    ]
  }
];
---

<Layout
  title="İletişim"
  description="Tedarik sorularınız, teknik destek ve ürün numuneleri için Sepiolite Mine ile iletişime geçin. 24 saatlik yanıt garantisi. Telefon, e-posta ve çevrimiçi iletişim formu mevcuttur."
  locale="tr"
  alternates={{ en: "/contact/", tr: "/tr/contact/" }}
  schemaJson={schemaJson}
>
<div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/tr/">Ana Sayfa</a>
        <span class="sep">&#8250;</span>
        <span class="current">İletişim</span>
      </div>
    </div>
  </div>

  <!-- HERO -->
  <section class="contact-hero">
    <div class="container">
      <h1>Tedarik <span>Yolculuğunuza</span> Başlayın</h1>
      <p>Her sorguyu 24 saat içinde yanıtlıyoruz. Numune talep eden yeni bir alıcı, hacim fiyatı arayan köklü bir ithalatçı veya teknik sorular soran bir uzman olun - ekibimiz yardıma hazır.</p>
    </div>
  </section>

  <!-- CONTACT FORM & INFO -->
  <section class="contact-main">
    <div class="container">
      <div class="contact-grid">

        <!-- Left: Contact Information -->
        <div class="contact-info-column reveal">
          <div class="info-block">
            <h3>Şirket Bilgileri</h3>
            <p><span class="info-label">Tüzel Kişilik</span>Zamana Danışmanlık</p>
          </div>

          <div class="info-block">
            <h3>Fabrika &amp; Üretim</h3>
            <p><span class="info-label">Adres</span>Başkent Organize Sanayi Atatürk Bulvarı No:48, Malıköy, Sincan / Ankara</p>
          </div>

          <div class="info-block">
            <h3>Genel Müdürlük</h3>
            <p><span class="info-label">Adres</span>Kızılay Mah. Fevziçakmak 1. Sokak No:15 D:7, Çankaya / Ankara</p>
          </div>

          <div class="info-block">
            <div class="contact-methods">
              <div class="contact-method">
                <span class="contact-method-label">Telefon &amp; WhatsApp</span>
                <span class="contact-method-text">+90 530 490 4740</span>
              </div>
              <div class="contact-method">
                <span class="contact-method-label">Sorgular</span>
                <span class="contact-method-text">Bu sayfadaki formu kullanın - 24 saat içinde yanıtlıyoruz</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="reveal">
          <div class="contact-form-card">
            <h2>Sorgunuzu Gönderin</h2>
            <form id="contactForm" onsubmit="handleFormSubmit(event)" novalidate>
              {/* Honeypot — bot tuzağı; insan görmez, backend bunun dolu olduğunu görünce sessizce reddeder. */}
              <div aria-hidden="true" style="position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden;">
                <label for="website">Web sitesi (boş bırakın)</label>
                <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="fullName">Ad Soyad <span class="required">*</span></label>
                  <input type="text" id="fullName" name="fullName" placeholder="Adınız ve soyadınız" required />
                </div>
                <div class="form-group">
                  <label for="company">Şirket <span class="required">*</span></label>
                  <input type="text" id="company" name="company" placeholder="Şirket adı" required />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="email">E-posta <span class="required">*</span></label>
                  <input type="email" id="email" name="email" placeholder="sizin@eposta.com" required />
                </div>
                <div class="form-group">
                  <label for="country">Ülke</label>
                  <input type="text" id="country" name="country" placeholder="Ülke" />
                </div>
              </div>

              <div class="form-group">
                <label for="product">İlgilenilen Ürün <span class="required">*</span></label>
                <select id="product" name="product" required>
                  <option value="">- Ürün kalitesi seçin -</option>
                  <option value="raw-ore">Ham Sepiyolit Cevheri</option>
                  <option value="granulated">Granüle Sepiyolit</option>
                  <option value="milled-powder">Öğütülmüş Toz</option>
                  <option value="drilling-grade">Sondaj Kalitesi</option>
                  <option value="agricultural-grade">Tarımsal Kalite</option>
                  <option value="construction-grade">İnşaat Kalitesi</option>
                  <option value="custom">Özel / Diğer</option>
                </select>
              </div>

              <div class="form-group">
                <label for="volume">Tahmini Yıllık Hacim <span class="required">*</span></label>
                <select id="volume" name="volume" required>
                  <option value="">- Hacim aralığı seçin -</option>
                  <option value="trial-5-10">Deneme Siparişi 5–10 MT</option>
                  <option value="container-20">1 Konteyner ~20 MT</option>
                  <option value="containers-2-5">2–5 Konteyner</option>
                  <option value="containers-5-10">5–10 Konteyner</option>
                  <option value="bulk-vessel">Dökme Gemi 3000+ MT</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message">Mesaj</label>
                <textarea id="message" name="message" placeholder="Projeniz, özellikleriniz, zaman çizelgeniz veya sorularınız hakkında bize bilgi verin..."></textarea>
              </div>

              <div class="form-privacy">
                <strong>Gizlilik &amp; Yanıt:</strong> Her sorguyu 24 saat içinde yanıtlıyoruz. İletişim bilgileriniz ve şirket bilgileriniz asla üçüncü taraflarla paylaşılmaz; yalnızca tedarik ihtiyaçlarınıza hizmet etmek amacıyla kullanılır.
              </div>

              <button type="submit" class="form-submit">Sorgu Gönder →</button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY CONTACT US -->
  <section class="why-contact-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Taahhüdümüz</span>
        <h2 class="section-title">Neden <span>Bize</span> Ulaşmalısınız?</h2>
      </div>

      <div class="why-contact-grid">
        <div class="why-card reveal">
          <div class="why-icon">⏱️</div>
          <h3>24 Saatlik Yanıt</h3>
          <p>Her sorguya bir iş günü içinde (24 saat) yanıt veriyoruz. Zamanınıza değer veriyoruz - yanıt ve seçeneklerle hızla geri döneceğiz.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">📦</div>
          <h3>Ücretsiz Numune</h3>
          <p>Herhangi bir kademedeki ürün numunesi talep edin. Nitelikli alıcılara dünya genelinde ücretsiz numune göndeririz. Taahhüt etmeden önce değerlendirin.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">🔬</div>
          <h3>Teknik Destek</h3>
          <p>Mühendislerimiz ürün seçimi, özellikler ve özel gereksinimler konusunda size rehberlik eder. Doğru ürünü bulmanızı sağlarız.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">⚙️</div>
          <h3>Özel Çözümler</h3>
          <p>Özel partikül boyutları, nem seviyeleri, ambalaj ve markalama. Ürünü tam ihtiyaçlarınıza göre uyarlıyoruz.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OFFICE LOCATIONS -->
  <section class="locations-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Konumlarımız</span>
        <h2 class="section-title"><span>Ankara</span>'da Bizi Ziyaret Edin</h2>
      </div>

      <div class="locations-grid">
        <div class="location-card reveal">
          <div class="location-icon">🏭</div>
          <h3>Fabrika &amp; Tesis</h3>
          <div class="location-subtitle">Üretim &amp; Kalite Kontrol</div>
          <p class="location-address">Başkent Organize Sanayi Atatürk Bulvarı No:48, Malıköy, Sincan / Ankara, Türkiye</p>
          <div class="location-hours">
            <span class="location-hours-label">Çalışma Saatleri</span>
            <span class="location-hours-text">Pazartesi–Cumartesi, 08:00–18:00 (İstanbul Saati)</span>
          </div>
        </div>

        <div class="location-card reveal">
          <div class="location-icon">🏢</div>
          <h3>Genel Müdürlük</h3>
          <div class="location-subtitle">Satış &amp; Yönetim</div>
          <p class="location-address">Kızılay Mah. Fevziçakmak 1. Sokak No:15 D:7, Çankaya / Ankara, Türkiye</p>
          <div class="location-hours">
            <span class="location-hours-label">Çalışma Saatleri</span>
            <span class="location-hours-text">Pazartesi–Cuma, 09:00–18:00 (İstanbul Saati)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Sık Sorulan Sorular</span>
        <h2 class="section-title">Sıkça Sorulan <span>Sorular</span></h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>Ne kadar sürede yanıt alırım?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-a">
            <p>Her sorguyu bir iş günü (24 saat) içinde yanıtlıyoruz. Satış ekibimiz tüm kanalları mesai saatlerinde izler ve acil talepleri öncelikli olarak işler. Mesai saatleri dışındaki konular için ertesi sabah ilk iş olarak yanıt bekleyebilirsiniz.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>Ürün numunesi talep edebilir miyim?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-a">
            <p>Evet, kesinlikle. Nitelikli alıcılara ücretsiz ürün numunesi sunuyoruz. Hangi kademeyi ve formu değerlendirmek istediğinizi (ham cevher, granül, toz vb.) belirtin; numuneleri dünya genelinde ücretsiz göndereceğiz. Numunelerin büyük çoğunluğu 5–10 iş günü içinde ulaşmaktadır.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>Sorgu formunda hangi bilgileri belirtmeliyim?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-a">
            <p>Size daha hızlı hizmet verebilmemiz için lütfen şunları belirtin: şirket adınız ve sektörünüz, ilgilendiğiniz sepiyolit kalitesi ve formu, tahmini yıllık hacim, hedef özellikler (partikül boyutu, nem, saflık), tercih edilen ambalaj ve teknik gereksinimler. Ne kadar ayrıntı verirseniz, yanıtımız o kadar özelleştirilmiş olur.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>Bulunduğum bölgede satış temsilciniz var mı?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-a">
            <p>45'ten fazla ülkeye hizmet veriyor; doğrudan satış, lojistik ortakları ve bölgesel distribütörler aracılığıyla çalışıyoruz. Bölgenizdeki kapsam hakkında ayrıntılı bilgi için yukarıdaki iletişim formunu kullanın veya +90 530 490 4740 numaralı WhatsApp hattımızı arayın. Sizi konumunuz için doğru iletişim kişisiyle buluşturacağız.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            <span>Çalışma saatleriniz nelerdir?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-a">
            <p>Fabrika (Üretim &amp; Kalite Kontrol): Pazartesi–Cumartesi, 08:00–18:00 (İstanbul/Türkiye saati). Genel Müdürlük (Satış &amp; Yönetim): Pazartesi–Cuma, 09:00–18:00 (İstanbul/Türkiye saati). Mesai saatleri dışında alınan mesajlar ve sorgular bir sonraki iş günü işleme alınacaktır.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="contact-cta">
    <div class="container">
      <h2>Premium <span>Sepiyolit</span> Tedarik Etmeye Hazır mısınız?</h2>
      <p>Yukarıdaki iletişim formunu doldurun; 24 saat içinde özelleştirilmiş bir teklif, teknik özellikler ve numune seçenekleri sunacağız.</p>
      <div class="btn-group">
        <a href="#contactForm" class="btn btn-primary">Sorgu Başlatın</a>
        <a href="/tr/markets/" class="btn btn-outline" style="border-color:rgba(255,255,255,0.4);color:#fff;">Pazarları Keşfedin</a>
      </div>
    </div>
  </section>

  

  
  <script>
    var navbar = document.getElementById('navbar');
    if (navbar) {
      window.addEventListener('scroll', function() {
        navbar.classList.toggle('scrolled', window.scrollY > 30);
      });
    }

    var hamburger = document.getElementById('hamburger');
    var mobileMenu = document.getElementById('mobileMenu');
    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', function() {
        var expanded = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!expanded));
        mobileMenu.classList.toggle('open');
        mobileMenu.setAttribute('aria-hidden', String(expanded));
      });
    }

    // Language dropdown
    var langBtn = document.querySelector('.lang-btn');
    var langDropdown = document.querySelector('.lang-dropdown');
    if (langBtn && langDropdown) {
      langBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var expanded = langBtn.getAttribute('aria-expanded') === 'true';
        langBtn.setAttribute('aria-expanded', String(!expanded));
        langDropdown.classList.toggle('open');
      });
      document.addEventListener('click', function() {
        langBtn.setAttribute('aria-expanded', 'false');
        langDropdown.classList.remove('open');
      });
    }

    // Scroll reveal
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });

    // Form submit — POST to /api/contact (Cloudflare Pages Function → Resend)
    async function handleFormSubmit(event) {
      event.preventDefault();
      var form = event.target;
      var card = form.closest('.contact-form-card');
      var submitBtn = form.querySelector('.form-submit');
      var data = new FormData(form);

      var productLabel = form.querySelector('#product').selectedOptions[0]?.text || '';
      var volumeLabel = form.querySelector('#volume').selectedOptions[0]?.text || '';

      var payload = {
        name: (data.get('fullName') || '').toString().trim(),
        email: (data.get('email') || '').toString().trim(),
        company: (data.get('company') || '').toString().trim(),
        country: (data.get('country') || '').toString().trim(),
        subject: productLabel || 'Sepiyolit sorgusu',
        message: [
          'Ürün:    ' + productLabel,
          'Hacim:   ' + volumeLabel,
          '',
          (data.get('message') || '').toString().trim() || '(mesaj yok)',
        ].join('\n'),
        website: (data.get('website') || '').toString(), // honeypot
        locale: 'tr',
      };

      submitBtn.disabled = true;
      var originalLabel = submitBtn.textContent;
      submitBtn.textContent = 'Gönderiliyor…';

      try {
        var r = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var result = await r.json().catch(function () { return { ok: false }; });

        if (r.ok && result.ok) {
          card.innerHTML = '<div style="text-align:center;padding:3rem 1.5rem;">' +
            '<div style="font-size:3rem;margin-bottom:1rem;color:var(--gold);">&#10003;</div>' +
            '<h2 style="font-family:Playfair Display,serif;font-size:1.6rem;color:var(--earth);margin-bottom:1rem;">Sorgunuz Alındı</h2>' +
            '<p style="font-size:0.95rem;color:var(--text-light);line-height:1.7;max-width:400px;margin:0 auto 1.5rem;">İlginiz için teşekkürler. Satış ekibimiz sorgunuzu inceleyecek ve 24 saat içinde yanıtlayacak.</p>' +
            '<p style="font-size:0.85rem;color:var(--stone);">Ayrıca <strong>+90 530 490 4740</strong> (WhatsApp) numarasından da bize ulaşabilirsiniz.</p>' +
            '</div>';
        } else {
          throw new Error(result.error || 'Gönderim başarısız');
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
        var existingErr = form.querySelector('.form-error');
        if (existingErr) existingErr.remove();
        var errBox = document.createElement('div');
        errBox.className = 'form-error';
        errBox.style.cssText = 'margin-top:1rem;padding:0.85rem 1rem;border-left:3px solid #b3261e;background:#fdecea;color:#5b1612;font-size:0.88rem;border-radius:0 6px 6px 0;';
        errBox.textContent = 'Gönderilemedi: ' + (err && err.message ? err.message : 'bilinmeyen hata') + '. Lütfen tekrar deneyin veya +90 530 490 4740 numarasını arayın.';
        form.appendChild(errBox);
      }
    }

    // FAQ toggle
    function toggleFaq(button) {
      var faqItem = button.parentElement;
      var answer = faqItem.querySelector('.faq-a');
      var isOpen = answer.classList.contains('open');
      document.querySelectorAll('.faq-a.open').forEach(function(a) {
        a.classList.remove('open');
        a.parentElement.querySelector('.faq-q').classList.remove('active');
      });
      if (!isOpen) {
        answer.classList.add('open');
        button.classList.add('active');
      }
    }
  </script>
</Layout>

<style is:global>
/* HERO */
    .contact-hero { position: relative; padding: 6rem 0 5rem; background: linear-gradient(135deg, var(--earth) 0%, var(--earth-mid) 50%, var(--earth-soft) 100%); overflow: hidden; }
    .contact-hero::before { content: ''; position: absolute; inset: 0; background: url('/images/mine/mine-aerial-02.webp') center/cover no-repeat; opacity: 0.15; }
    .contact-hero .container { position: relative; z-index: 2; text-align: center; }
    .contact-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 5vw, 3.8rem); color: var(--white); margin-bottom: 1.25rem; line-height: 1.12; }
    .contact-hero h1 span { color: var(--gold); }
    .contact-hero p { font-size: 1.1rem; color: rgba(255,255,255,0.75); max-width: 700px; margin: 0 auto; line-height: 1.7; }

    /* CONTACT FORM */
    .contact-main { padding: 5rem 0; background: var(--white); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: flex-start; }
    .contact-info-column { display: flex; flex-direction: column; gap: 2rem; }
    .info-block { background: var(--cream); border-left: 4px solid var(--gold); padding: 2rem; border-radius: var(--radius); box-shadow: var(--shadow-sm); }
    .info-block h3 { font-family: 'Playfair Display', serif; font-size: 0.95rem; color: var(--earth); margin-bottom: 1.25rem; font-weight: 700; }
    .info-block p { font-size: 0.85rem; line-height: 1.65; color: var(--text-light); margin-bottom: 0.75rem; }
    .info-block p:last-child { margin-bottom: 0; }
    .info-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.35rem; }
    .contact-methods { display: flex; flex-direction: column; gap: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--cream-dark); }
    .contact-method { display: flex; flex-direction: column; }
    .contact-method-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
    .contact-method-text { font-size: 0.92rem; font-weight: 600; color: var(--earth); }

    /* FORM */
    .contact-form-card { background: var(--cream); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-md); border: 1px solid var(--cream-dark); }
    .contact-form-card h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--earth); margin-bottom: 2rem; }
