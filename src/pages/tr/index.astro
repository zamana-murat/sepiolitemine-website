---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: BRAND.name,
  url: siteUrl,
  description: BRAND.description,
  telephone: BRAND.contact.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Başkent Organize Sanayi Atatürk Bulvarı No:48',
    addressLocality: 'Sincan / Ankara',
    addressCountry: 'TR',
  },
  sameAs: ['https://www.linkedin.com/in/murat-%C3%B6zsayg%C4%B1l%C4%B1-59790865/?locale=en'],
  parentOrganization: {
    '@type': 'Organization',
    name: 'Zamana',
    url: 'https://zamana.com.tr',
  },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteUrl}/#owner`,
  name: 'Murat Özsaygılı',
  jobTitle: 'Sahibi / Operatör',
  worksFor: {
    '@type': 'Organization',
    name: 'Zamana',
    url: 'https://zamana.com.tr',
  },
  url: 'https://zamana.com.tr',
  sameAs: ['https://www.linkedin.com/in/murat-%C3%B6zsayg%C4%B1l%C4%B1-59790865/?locale=en'],
};
---

<Layout
  title="Premium Türk Sepiyolit Tedarikçisi"
  description="Türkiye'nin öncü sepiyolit üreticisi. Tarım, petrol ve gaz, inşaat, kedi kumu ve küresel endüstriyel pazarlar için premium ham ve işlenmiş sepiyolit."
  alternates={{ en: '/', tr: '/tr/' }}
  locale="tr"
  noSuffix={true}
  schemaJson={[orgSchema, personSchema]}
>
  <Fragment slot="head">
    {/* Responsive preload: mobil 800w (97 KB) vs masaüstü 1200w (220 KB) */}
    <link rel="preload" as="image" href="/images/mine/aerial-02-800w.webp" media="(max-width: 1279px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/mine/aerial-02-1200w.webp" media="(min-width: 1280px)" fetchpriority="high" />
  </Fragment>

  {/* HERO */}
  <section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-particles" id="particles"></div>
    <div class="container hero-content">
      <div class="hero-badge">Türkiye'nin Öncü Sepiyolit Üreticisi</div>
      <h1 class="hero-title">
        Dünyanın En<br/><em>Çok Yönlü Minerali</em><br/>Küresel Pazarlara
      </h1>
      <p class="hero-desc">
        Türkiye'nin zengin yataklarından, Sepiolite Mine; tarım, petrol &amp; gaz, inşaat, çevre ve daha pek çok sektöre dünya genelinde premium ham ve işlenmiş sepiyolit tedarik eder.
      </p>
      <div class="hero-actions">
        <a href="#urunler" class="btn btn-primary">Ürünleri Keşfedin ↓</a>
        <a href="/tr/contact/" class="btn btn-outline">Numune Talep Edin</a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-value">50+</div>
          <div class="hero-stat-label">Hizmet Verilen Ülke</div>
        </div>
        <div>
          <div class="hero-stat-value">15+</div>
          <div class="hero-stat-label">Endüstri Sektörü</div>
        </div>
        <div>
          <div class="hero-stat-value">%99.2</div>
          <div class="hero-stat-label">Saflık Derecesi</div>
        </div>
        <div>
          <div class="hero-stat-value">25+</div>
          <div class="hero-stat-label">Yıllık Deneyim</div>
        </div>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Kaydır</span>
      <div class="hero-scroll-line"></div>
    </div>
  </section>

  {/* BANT */}
  <div class="ticker-strip">
    <div class="ticker-inner" id="ticker">
      <span>Ham Sepiyolit</span><span>Granüle Sepiyolit</span><span>Öğütülmüş Toz</span>
      <span>Kedi Kumu Kalitesi</span><span>Sondaj Kalitesi</span><span>Tarım Kalitesi</span>
      <span>Endüstriyel Kalite</span><span>Farmasötik Kalite</span><span>Çevre Kalitesi</span>
      <span>Sepiyolit Türkiye</span><span>Zamana</span><span>sepiolitemine.com</span>
      <span>Ham Sepiyolit</span><span>Granüle Sepiyolit</span><span>Öğütülmüş Toz</span>
      <span>Kedi Kumu Kalitesi</span><span>Sondaj Kalitesi</span><span>Tarım Kalitesi</span>
      <span>Endüstriyel Kalite</span><span>Farmasötik Kalite</span><span>Çevre Kalitesi</span>
      <span>Sepiyolit Türkiye</span><span>Zamana</span><span>sepiolitemine.com</span>
    </div>
  </div>

  {/* HAKKIMIZDA */}
  <section id="about">
    <div class="container">
      <div class="grid-2">
        <div class="about-visual">
          <img
            src="/images/mine/cliff-800w.webp"
            srcset="/images/mine/cliff-400w.webp 400w, /images/mine/cliff-800w.webp 800w, /images/mine/cliff-1280w.webp 1280w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="Sepiyolit Madeni, Türkiye" width="1280" height="960" loading="lazy"/>
          <div class="about-visual-badge">
            <strong>Est. 1995</strong>
            <span>Zamana</span>
          </div>
        </div>
        <div>
          <div class="section-tag">Hikayemiz</div>
          <div class="divider"></div>
          <h2 class="section-title">Toprağa Köklenmiş,<br/>Dünyaya <span>Ulaşan</span></h2>
          <p class="section-subtitle">
            Sepiolite Mine, Türkiye'nin en zengin mineral yataklarının kalbinde faaliyet gösteren <strong>Zamana</strong>'in özel bir sepiyolit üretim ve ihracat bölümüdür. 50'den fazla ülkedeki müşterilerimize en yüksek kaliteli sepiyoliti maden, işleme ve teslimat zinciriyle sunuyoruz.
          </p>
          <p class="section-subtitle" style="margin-top:1rem;">
            Türkiye, dünyanın en büyük sepiyolit rezervlerine sahiptir; biz de bu kaynakların sorumlu koruyucuları olarak sürdürülebilir çıkarım, titiz kalite kontrol ve müşteri odaklı çözümler sunmaya kararlıyız.
          </p>
          <div class="about-features">
            <div class="about-feature">
              <div class="about-feature-icon">🏔️</div>
              <div class="about-feature-text">
                <strong>Birincil Yataklar</strong>
                <span>Türkiye'nin en zengin damarlarına doğrudan erişim</span>
              </div>
            </div>
            <div class="about-feature">
              <div class="about-feature-icon">🔬</div>
              <div class="about-feature-text">
                <strong>ISO Sertifikalı Lab</strong>
                <span>Her parti test edilmiş ve sertifikalandırılmıştır</span>
              </div>
            </div>
            <div class="about-feature">
              <div class="about-feature-icon">🌍</div>
              <div class="about-feature-text">
                <strong>Küresel Lojistik</strong>
                <span>Dünya genelinde dökme &amp; konteyner sevkiyatı</span>
              </div>
            </div>
            <div class="about-feature">
              <div class="about-feature-icon">♻️</div>
              <div class="about-feature-text">
                <strong>Çevre Dostu Madencilik</strong>
                <span>Sorumlu arazi restorasyon politikası</span>
              </div>
            </div>
          </div>
          <div class="akmin-badge">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L18 7V13L10 18L2 13V7L10 2Z" stroke="#C9922A" stroke-width="1.5" fill="none"/><circle cx="10" cy="10" r="3" fill="#C9922A"/></svg>
            <span>Zamana</span> bünyesinde bir bölüm
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ÜRÜNLER */}
  <section id="products">
    <div class="container">
      <div class="products-header">
        <div class="section-tag">Ürün Yelpazesi</div>
        <div class="divider divider--center"></div>
        <h2 class="section-title" style="text-align:center;">Premium <span>Sepiyolit</span> Ürünleri</h2>
        <p class="section-subtitle" style="text-align:center;margin:0 auto;">
          Ham cevherden hassas işlenmiş kalitelere; ürün yelpazemizin tamamı, hizmet verdiğimiz her sektörün tam özelliklerini karşılayacak şekilde tasarlanmıştır.
        </p>
      </div>
      <div class="grid-3">

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/raw-ore-400w.webp" alt="Ham Sepiyolit Cevheri" width="400" height="220" loading="lazy"/>
            <span class="product-card-tag">Ham Malzeme</span>
          </div>
          <div class="product-card-body">
            <h3>Ham Sepiyolit Cevheri</h3>
            <p>Doğal blok veya parça formunda doğrudan çıkarılmış sepiyolit. Kendi tesisinde işleme yapan müşteriler için idealdir. Yüksek saflık, rafine edilmemiş, doğal fiber yapısı korunmuş.</p>
            <div class="product-specs">
              <span class="product-spec">MgO ≥18%</span>
              <span class="product-spec">SiO₂ ≥54%</span>
              <span class="product-spec">Büyük Torbalar</span>
            </div>
            <a href="/tr/products/ham-sepiyolit-cevheri/" class="product-link">Detayları Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/granulated-400w.webp" alt="Granüle Sepiyolit" width="400" height="220" loading="lazy"/>
            <span class="product-card-tag">İşlenmiş</span>
          </div>
          <div class="product-card-body">
            <h3>Granüle Sepiyolit</h3>
            <p>Kedi kumu, tarım ve endüstriyel emici pazarlar için hassas boyutlandırılmış granüller. Kontrollü nem içeriğiyle 0–2mm, 2–4mm ve 4–8mm fraksiyonlarında mevcuttur.</p>
            <div class="product-specs">
              <span class="product-spec">0–8mm</span>
              <span class="product-spec">Düşük Toz</span>
              <span class="product-spec">Özel Boyut</span>
            </div>
            <a href="/tr/products/granule-sepiyolit/" class="product-link">Detayları Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/milled-powder-800w.webp" alt="Öğütülmüş Sepiyolit Tozu" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">İnce Kalite</span>
          </div>
          <div class="product-card-body">
            <h3>Öğütülmüş Sepiyolit Tozu</h3>
            <p>Boya, kaplama, ilaç ve kozmetik ürünler için ultra ince mikronize toz. 5–200 mikron aralığında kontrollü partikül dağılımı ve yüksek yüzey alanına sahiptir.</p>
            <div class="product-specs">
              <span class="product-spec">5–200μm</span>
              <span class="product-spec">Yüksek Yüzey</span>
              <span class="product-spec">Torba/BigBag</span>
            </div>
            <a href="/tr/products/ogutulmus-sepiyolit-tozu/" class="product-link">Detayları Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/drilling-grade-800w.webp" alt="Sondaj Kalitesi Sepiyolit" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">Petrol &amp; Gaz</span>
          </div>
          <div class="product-card-body">
            <h3>Sondaj Kalitesi Sepiyolit</h3>
            <p>Petrol ve gaz sondaj sıvısı uygulamaları için API uyumlu sepiyolit. Bentonitin yetersiz kaldığı tuzlu ve yüksek sıcaklık ortamlarında stabil reoloji sağlar.</p>
            <div class="product-specs">
              <span class="product-spec">API Spec 13A</span>
              <span class="product-spec">Tuz Dayanımlı</span>
              <span class="product-spec">50kg Torba</span>
            </div>
            <a href="/tr/products/sondaj-kalitesi-sepiyolit/" class="product-link">Detayları Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/agriculture-800w.webp" alt="Tarımsal Sepiyolit" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">Tarım</span>
          </div>
          <div class="product-card-body">
            <h3>Tarımsal Sepiyolit</h3>
            <p>Gübre, pestisit ve tohum kaplamaları için toprak düzenleyici ve taşıyıcı kalite. Toprak yapısını, su tutma kapasitesini ve besin iletimini iyileştirerek verimi artırır.</p>
            <div class="product-specs">
              <span class="product-spec">Toprak Kalitesi</span>
              <span class="product-spec">Taşıyıcı</span>
              <span class="product-spec">Eko Sertifikalı</span>
            </div>
            <a href="/tr/products/tarimsal-sepiyolit/" class="product-link">Detayları Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

        <div class="product-card">
          <div class="product-card-img">
            <img src="/images/products/construction-800w.webp" alt="İnşaat & Yalıtım Kalitesi Sepiyolit" width="800" height="440" loading="lazy"/>
            <span class="product-card-tag">İnşaat</span>
          </div>
          <div class="product-card-body">
            <h3>İnşaat &amp; Yalıtım Kalitesi</h3>
            <p>Yalıtım levhaları, harç ve yangına dayanıklı kaplamalar için düşük ısıl iletkenlikli sepiyolit. Çimento ve kireç bazlı ürünlerde işlenebilirliği ve dayanıklılığı artırır.</p>
            <div class="product-specs">
              <span class="product-spec">Düşük λ</span>
              <span class="product-spec">Yanmaz</span>
              <span class="product-spec">Dökme Teslimat</span>
            </div>
            <a href="/tr/products/insaat-yalitim-kalitesi/" class="product-link">Detayları Görüntüle <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* UYGULAMALAR */}
  <section id="applications" style="padding:6rem 0;background:var(--earth);">
    <div class="container">
      <div style="text-align:center;margin-bottom:3.5rem;">
        <div class="section-tag">Çözümler</div>
        <div class="divider divider--center"></div>
        <h2 class="section-title section-title--white">Sepiyolitin Sektörleri <span>Dönüştürdüğü</span> Alanlar</h2>
        <p class="section-subtitle section-subtitle--white" style="margin:0 auto;">
          Mineralimizin yüksek gözeneklilik, termal kararlılık ve kimyasal inerlik kombinasyonu, onu 15'ten fazla küresel sektörde vazgeçilmez kılmaktadır.
        </p>
      </div>
      <div class="app-grid">
        <div class="app-card">
          <div class="app-icon">🐾</div>
          <h3>Evcil Hayvan Bakımı &amp; Kedi Kumu</h3>
          <p>Üstün koku kontrolü ve nem emişi. Küresel ölçekte en hızlı büyüyen uygulama; sepiyolit, topaklanma ve hijyen açısından kil rakiplerini geride bırakır.</p>
          <ul class="app-list">
            <li>Topaklaşan &amp; topaklaşmayan kaliteler</li>
            <li>Koku nötralizasyonu</li>
            <li>Düşük dağılma, tozsuz</li>
            <li>Özel koku seçenekleri</li>
          </ul>
          <a href="/tr/applications/evcil-hayvan-kedi-kumu/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🌾</div>
          <h3>Tarım</h3>
          <p>Üstün su tutma, gübre ve pestisit taşıyıcılar ve besin biyoyararlanımını artıran hayvan yemi bağlayıcıları ile toprak bilimini dönüştürmek.</p>
          <ul class="app-list">
            <li>Toprak düzenleyici</li>
            <li>Gübre/pestisit taşıyıcısı</li>
            <li>Tohum kaplama bağlayıcısı</li>
            <li>Yem katkısı (akış ajanı)</li>
          </ul>
          <a href="/tr/applications/tarim/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🛢️</div>
          <h3>Petrol &amp; Gaz Sondajı</h3>
          <p>Doymuş tuzlu suda stabil reoloji koruyan tek mineral; dünya genelinde açık deniz ve yüksek tuzluluklu sondaj operasyonları için vazgeçilmez.</p>
          <ul class="app-list">
            <li>Tuz doymuş çamur sistemleri</li>
            <li>Yüksek sıcaklık kararlılığı</li>
            <li>Sızıntı absorbsiyonu</li>
            <li>API 13A uyumlu</li>
          </ul>
          <a href="/tr/applications/petrol-gaz-sondaj/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🏗️</div>
          <h3>İnşaat</h3>
          <p>Harç, sıva ve betonda termal yalıtım, yangın direnci ve gelişmiş işlenebilirlik; daha güvenli, daha güçlü ve daha verimli yapılar.</p>
          <ul class="app-list">
            <li>Yalıtım tuğlası &amp; levhalar</li>
            <li>Kireç harç katkısı</li>
            <li>Reoloji düzenleyici</li>
            <li>Yangına dayanıklı kaplamalar</li>
          </ul>
          <a href="/tr/applications/insaat/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🌿</div>
          <h3>Çevre Rehabilitasyonu</h3>
          <p>Kirliliğe doğal bir çözüm. Sepiyolitin benzersiz adsorpsiyon kapasitesi, onu atık su arıtma, ağır metal tutma ve petrol sızıntısı müdahalesi için ideal kılar.</p>
          <ul class="app-list">
            <li>Atık su arıtma</li>
            <li>Ağır metal uzaklaştırma</li>
            <li>Petrol sızıntısı temizliği</li>
            <li>Hava arıtma ortamı</li>
          </ul>
          <a href="/tr/applications/cevre-rehabilitasyon/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🎨</div>
          <h3>Boya &amp; Kaplamalar</h3>
          <p>Su bazlı ve solvent bazlı boyalarda reoloji düzenleyici, sarkma önleyici ve mat verici ajan olarak görev yapar; opaklığı korurken dokuyu iyileştirir.</p>
          <ul class="app-list">
            <li>Çökelme önleyici ajan</li>
            <li>Tiksotropik katkı</li>
            <li>Matlık etkisi</li>
            <li>Gelişmiş fırçalanabilirlik</li>
          </ul>
          <a href="/tr/applications/boya-kaplama/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">⚗️</div>
          <h3>Kataliz &amp; Kimya</h3>
          <p>Yüksek yüzey alanı ve termal kararlılık, sepiyoliti hidrojenasyon, dehidrojenasyon ve oksidasyon reaksiyonları için olağanüstü bir katalizör taşıyıcısı yapar.</p>
          <ul class="app-list">
            <li>Katalizör taşıyıcısı</li>
            <li>Zeolit alternatifi</li>
            <li>Yüksek sıcaklık reaksiyonları</li>
            <li>Seçicilik artırımı</li>
          </ul>
          <a href="/tr/applications/kataliz-kimya/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">💊</div>
          <h3>İlaç &amp; Kozmetik</h3>
          <p>GRAS listesinde yer alan ve biyouyumlu sepiyolit; farmasötik formülasyonlarda, yüz maskelerinde ve kişisel bakım ürünlerinde eksipiyan, kıvamlaştırıcı ve taşıyıcı olarak kullanılır.</p>
          <ul class="app-list">
            <li>Tablet eksipiyanı</li>
            <li>Kozmetik kıvamlaştırıcı</li>
            <li>Yüz maskesi doldurucu</li>
            <li>İlaç iletim taşıyıcısı</li>
          </ul>
          <a href="/tr/applications/ilac-kozmetik/" class="app-link-home">Daha Fazla →</a>
        </div>
        <div class="app-card">
          <div class="app-icon">🌱</div>
          <h3>Biyoplastikler (Gelişmekte)</h3>
          <p>Sürdürülebilirlik inovasyonu yönlendirdikçe, sepiyolit nano fiberler biyobozunabilir polimerleri güçlendirerek mekanik dayanımı artırırken kompostlanabilirliği korur.</p>
          <ul class="app-list">
            <li>PLA / PHA güçlendirme</li>
            <li>Nano doldurucu</li>
            <li>Kompostlanabilir uyumlu</li>
            <li>Bariyer iyileştirme</li>
          </ul>
