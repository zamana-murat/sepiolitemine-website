---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const products = (await getCollection('products', (p) => p.data.locale === 'tr' && !p.data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const apps = (await getCollection('applications', (a) => a.data.locale === 'tr' && !a.data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const description =
  "Premium Türk sepiyolit tedarikçisi. Tarım, petrol ve gaz sondajı, inşaat, kedi kumu ve global endüstriyel pazarlar için ham ve işlenmiş sepiyolit. 1995'ten beri B2B tedarik.";
---

<Layout
  title="Premium Türk Sepiyolit Tedarikçisi"
  description={description}
  alternates={{ en: '/', tr: '/tr/' }}
  locale="tr"
  noSuffix={true}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/mine/aerial-02-800w.webp" fetchpriority="high" />
  </Fragment>

  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="section-tag">Endüstriyel Sepiyolit · Türkiye</span>
      <h1>Premium Türk Sepiyolit Tedarikçisi</h1>
      <p class="lead">
        Tarım, petrol ve gaz sondajı, inşaat, kedi kumu ve global endüstriyel pazarlar
        için ham ve işlenmiş sepiyolit. Madenden limana doğrudan tedarik, sadece B2B.
      </p>
      <div class="hero-actions">
        <a href="/tr/contact/" class="btn btn-primary">Teklif İste</a>
        <a href="/tr/products/" class="btn btn-outline">Ürünleri İncele</a>
      </div>
    </div>
  </section>

  <section class="trust-strip">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item">
          <strong>%70</strong>
          <span>Küresel sepiyolit rezervi Türkiye'de</span>
        </div>
        <div class="trust-item">
          <strong>1995</strong>
          <span>Faaliyet başlangıcı</span>
        </div>
        <div class="trust-item">
          <strong>50+</strong>
          <span>İhracat ülkesi</span>
        </div>
        <div class="trust-item">
          <strong>%99+</strong>
          <span>Tipik saflık derecesi</span>
        </div>
      </div>
    </div>
  </section>

  <section class="products-section section">
    <div class="container">
      <header class="section-header">
        <span class="section-tag">Ürünler</span>
        <div class="divider"></div>
        <h2>Altı Kademe, Tek Maden</h2>
        <p>Ham cevherden mikronize toza, sondaj kalitesinden tarımsal taşıyıcıya, her kademe kendi tesisimizde işlenir ve kalite kontrolünden geçer.</p>
      </header>
      <div class="products-grid">
        {products.map((p) => (
          <a href={`/tr/products/${p.slug}/`} class="product-card">
            <div class="card-img">
              <img src={p.data.heroImage} alt={p.data.heroImageAlt} width="400" height="300" loading="lazy" />
            </div>
            <div class="card-body">
              <h3>{p.data.title}</h3>
              <p>{p.data.tagline}</p>
              <span class="card-link">Detayları gör →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="apps-section section section--dark">
    <div class="container">
      <header class="section-header centered">
        <span class="section-tag">Uygulamalar</span>
        <div class="divider divider--center"></div>
        <h2>Sepiyolit Hangi Sektörlerde Değer Katıyor</h2>
        <p>Dokuz sektör; emicilik, reoloji, kontrollü salınım ve yapısal performans için sepiyolite güvenir.</p>
      </header>
      <div class="apps-grid">
        {apps.map((a) => (
          <a href={`/tr/applications/${a.slug}/`} class="app-tile">
            <span class="app-name">{a.data.title}</span>
            <span class="app-arrow">→</span>
          </a>
        ))}
      </div>
      <div class="apps-cta">
        <a href="/tr/applications/" class="btn btn-outline">Tüm Uygulamalar</a>
      </div>
    </div>
  </section>

  <section class="why-section section">
    <div class="container">
      <header class="section-header centered">
        <span class="section-tag">Neden Sepiolite Mine</span>
        <div class="divider divider--center"></div>
        <h2>Direkt Maden, Direkt Tedarik</h2>
      </header>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-num">01</div>
          <h3>Dünyanın En Yüksek Saflığı</h3>
          <p>Eskişehir ve Sivrihisar yatakları sürekli %99+ saflık verir; küresel kıyaslama değeri.</p>
        </div>
        <div class="why-card">
          <div class="why-num">02</div>
          <h3>Maden-Liman Kontrolü</h3>
          <p>Çıkartmadan FOB teslimine tüm zincirin sahibi biziz. Aracı yok, kalite boşluğu yok.</p>
        </div>
        <div class="why-card">
          <div class="why-num">03</div>
          <h3>ISO Sertifikalı Kalite</h3>
          <p>Her parti yerleşik laboratuvarımızda test edilir. Her sevkiyatta tam Analiz Sertifikası.</p>
        </div>
        <div class="why-card">
          <div class="why-num">04</div>
          <h3>Ölçeklenebilir Tedarik</h3>
          <p>Tek 20 MT konteynerden tam gemi yüklerine. Uzun vadeli sözleşmeler memnuniyetle.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="final-cta section section--dark">
    <div class="container container-narrow">
      <h2>Sepiyolit ihtiyacınızı konuşmaya hazır mısınız?</h2>
      <p>Spesifikasyon, hedef hacim ve varış noktanızı paylaşın. 24 saat içinde yanıtlıyoruz.</p>
      <a href="/tr/contact/" class="btn btn-primary">Teklif İste</a>
    </div>
  </section>
</Layout>

<style>
  .hero { position: relative; min-height: 70vh; display: flex; align-items: center; overflow: hidden; background: var(--c-earth); padding-block: var(--s-7); }
  .hero-bg { position: absolute; inset: 0; background: url('/images/mine/aerial-02-800w.webp') center/cover no-repeat; opacity: 0.55; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(28, 20, 16, 0.78), rgba(46, 33, 24, 0.55)); }
  .hero-content { position: relative; z-index: 1; max-width: 720px; }
  .hero .section-tag { color: var(--c-gold); }
  .hero h1 { color: var(--c-white); margin-bottom: var(--s-3); }
  .hero .lead { font-size: 1.15rem; color: var(--c-text-light); line-height: 1.7; margin-bottom: var(--s-5); }
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--s-3); }
  .trust-strip { background: var(--c-cream); border-bottom: 1px solid var(--c-cream-dark); padding-block: var(--s-5); }
  .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: var(--s-4); text-align: center; }
  .trust-item strong { display: block; font-family: var(--font-serif); font-size: 2.2rem; font-weight: 800; color: var(--c-gold-dark); line-height: 1; margin-bottom: var(--s-2); }
  .trust-item span { font-size: 0.9rem; color: var(--c-text-muted); line-height: 1.5; }
  .section-header { margin-bottom: var(--s-6); max-width: 640px; }
  .section-header.centered { text-align: center; margin-inline: auto; }
  .section-header h2 { margin-block: var(--s-2) var(--s-3); }
  .section-header p { font-size: 1.05rem; color: var(--c-text-muted); line-height: 1.7; margin: 0; }
  .section--dark .section-header p { color: var(--c-text-light); }
  .divider--center { margin-inline: auto; }
  .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--s-4); }
  .product-card { background: var(--c-white); border: 1px solid var(--c-cream-dark); border-radius: var(--r-card); overflow: hidden; text-decoration: none; color: var(--c-text); display: flex; flex-direction: column; transition: border-color var(--t), transform var(--t), box-shadow var(--t); }
  .product-card:hover { border-color: var(--c-gold); transform: translateY(-4px); box-shadow: var(--sh-mid); text-decoration: none; }
  .product-card .card-img { aspect-ratio: 4 / 3; overflow: hidden; background: var(--c-cream); }
  .product-card .card-img img { width: 100%; height: 100%; object-fit: cover; }
  .product-card .card-body { padding: var(--s-4); flex: 1; display: flex; flex-direction: column; gap: var(--s-2); }
  .product-card h3 { font-size: 1.15rem; margin: 0; }
  .product-card p { font-size: 0.9rem; color: var(--c-text-muted); line-height: 1.6; margin: 0; flex: 1; }
  .product-card .card-link { color: var(--c-gold-dark); font-weight: 600; font-size: 0.9rem; margin-top: var(--s-2); }
  .apps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--s-3); }
  .app-tile { background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r-input); padding: var(--s-4); text-decoration: none; color: var(--c-text-light); display: flex; justify-content: space-between; align-items: center; gap: var(--s-3); transition: border-color var(--t), background var(--t); }
  .app-tile:hover { border-color: var(--c-gold); background: rgba(201, 146, 42, 0.08); color: var(--c-white); text-decoration: none; }
  .app-name { font-weight: 500; font-size: 0.95rem; }
  .app-arrow { color: var(--c-gold); font-size: 1.1rem; }
  .apps-cta { text-align: center; margin-top: var(--s-5); }
  .why-section { background: var(--c-cream); }
  .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--s-4); }
  .why-card { background: var(--c-white); border: 1px solid var(--c-cream-dark); border-radius: var(--r-card); padding: var(--s-5); }
  .why-num { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 800; color: var(--c-gold); line-height: 1; margin-bottom: var(--s-3); }
  .why-card h3 { font-size: 1.1rem; margin-bottom: var(--s-2); color: var(--c-earth); }
  .why-card p { font-size: 0.92rem; color: var(--c-text-muted); line-height: 1.7; margin: 0; }
  .final-cta { text-align: center; }
  .final-cta h2 { color: var(--c-white); margin-bottom: var(--s-3); }
  .final-cta p { color: var(--c-text-light); margin-bottom: var(--s-4); font-size: 1.05rem; }
</style>
