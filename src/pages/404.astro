---
import Layout from '@layouts/Layout.astro';
import { BRAND } from '@config/brand';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<Layout
  title="Page Not Found – 404"
  description="The page you are looking for could not be found. Return to the Sepiolite Mine homepage or explore our products and services."
  locale="en"
>
<!-- ===== HEADER ===== -->
  <header class="error-header">
    <div class="header-inner">
      <a href="/" class="logo-link" aria-label="Sepiolite Mine – Home">
        <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="22" cy="22" r="20.5" fill="rgba(201,146,42,0.12)" stroke="#C9922A" stroke-width="1.5"/>
          <path d="M6,34 L14,12 L19,18 L23,11 L28,34 Z" fill="#C9922A" opacity="0.25"/>
          <path d="M6,34 L14,12 L19,18 L23,11 L28,34" stroke="#C9922A" stroke-width="1.5" stroke-linejoin="round" fill="none"/>
          <line x1="23" y1="11" x2="25.5" y2="19" stroke="#C9922A" stroke-width="0.8" stroke-linecap="round" opacity="0.55"/>
          <rect x="29.5" y="18" width="7" height="16" fill="#C9922A" opacity="0.18"/>
          <rect x="29.5" y="18" width="7" height="16" stroke="#C9922A" stroke-width="1.3" fill="none"/>
          <path d="M29,18 Q33,13 37,18 Z" fill="#C9922A" opacity="0.28"/>
          <path d="M29,18 Q33,13 37,18" stroke="#C9922A" stroke-width="1.3" fill="none"/>
          <line x1="33" y1="13" x2="33" y2="9.5" stroke="#C9922A" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="33" cy="8.5" r="1.2" fill="#C9922A" opacity="0.55"/>
          <circle cx="34.2" cy="7.2" r="0.75" fill="#C9922A" opacity="0.3"/>
          <line x1="29.5" y1="22.5" x2="26" y2="22.5" stroke="#C9922A" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="26" cy="22.5" r="0.9" fill="#C9922A" opacity="0.55"/>
          <line x1="29.5" y1="28" x2="27" y2="28" stroke="#C9922A" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="27" cy="28" r="0.9" fill="#C9922A" opacity="0.55"/>
          <line x1="5" y1="34" x2="39" y2="34" stroke="#C9922A" stroke-width="1" stroke-linecap="round" opacity="0.35"/>
        </svg>
        <div class="logo-text">
          <span class="logo-main">Sepiolite Mine</span>
          <span class="logo-sub">by Zamana</span>
        </div>
      </a>
      <div class="header-nav">
        <a href="/">Home</a>
        <a href="/products/">Products</a>
        <a href="/contact/">Contact</a>
      </div>
    </div>
  </header>

  <!-- ===== MAIN ===== -->
  <main class="error-main">
    <div class="error-content">
      <div class="error-code">404</div>
      <h1 class="error-title">Page <span>Not Found</span></h1>
      <p class="error-desc">The page you are looking for may have been moved, removed, or does not exist. Please check the URL or navigate back to our main pages.</p>
      <div class="error-actions">
        <a href="/" class="btn btn-primary">Back to Homepage</a>
        <a href="/contact/" class="btn btn-outline">Contact Us</a>
      </div>
      <div class="error-links">
        <p>Or try one of these pages:</p>
        <div class="error-links-list">
          <a href="/products/">Products</a>
          <a href="/applications/">Applications</a>
          <a href="/markets/">Global Markets</a>
          <a href="/sustainability/">Sustainability</a>
        </div>
      </div>
    </div>
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="error-footer">
    <p>&copy; <script>document.write(new Date().getFullYear())</script> Sepiolite Mine &middot; A division of <a href="https://zamana.com.tr" target="_blank" rel="noopener noreferrer">Zamana</a> &middot; <a href="/privacy.html">Privacy</a> &middot; <a href="/terms.html">Terms</a></p>
  </footer>
</Layout>

<style is:global>
/* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; height: 100%; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #1a1a1a; background: #1C1410; overflow-x: hidden; min-height: 100%; display: flex; flex-direction: column; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }

    /* ===== DESIGN TOKENS ===== */
    :root {
      --gold:        #C9922A;
      --gold-light:  #E8B84B;
      --gold-dark:   #9A6E1A;
      --earth:       #1C1410;
      --earth-mid:   #2E2118;
      --earth-soft:  #3D2E1E;
      --stone:       #7A6652;
      --stone-light: #B8A898;
      --cream:       #F7F3EE;
      --cream-dark:  #EDE6DC;
      --white:       #FFFFFF;
      --transition:  0.35s cubic-bezier(0.4,0,0.2,1);
    }

    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--earth); }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

    /* ===== HEADER ===== */
    .error-header {
      background: rgba(28,20,16,0.97);
      border-bottom: 1px solid rgba(201,146,42,0.15);
      padding: 0;
    }
    .error-header .header-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }
    .logo-link {
      display: flex;
      align-items: center;
      gap: 0.65rem;
    }
    .logo-link svg { width: 36px; height: 36px; flex-shrink: 0; }
    .logo-text { display: flex; flex-direction: column; }
    .logo-main { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--white); line-height: 1; }
    .logo-sub { font-size: 0.58rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-top: 2px; }
    .header-nav { display: flex; align-items: center; gap: 1.5rem; }
    .header-nav a { font-size: 0.82rem; font-weight: 500; color: rgba(255,255,255,0.7); transition: color 0.25s ease; }
    .header-nav a:hover { color: var(--white); }

    /* ===== MAIN CONTENT ===== */
    .error-main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 4rem 2rem;
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, var(--earth) 0%, var(--earth-mid) 50%, var(--earth-soft) 100%);
    }
    .error-main::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% 40%, rgba(201,146,42,0.06) 0%, transparent 70%);
    }
    .error-content {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 600px;
    }
    .error-code {
      font-family: 'Playfair Display', serif;
      font-size: clamp(5rem, 15vw, 10rem);
      font-weight: 800;
      color: rgba(201,146,42,0.15);
      line-height: 1;
      margin-bottom: -0.5rem;
      letter-spacing: -0.02em;
    }
    .error-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      color: var(--white);
      margin-bottom: 1rem;
      line-height: 1.15;
    }
    .error-title span { color: var(--gold); }
    .error-desc {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.7;
      margin-bottom: 2.5rem;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }
    .error-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.85rem 2rem;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      transition: var(--transition);
      font-family: 'Inter', system-ui, sans-serif;
      cursor: pointer;
    }
    .btn-primary { background: var(--gold); color: var(--earth); }
    .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(201,146,42,0.38); }
    .btn-outline { border: 2px solid rgba(201,146,42,0.5); color: var(--gold); background: transparent; }
    .btn-outline:hover { background: var(--gold); color: var(--earth); border-color: var(--gold); }

    .error-links {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .error-links p {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.4);
      margin-bottom: 0.75rem;
    }
    .error-links-list {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .error-links-list a {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.55);
      transition: color 0.25s ease;
      position: relative;
    }
    .error-links-list a:hover { color: var(--gold-light); }
    .error-links-list a::after {
      content: '';
      position: absolute;
      bottom: -3px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--gold);
      transition: width 0.3s ease;
    }
    .error-links-list a:hover::after { width: 100%; }

    /* ===== FOOTER ===== */
    .error-footer {
      background: var(--earth);
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 1.5rem 2rem;
      text-align: center;
    }
    .error-footer p {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.3);
    }
    .error-footer a {
      color: rgba(255,255,255,0.4);
      transition: color 0.2s ease;
    }
    .error-footer a:hover { color: var(--gold); }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .header-nav { display: none; }
      .error-main { padding: 3rem 1.5rem; }
      .error-actions { flex-direction: column; align-items: center; }
      .btn { width: 100%; max-width: 280px; justify-content: center; }
    }
</style>
