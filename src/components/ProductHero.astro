---
/**
 * ProductHero.astro — Ürün detay hero (gallery + info)
 *
 * B2 — Fiyat görünmez. Eski sitedeki price-box yerine "Request Quote" CTA.
 */
import type { CollectionEntry } from 'astro:content';

export interface Props {
  product: CollectionEntry<'products'>['data'];
  locale: 'en' | 'tr';
  contactHref: string;
}

const { product, locale, contactHref } = Astro.props;
const isTr = locale === 'tr';

const labels = isTr
  ? { quote: 'Teklif İste', sample: 'Numune İste', specs: 'Hızlı Özellikler' }
  : { quote: 'Request Quote', sample: 'Request Sample', specs: 'Key Specs' };
---

<section class="product-hero">
  <div class="container">
    <div class="hero-grid">
      <div class="gallery">
        <div class="main-img">
          <img
            src={product.heroImage}
            alt={product.heroImageAlt}
            width="800"
            height="600"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        {product.gallery.length > 0 && (
          <div class="thumbs">
            {product.gallery.map((g) => (
              <div class="thumb">
                <img src={g.image} alt={g.alt} width="120" height="120" loading="lazy" />
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="info">
        {product.badge && <span class="badge">{product.badge}</span>}
        <h1>
          {product.titleAccent ? (
            <>
              {product.title.replace(product.titleAccent, '').trim()}{' '}
              <em>{product.titleAccent}</em>
            </>
          ) : (
            product.title
          )}
        </h1>
        <p class="tagline">{product.tagline}</p>

        {product.keySpecs.length > 0 && (
          <div class="key-specs">
            {product.keySpecs.map((s) => (
              <div class="key-spec">
                <div class="value">{s.value}</div>
                <div class="label">{s.label}</div>
              </div>
            ))}
          </div>
        )}

        {/* B2 — Fiyat görünmez, "Request Quote" CTA */}
        <div class="cta-box">
          <p class="cta-headline">
            {isTr
              ? 'Toplu sipariş için size özel teklif hazırlayalım.'
              : 'Get a tailored bulk quote for your requirements.'}
          </p>
          <div class="cta-actions">
            <a href={contactHref} class="btn btn-primary">{labels.quote}</a>
            <a href={contactHref} class="btn btn-outline-dark">{labels.sample}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .product-hero {
    padding-block: var(--s-7) var(--s-7);
    background: var(--c-cream);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-6);
    align-items: start;
  }

  .gallery {
    position: sticky;
    top: 5rem;
  }

  .main-img {
    border-radius: var(--r-card);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--c-white);
    box-shadow: var(--sh-mid);
    border: 1px solid var(--c-cream-dark);
  }

  .main-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumbs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-2);
    margin-top: var(--s-3);
  }

  .thumb {
    border-radius: var(--r-input);
    overflow: hidden;
    aspect-ratio: 1;
    border: 2px solid transparent;
    background: var(--c-white);
    cursor: pointer;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }

  .thumb:hover {
    border-color: var(--c-gold);
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info {
    display: flex;
    flex-direction: column;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    background: rgba(201, 146, 42, 0.14);
    border: 1px solid rgba(201, 146, 42, 0.35);
    color: var(--c-gold-dark);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.4rem 0.9rem;
    border-radius: 100px;
    margin-bottom: var(--s-3);
    align-self: flex-start;
  }

  .badge::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--c-gold);
    border-radius: 50%;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1.12;
    color: var(--c-earth);
    margin-bottom: var(--s-3);
  }

  h1 em {
    font-style: italic;
    color: var(--c-gold);
  }

  .tagline {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--c-text-muted);
    margin-bottom: var(--s-5);
    max-width: 520px;
  }

  .key-specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-3);
    margin-bottom: var(--s-5);
  }

  .key-spec {
    background: var(--c-white);
    border: 1px solid var(--c-cream-dark);
    border-radius: var(--r-input);
    padding: var(--s-3);
    text-align: center;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }

  .key-spec:hover {
    border-color: var(--c-gold);
    box-shadow: var(--sh-soft);
  }

  .key-spec .value {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--c-gold);
    line-height: 1;
  }

  .key-spec .label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-stone);
    margin-top: 0.35rem;
  }

  .cta-box {
    background: linear-gradient(135deg, var(--c-earth) 0%, var(--c-earth-mid) 100%);
    border-radius: var(--r-card);
    padding: var(--s-5);
    color: var(--c-text-light);
  }

  .cta-headline {
    font-size: 1rem;
    color: var(--c-white);
    margin-bottom: var(--s-3);
    font-weight: 500;
  }

  .cta-actions {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .cta-actions .btn {
    flex: 1;
    min-width: 140px;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .gallery {
      position: relative;
      top: 0;
    }
  }

  @media (max-width: 480px) {
    .key-specs {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
