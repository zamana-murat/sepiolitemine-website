---
/**
 * Header.astro — Fixed dark transparent navbar with backdrop blur
 * Ported 1:1 from legacy js/include.js HEADER_EN / HEADER_TR.
 * Brand-aware logo SVG (mineral motif), language dropdown, CTA.
 */
import { BRAND } from '@config/brand';

export interface Props {
  locale: 'en' | 'tr';
  currentPath?: string;
}

const { locale, currentPath = Astro.url.pathname } = Astro.props;
const isTr = locale === 'tr';
const prefix = isTr ? '/tr' : '';

const labels = isTr
  ? {
      home: 'Ana Sayfa',
      about: 'Hakkımızda',
      products: 'Ürünler',
      applications: 'Uygulamalar',
      markets: 'Pazarlar',
      sustainability: 'Sürdürülebilirlik',
      contact: 'İletişim',
      cta: 'Teklif Alın',
      langOther: 'EN',
      langOtherHref: currentPath.replace(/^\/tr\//, '/').replace(/^\/tr$/, '/'),
      langCurrent: 'TR',
      navAria: 'Ana gezinme',
      logoAria: 'Sepiolite Mine — Ana Sayfa',
      hamAria: 'Gezinme menüsünü aç/kapat',
    }
  : {
      home: 'Home',
      about: 'About',
      products: 'Products',
      applications: 'Applications',
      markets: 'Markets',
      sustainability: 'Sustainability',
      contact: 'Contact',
      cta: 'Get a Quote',
      langOther: 'TR',
      langOtherHref: currentPath === '/' ? '/tr/' : `/tr${currentPath}`,
      langCurrent: 'EN',
      navAria: 'Main navigation',
      logoAria: 'Sepiolite Mine — Home',
      hamAria: 'Toggle navigation menu',
    };

const homeHref = isTr ? '/tr/' : '/';
const aboutHref = `${homeHref}#about`;
const productsHref = `${prefix}/products/`;
const applicationsHref = `${prefix}/applications/`;
const marketsHref = `${prefix}/markets/`;
const sustainabilityHref = `${prefix}/sustainability/`;
const contactHref = `${prefix}/contact/`;
---

<nav id="navbar" role="navigation" aria-label={labels.navAria}>
  <div class="container">
    <div class="nav-inner">
      <a href={homeHref} class="nav-logo" aria-label={labels.logoAria}>
        <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <circle cx="22" cy="22" r="20.5" fill="rgba(201,146,42,0.12)" stroke="#C9922A" stroke-width="1.5"/>
          <path d="M6,34 L14,12 L19,18 L23,11 L28,34 Z" fill="#C9922A" opacity="0.25"/>
          <path d="M6,34 L14,12 L19,18 L23,11 L28,34" stroke="#C9922A" stroke-width="1.5" stroke-linejoin="round" fill="none"/>
          <line x1="23" y1="11" x2="25.5" y2="19" stroke="#C9922A" stroke-width="0.8" stroke-linecap="round" opacity="0.55"/>
          <rect x="29.5" y="18" width="7" height="16" fill="#C9922A" opacity="0.18"/>
          <rect x="29.5" y="18" width="7" height="16" stroke="#C9922A" stroke-width="1.3" fill="none"/>
          <path d="M29,18 Q33,13 37,18 Z" fill="#C9922A" opacity="0.28"/>
          <path d="M29,18 Q33,13 37,18" stroke="#C9922A" stroke-width="1.3" fill="none"/>
          <line x1="33" y1="13" x2="33" y2="9.5" stroke="#C9922A" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="33" cy="8.5" r="1.2" fill="#C9922A" opacity="0.55"/>
          <circle cx="34.2" cy="7.2" r="0.75" fill="#C9922A" opacity="0.3"/>
          <line x1="29.5" y1="22.5" x2="26" y2="22.5" stroke="#C9922A" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="26" cy="22.5" r="0.9" fill="#C9922A" opacity="0.55"/>
          <line x1="29.5" y1="28" x2="27" y2="28" stroke="#C9922A" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="27" cy="28" r="0.9" fill="#C9922A" opacity="0.55"/>
          <line x1="5" y1="34" x2="39" y2="34" stroke="#C9922A" stroke-width="1" stroke-linecap="round" opacity="0.35"/>
        </svg>
        <div class="nav-logo-text">
          <span class="nav-logo-main">{BRAND.name}</span>
          <span class="nav-logo-sub">by Akmin Mining</span>
        </div>
      </a>

      <div class="nav-links" id="navLinks" role="list">
        <a href={aboutHref} role="listitem">{labels.about}</a>
        <a href={productsHref} role="listitem" class:list={[{ active: currentPath.startsWith(productsHref) }]}>{labels.products}</a>
        <a href={applicationsHref} role="listitem" class:list={[{ active: currentPath.startsWith(applicationsHref) }]}>{labels.applications}</a>
        <a href={marketsHref} role="listitem" class:list={[{ active: currentPath.startsWith(marketsHref) }]}>{labels.markets}</a>
        <a href={sustainabilityHref} role="listitem" class:list={[{ active: currentPath.startsWith(sustainabilityHref) }]}>{labels.sustainability}</a>
        <a href={contactHref} role="listitem" class:list={[{ active: currentPath.startsWith(contactHref) }]}>{labels.contact}</a>
      </div>

      <div class="nav-cta">
        <div class="lang-selector" role="navigation" aria-label={isTr ? 'Dil seçici' : 'Language selector'}>
          <button class="lang-btn" aria-haspopup="listbox" aria-expanded="false">
            <span class="lang-flag">{labels.langCurrent}</span>
            <svg class="lang-chevron" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
              <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            </svg>
          </button>
          <ul class="lang-dropdown" role="listbox">
            <li role="option" aria-selected={!isTr} data-lang="en">
              <a href={isTr ? labels.langOtherHref : currentPath} hreflang="en">EN</a>
            </li>
            <li role="option" aria-selected={isTr} data-lang="tr">
              <a href={!isTr ? labels.langOtherHref : currentPath} hreflang="tr">TR</a>
            </li>
          </ul>
        </div>
        <a href={contactHref} class="btn-nav-cta">{labels.cta}</a>
      </div>

      <button class="hamburger" id="hamburger" aria-label={labels.hamAria} aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
    <nav>
      <a href={aboutHref}>{labels.about}</a>
      <a href={productsHref}>{labels.products}</a>
      <a href={applicationsHref}>{labels.applications}</a>
      <a href={marketsHref}>{labels.markets}</a>
      <a href={sustainabilityHref}>{labels.sustainability}</a>
      <a href={contactHref}>{labels.contact}</a>
      <a href={contactHref} class="btn-nav-cta" style="text-align:center;margin-top:0.5rem;">{labels.cta}</a>
    </nav>
    <div style="display:flex;justify-content:center;gap:1rem;margin-top:1rem;padding-top:0.75rem;border-top:1px solid rgba(255,255,255,0.1);">
      <a href={isTr ? labels.langOtherHref : currentPath} style={`font-size:0.82rem;color:${!isTr ? 'var(--gold)' : 'rgba(255,255,255,0.55)'};font-weight:600;`}>EN</a>
      <span style="color:rgba(255,255,255,0.2);">|</span>
      <a href={!isTr ? labels.langOtherHref : currentPath} style={`font-size:0.82rem;color:${isTr ? 'var(--gold)' : 'rgba(255,255,255,0.55)'};font-weight:600;`}>TR</a>
    </div>
  </div>
</nav>

<script>
  // Lang dropdown toggle
  const langBtn = document.querySelector<HTMLButtonElement>('.lang-btn');
  const langDropdown = document.querySelector<HTMLElement>('.lang-dropdown');
  if (langBtn && langDropdown) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const expanded = langBtn.getAttribute('aria-expanded') === 'true';
      langBtn.setAttribute('aria-expanded', String(!expanded));
      langDropdown.classList.toggle('open');
    });
    document.addEventListener('click', () => {
      langBtn.setAttribute('aria-expanded', 'false');
      langDropdown.classList.remove('open');
    });
  }

  // Sticky navbar scroll class
  const navbar = document.getElementById('navbar');
  if (navbar) {
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });
  }

  // Mobile hamburger toggle
  document.addEventListener('click', (e) => {
    const ham = (e.target as Element).closest('#hamburger');
    if (ham) {
      const menu = document.getElementById('mobileMenu');
      const isOpen = menu?.classList.toggle('open');
      ham.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      if (menu) menu.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
    }
    if ((e.target as Element).closest('#mobileMenu a')) {
      const menu = document.getElementById('mobileMenu');
      const ham = document.getElementById('hamburger');
      if (menu) { menu.classList.remove('open'); menu.setAttribute('aria-hidden', 'true'); }
      if (ham) ham.setAttribute('aria-expanded', 'false');
    }
  });
</script>
