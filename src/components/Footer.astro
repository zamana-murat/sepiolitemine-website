---
/**
 * Footer.astro — Footer CTA + 3-column site-footer
 * Ported 1:1 from legacy js/include.js FOOTER_EN / FOOTER_TR.
 * C4: no mailto: anywhere — email icon links to contact form.
 */
import { BRAND } from '@config/brand';

export interface Props {
  locale: 'en' | 'tr';
}

const { locale } = Astro.props;
const isTr = locale === 'tr';
const prefix = isTr ? '/tr' : '';
const homeHref = isTr ? '/tr/' : '/';

const labels = isTr
  ? {
      ctaHeading: 'Dünyanın En Kaliteli Sepiyolitini Tedarik Etmeye Hazır mısınız?',
      ctaBody: 'Numune, teknik özellikler ve sektörünüze özel rekabetçi fiyatlandırma için teknik satış ekibimizle bugün iletişime geçin.',
      ctaContact: 'Satış Ekibiyle İletişime Geçin',
      ctaProducts: 'Tüm Ürünleri Görüntüle',
      brandTagline: "1995'ten bu yana küresel endüstrilere premium ham ve işlenmiş mineral ürünleri sunan Türkiye'nin önde gelen sepiyolit üreticisi.",
      products: 'Ürünler',
      applications: 'Uygulamalar',
      company: 'Şirket',
      about: 'Hakkımızda',
      sustainability: 'Sürdürülebilirlik',
      markets: 'Küresel Pazarlar',
      contact: 'İletişim',
      copyright: '· sepiolitemine.com · Tüm hakları saklıdır Murat Özsaygılı - Zamana.',
      privacy: 'Gizlilik Politikası',
      terms: 'Kullanım Şartları',
      sitemap: 'Site Haritası',
      logoAria: 'Sepiolite Mine - Ana Sayfa',
      emailAria: 'İletişim formuna git',
      phoneAria: 'Bizi arayın',
    }
  : {
      ctaHeading: "Ready to Source the World's Finest Sepiolite?",
      ctaBody: 'Contact our technical sales team today for samples, specifications, and competitive pricing tailored to your industry.',
      ctaContact: 'Contact Sales Team',
      ctaProducts: 'View All Products',
      brandTagline: "Turkey's premier sepiolite producer serving global industries with premium raw and processed mineral products since 1995.",
      products: 'Products',
      applications: 'Applications',
      company: 'Company',
      about: 'About Us',
      sustainability: 'Sustainability',
      markets: 'Global Markets',
      contact: 'Contact',
      copyright: '· sepiolitemine.com · All rights reserved by Murat Ozsaygili - Zamana.',
      privacy: 'Privacy Policy',
      terms: 'Terms of Use',
      sitemap: 'Sitemap',
      logoAria: 'Sepiolite Mine — Home',
      emailAria: 'Go to contact form',
      phoneAria: 'Call us',
    };

const productLinks = isTr
  ? [
      { href: '/tr/products/ham-sepiyolit-cevheri/', label: 'Ham Sepiyolit Cevheri' },
      { href: '/tr/products/granule-sepiyolit/', label: 'Granül Sepiyolit' },
      { href: '/tr/products/ogutulmus-sepiyolit-tozu/', label: 'Öğütülmüş Toz' },
      { href: '/tr/products/sondaj-kalitesi-sepiyolit/', label: 'Sondaj Kalitesi' },
      { href: '/tr/products/tarimsal-sepiyolit/', label: 'Tarımsal Kalite' },
      { href: '/tr/products/insaat-yalitim-kalitesi/', label: 'İnşaat Kalitesi' },
    ]
  : [
      { href: '/products/raw-sepiolite-ore/', label: 'Raw Sepiolite Ore' },
      { href: '/products/granulated-sepiolite/', label: 'Granulated Sepiolite' },
      { href: '/products/milled-sepiolite-powder/', label: 'Milled Powder' },
      { href: '/products/drilling-grade-sepiolite/', label: 'Drilling Grade' },
      { href: '/products/agricultural-sepiolite/', label: 'Agricultural Grade' },
      { href: '/products/construction-insulation-grade/', label: 'Construction Grade' },
    ];

const appLinks = isTr
  ? [
      { href: '/tr/applications/evcil-hayvan-kedi-kumu/', label: 'Evcil Hayvan Bakımı' },
      { href: '/tr/applications/tarim/', label: 'Tarım' },
      { href: '/tr/applications/petrol-gaz-sondaj/', label: 'Petrol ve Gaz' },
      { href: '/tr/applications/insaat/', label: 'İnşaat' },
      { href: '/tr/applications/cevre-rehabilitasyon/', label: 'Çevre' },
      { href: '/tr/applications/ilac-kozmetik/', label: 'İlaç ve Kozmetik' },
    ]
  : [
      { href: '/applications/pet-care-cat-litter/', label: 'Pet Care' },
      { href: '/applications/agriculture/', label: 'Agriculture' },
      { href: '/applications/oil-gas-drilling/', label: 'Oil & Gas' },
      { href: '/applications/construction/', label: 'Construction' },
      { href: '/applications/environmental-remediation/', label: 'Environmental' },
      { href: '/applications/pharma-cosmetics/', label: 'Pharma & Cosmetics' },
    ];

const phoneHref = `tel:${BRAND.contact.phone.replace(/\s/g, '')}`;
const year = new Date().getFullYear();
---

<section class="footer-cta" aria-labelledby="footer-cta-heading">
  <div class="container" style="text-align:center;">
    <h2 id="footer-cta-heading">{labels.ctaHeading}</h2>
    <p>{labels.ctaBody}</p>
    <div class="footer-cta-actions">
      <a href={`${prefix}/contact/`} class="btn btn-dark">{labels.ctaContact}</a>
      <a href={`${prefix}/products/`} class="btn btn-outline-dark">{labels.ctaProducts}</a>
    </div>
  </div>
</section>

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={homeHref} class="footer-logo" aria-label={labels.logoAria}>
          <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <circle cx="22" cy="22" r="20.5" fill="rgba(201,146,42,0.07)" stroke="#C9922A" stroke-width="1.5"/>
            <path d="M6,34 L14,12 L19,18 L23,11 L28,34 Z" fill="#C9922A" opacity="0.20"/>
            <path d="M6,34 L14,12 L19,18 L23,11 L28,34" stroke="#C9922A" stroke-width="1.5" stroke-linejoin="round" fill="none"/>
            <line x1="23" y1="11" x2="25.5" y2="19" stroke="#C9922A" stroke-width="0.8" stroke-linecap="round" opacity="0.55"/>
            <rect x="29.5" y="18" width="7" height="16" fill="#C9922A" opacity="0.18"/>
            <rect x="29.5" y="18" width="7" height="16" stroke="#C9922A" stroke-width="1.3" fill="none"/>
            <path d="M29,18 Q33,13 37,18 Z" fill="#C9922A" opacity="0.28"/>
            <path d="M29,18 Q33,13 37,18" stroke="#C9922A" stroke-width="1.3" fill="none"/>
            <line x1="33" y1="13" x2="33" y2="9.5" stroke="#C9922A" stroke-width="1.6" stroke-linecap="round"/>
            <circle cx="33" cy="8.5" r="1.2" fill="#C9922A" opacity="0.55"/>
            <circle cx="34.2" cy="7.2" r="0.75" fill="#C9922A" opacity="0.3"/>
            <line x1="29.5" y1="22.5" x2="26" y2="22.5" stroke="#C9922A" stroke-width="1.2" stroke-linecap="round"/>
            <circle cx="26" cy="22.5" r="0.9" fill="#C9922A" opacity="0.55"/>
            <line x1="29.5" y1="28" x2="27" y2="28" stroke="#C9922A" stroke-width="1.2" stroke-linecap="round"/>
            <circle cx="27" cy="28" r="0.9" fill="#C9922A" opacity="0.55"/>
            <line x1="5" y1="34" x2="39" y2="34" stroke="#C9922A" stroke-width="1" stroke-linecap="round" opacity="0.35"/>
          </svg>
          <div style="display:flex;flex-direction:column;">
            <span class="nav-logo-main">{BRAND.name}</span>
            <span class="nav-logo-sub">by Zamana</span>
          </div>
        </a>
        <p>{labels.brandTagline}</p>
        <div class="footer-social">
          <a href="https://www.linkedin.com/in/murat-%C3%B6zsayg%C4%B1l%C4%B1-59790865/?locale=en" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">in</a>
          {/* C4: email icon links to contact form, NOT mailto: */}
          <a href={`${prefix}/contact/`} aria-label={labels.emailAria}>✉</a>
          <a href={phoneHref} aria-label={labels.phoneAria}>📞</a>
        </div>
      </div>

      <div class="footer-col">
        <h3>{labels.products}</h3>
        <ul>
          {productLinks.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h3>{labels.applications}</h3>
        <ul>
          {appLinks.map((a) => <li><a href={a.href}>{a.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h3>{labels.company}</h3>
        <ul>
          <li><a href={`${homeHref}#about`}>{labels.about}</a></li>
          <li><a href={`${prefix}/sustainability/`}>{labels.sustainability}</a></li>
          <li><a href={`${prefix}/markets/`}>{labels.markets}</a></li>
          <li><a href={`${prefix}/contact/`}>{labels.contact}</a></li>
          <li><a href="https://zamana.com.tr" rel="noopener noreferrer" target="_blank">Zamana</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {BRAND.name} {labels.copyright}</p>
      <div class="footer-legal">
        {/* Privacy & Terms are EN-only legal pages — link there from both locales. */}
        <a href="/privacy/">{labels.privacy}</a>
        <a href="/terms/">{labels.terms}</a>
        <a href="/sitemap-index.xml">{labels.sitemap}</a>
      </div>
    </div>
  </div>
</footer>
